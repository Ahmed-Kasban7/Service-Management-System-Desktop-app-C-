<Window x:Class="Presentation.View.EmployeeView.CreateEmployee"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterScreen"
        Title="إضافة موظف جديد" Height="820" Width="540"
        FlowDirection="RightToLeft"
        Background="#EEF2F7">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBlue" Color="#2563EB"/>
        <SolidColorBrush x:Key="DangerRed" Color="#E53935"/>
        <SolidColorBrush x:Key="DangerRedDark" Color="#B71C1C"/>

        <Style x:Key="FieldHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource DangerRed}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                        Background="{TemplateBinding Background}"
                        CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource DangerRedDark}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ErrorText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource DangerRed}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="Visibility" Value="Collapsed"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

       
        <Style x:Key="ModernDatePicker" TargetType="DatePicker">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <DatePickerTextBox x:Name="PART_TextBox"
                                               Grid.Column="0"
                                               Foreground="{TemplateBinding Foreground}"
                                               Background="Transparent"
                                               BorderThickness="0"
                                               Padding="{TemplateBinding Padding}"
                                               VerticalContentAlignment="Center"/>
                                <Button x:Name="PART_Button"
                                    Grid.Column="1"
                                    Width="32"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand">
                                    <TextBlock Text="📅" FontSize="16"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                </Button>
                                <Popup x:Name="PART_Popup"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#2563EB"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter Property="BorderBrush" Value="#2563EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="👤 إضافة موظف جديد"
                   FontSize="18" FontWeight="Bold"
                   Foreground="{StaticResource PrimaryBlue}"
                   Margin="0,0,0,12" TextAlignment="Center"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- ===== البيانات الأساسية ===== -->
                <Border Background="White" CornerRadius="12" Padding="18"
                        Margin="0,0,0,14" BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="👤 البيانات الأساسية"
                                   FontWeight="Bold" FontSize="15"
                                   Foreground="{StaticResource PrimaryBlue}"
                                   Margin="0,0,0,14"/>

                        <!-- الاسم -->
                        <TextBlock Style="{StaticResource FieldHeader}">
                            <Run Text="الاسم الكامل"/>
                            <Run Text=" *" Foreground="{StaticResource DangerRed}"/>
                        </TextBlock>
                        <TextBox x:Name="TxtName"
                                 Style="{StaticResource ModernTextBox}"
                                 Height="36" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtNameError"
                                   Foreground="{StaticResource DangerRed}"
                                   FontSize="11" Margin="0,0,0,12"
                                   Visibility="Collapsed"/>
                        
                        <TextBlock Style="{StaticResource FieldHeader}">
                            <Run Text="العنوان"/>
                        </TextBlock>
                        <TextBox x:Name="TxtAddress"
                                 Style="{StaticResource ModernTextBox}"
                                 Height="36" Margin="0,0,0,4"/>
                 

                        <!-- القسم + الدور -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- القسم -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource FieldHeader}">
        <Run Text="القسم"/>
        <Run Text=" *" Foreground="{StaticResource DangerRed}"/>
                                </TextBlock>
                                <ComboBox x:Name="CbDepartment"
              Style="{StaticResource ModernComboBox}"
              DisplayMemberPath="DepartmentName"
              SelectedValuePath="DepartmentId"
              Height="36"
              SelectionChanged="CbDepartment_SelectionChanged"/>
                                <TextBlock x:Name="TxtDepartmentError"
               Foreground="{StaticResource DangerRed}"
               FontSize="11" Margin="0,4,0,0"
               Visibility="Collapsed"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource FieldHeader}">
                                    <Run Text="الدور الوظيفي"/>
                                    <Run Text=" *" Foreground="{StaticResource DangerRed}"/>
                                </TextBlock>
                                <ComboBox x:Name="CbRole"
                                          Style="{StaticResource ModernComboBox}"
                                          DisplayMemberPath="RoleName"
                                          SelectedValuePath="RoleId"
                                          Height="36"/>
                                <TextBlock x:Name="TxtRoleError"
                                           Foreground="{StaticResource DangerRed}"
                                           FontSize="11" Margin="0,4,0,0"
                                           Visibility="Collapsed"/>
                            </StackPanel>
                        </Grid>

                        <!-- تاريخ التعيين -->
                        <!-- تاريخ التعيين -->
                        <TextBlock Style="{StaticResource FieldHeader}">
    <Run Text="تاريخ التعيين"/>
    <Run Text=" *" Foreground="{StaticResource DangerRed}"/>
                        </TextBlock>
                        <DatePicker x:Name="DpHireDate"
            Style="{StaticResource ModernDatePicker}"
            SelectedDateFormat="Short"/>
                        <TextBlock x:Name="TxtHireDateError"
           Foreground="{StaticResource DangerRed}"
           FontSize="11" Margin="0,4,0,0"
           Visibility="Collapsed"/>

                        <!-- العمر + الجنس -->
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- العمر -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="العمر"
                   Style="{StaticResource FieldHeader}"/>
                                <TextBox x:Name="TxtAge"
                 Style="{StaticResource ModernTextBox}"
                 Height="36"
                 FlowDirection="LeftToRight"
                 HorizontalContentAlignment="Right"/>
                                <TextBlock x:Name="TxtAgeError"
                   Foreground="{StaticResource DangerRed}"
                   FontSize="11" Margin="0,4,0,0"
                   Visibility="Collapsed"/>
                            </StackPanel>

                            <!-- الجنس -->
                            <!-- الجنس -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource FieldHeader}">
        <Run Text="الجنس"/>
        <Run Text=" *" Foreground="{StaticResource DangerRed}"/>
                                </TextBlock>
                                <ComboBox x:Name="CbSex"
              Style="{StaticResource ModernComboBox}"
              Height="36">
                                    <ComboBoxItem Content="ذكر" IsSelected="True"/>
                                    <ComboBoxItem Content="أنثى"/>
                                </ComboBox>
                                <TextBlock x:Name="TxtSexError"
               Foreground="{StaticResource DangerRed}"
               FontSize="11" Margin="0,4,0,0"
               Visibility="Collapsed"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ===== طريقة التعويض ===== -->
                <Border Background="White" CornerRadius="12" Padding="18"
                        Margin="0,0,0,14" BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel>
                        <!-- نوع الحساب -->
                        <TextBlock Style="{StaticResource FieldHeader}">
    <Run Text="نوع الحساب"/>
    <Run Text=" *" Foreground="{StaticResource DangerRed}"/>
                        </TextBlock>
                        <ComboBox x:Name="CbCompensationType"
          Style="{StaticResource ModernComboBox}"
          Height="36"
          Margin="0,0,0,4"
          SelectionChanged="CbCompensationType_SelectionChanged">
                            <ComboBoxItem Content="مرتب ثابت"            Tag="Salary" IsSelected="True"/>
                            <ComboBoxItem Content="نسبة"      Tag="Commission"/>
                            <ComboBoxItem Content="مرتب ثابت + نسبة"     Tag="Both"/>
                            <ComboBoxItem Content="بالمشوار" Tag="FullTrip"/>
                        </ComboBox>
                        <TextBlock x:Name="TxtCompensationTypeError"
           Foreground="{StaticResource DangerRed}"
           FontSize="11" Margin="0,0,0,10"
           Visibility="Collapsed"/>

                        <!-- المرتب -->
                        <StackPanel x:Name="PanelBaseSalary">
                            <TextBlock Style="{StaticResource FieldHeader}">
                                <Run Text="المرتب الأساسي (ج.م)"/>
                                <Run Text=" *" Foreground="{StaticResource DangerRed}"/>
                            </TextBlock>
                            <TextBox x:Name="TxtBaseSalary"
                                     Style="{StaticResource ModernTextBox}"
                                     Text="0" Height="36"
                                     FlowDirection="LeftToRight"
                                     HorizontalContentAlignment="Right"
                                     />

                            <TextBlock x:Name="TxtSalartError"
                                   Foreground="{StaticResource DangerRed}"
                                   FontSize="11" Margin="0,6,0,0"
                                   Visibility="Collapsed"/>
                        </StackPanel>

                        <!-- النسبة -->
                        <StackPanel x:Name="PanelCommission" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource FieldHeader}">
        <Run Text="نسبة العمولة %"/>
        <Run Text=" *" Foreground="{StaticResource DangerRed}"/>
                            </TextBlock>
                            <TextBox x:Name="TxtCommissionPercent"
             Style="{StaticResource ModernTextBox}"
             Text="0" Height="36"
             FlowDirection="LeftToRight"
             HorizontalContentAlignment="Right"/>
                        </StackPanel>

                        <TextBlock x:Name="TxtCompensationError"
                                   Foreground="{StaticResource DangerRed}"
                                   FontSize="11" Margin="0,6,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <!-- ===== أرقام الهاتف ===== -->
                <Border Background="White" CornerRadius="12" Padding="15" Margin="0,0,0,12" BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="📞 أرقام الهاتف" FontWeight="Bold" FontSize="14" Foreground="{StaticResource PrimaryBlue}" Margin="0,0,0,10"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBox x:Name="TxtNewPhone"
 Style="{StaticResource ModernTextBox}"
 Margin="0,0,8,0"
 Height="32"
 Grid.Row="0"
 Grid.Column="0"/>

                            <Button Grid.Row="0"
Grid.Column="1"
Content="إضافة"
Background="{StaticResource PrimaryBlue}"
Style="{StaticResource ActionButtonStyle}"
Height="32"
FontSize="12"
Click="BtnAddPhoneToList_Click"/>

                            <TextBlock x:Name="txtPhoneError"
   Grid.Row="1"
   Grid.Column="0"
   Text=""
   Foreground="Red"
   FontSize="11"
   Visibility="Visible"
   Margin="2,2,0,0"/>
                        </Grid>

                        <ListBox x:Name="LstPhones" Height="70" Background="#F8FAFC" BorderBrush="#E2E8F0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Width="400">
                                        <TextBlock Text="{Binding}" VerticalAlignment="Center" FontSize="13"/>
                                        <Button Content="🗑️" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" 
                                    Foreground="{StaticResource DangerRed}" Click="BtnRemovePhone_Click" Cursor="Hand"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>
                <!-- ===== المرفقات ===== -->
                <Border Background="White" CornerRadius="12" Padding="15"
                        Margin="0,0,0,14" BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="📎 المرفقات (صور البطاقة، عقود...)"
                                       FontWeight="Bold" FontSize="14"
                                       Foreground="{StaticResource PrimaryBlue}"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Content="➕ إضافة مرفق"
                                    Padding="12,6"
                                    Background="#EFF6FF"
                                    Foreground="{StaticResource PrimaryBlue}"
                                    BorderThickness="0" FontSize="12"
                                    Cursor="Hand"
                                    Click="BtnAddAttachment_Click"/>
                        </Grid>

                        <!-- قائمة المرفقات -->
                        <ItemsControl x:Name="ListAttachments">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F8FAFC" CornerRadius="8"
                                            BorderBrush="#E2E8F0" BorderThickness="1"
                                            Padding="10" Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Width="40" Height="40" Background="#EFF6FF" CornerRadius="6" Margin="0,0,10,0" ClipToBounds="True">
                                                <Image Source="{Binding FilePath}" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>



                                            <Button Grid.Column="2"
                                                    Content="🗑️"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Foreground="{StaticResource DangerRed}"
                                                    Cursor="Hand"
                                                    Click="BtnRemoveAttachment_Click"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock x:Name="TxtNoAttachments"
                                   Text="لا توجد مرفقات حتى الآن"
                                   Foreground="#94A3B8" FontSize="12"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
         Padding="0,16,0,0"
         BorderThickness="0,1,0,0"
         BorderBrush="{StaticResource BorderColor}">
            <StackPanel Orientation="Horizontal"
                 HorizontalAlignment="Center"
                 Margin="0,4,0,0">
                <Button x:Name="BtnSave"
                 Style="{StaticResource PrimaryButton}"
                 Click="BtnSave_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💾" Margin="0,0,6,0"/>
                        <TextBlock Text="حفظ"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnCancel"
                 Style="{StaticResource DangerButton}"
                 Margin="12,0,0,0"
                 Click="BtnCancel_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✖" Margin="0,0,6,0"/>
                        <TextBlock Text="إلغاء"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>