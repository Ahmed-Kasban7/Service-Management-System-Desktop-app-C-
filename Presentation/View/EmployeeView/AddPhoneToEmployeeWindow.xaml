<Window x:Class="Presentation.View.EmployeeView.AddPhoneToEmployeeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="إضافة رقم هاتف"
        Height="280" Width="400"
            SizeToContent="Height"
        MinHeight="280"
        WindowStartupLocation="CenterOwner"
        Background="#EEF2F7"
        FlowDirection="RightToLeft">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBlue" Color="#4169E1"/>
        <SolidColorBrush x:Key="SuccessGreen" Color="#27AE60"/>
        <SolidColorBrush x:Key="DangerRed" Color="#E53935"/>
        <SolidColorBrush x:Key="DangerRedDark" Color="#B71C1C"/>

        <Style x:Key="FieldHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="إضافة رقم هاتف" FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBlue}" HorizontalAlignment="Center"/>
        </StackPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="20"
        BorderBrush="#E2E8F0" BorderThickness="1">
            <StackPanel>
                <TextBlock Style="{StaticResource FieldHeader}">
            <Run Text="رقم الهاتف"/>
            <Run Text=" *" Foreground="{StaticResource DangerRed}"/>
                </TextBlock>
                <TextBox x:Name="TxtPhone" Style="{StaticResource ModernTextBox}"/>
                <TextBlock x:Name="TxtPhoneError"
                   Foreground="{StaticResource DangerRed}"
                   FontSize="12" Margin="0,6,0,0"
                   TextWrapping="Wrap"
                   Visibility="Collapsed"
                   MinHeight="20"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Padding="0,15,0,0"
                BorderThickness="0,1,0,0" BorderBrush="#CBD5E1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                <Button x:Name="BtnSave"
                 Content="✚ إضافة"
                        Width="130" Height="42"
                        Style="{StaticResource SuccessButton}" 
                        Foreground="White" FontWeight="Bold" Cursor="Hand"
                        Click="BtnSave_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.9"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="BtnCancel"
                        Content="❌ إلغاء"
                        Margin="15,0,0,0"
                        Width="100" Height="42"
                        Background="{StaticResource DangerRed}"
                        Foreground="White" FontWeight="Bold" Cursor="Hand"
                        Click="BtnCancel_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{StaticResource DangerRedDark}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </StackPanel>
        </Border>
    </Grid>
</Window>