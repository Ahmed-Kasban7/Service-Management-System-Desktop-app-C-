<UserControl x:Class="Presentation.View.OrderView.OrderDetailsUC"             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#EEF2F7"
             FlowDirection="RightToLeft">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Tabs -->
            <RowDefinition Height="*"/>
            <!-- Content -->
        </Grid.RowDefinitions>

        <!-- ===== HEADER ===== -->
        <Border Grid.Row="0" Background="White"
                BorderThickness="0,0,0,1" BorderBrush="#EDF2F7"
                Padding="24,16">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" Color="#000" Opacity="0.03" ShadowDepth="2"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- رقم الطلب + الحالة + التاريخ -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                        <!-- زر رجوع -->
                        <Button x:Name="BtnBack" Click="BtnBack_Click"
                                Width="32" Height="32"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Margin="0,0,12,0" VerticalAlignment="Center">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                        <Path Data="M8 4L2 10L8 16"
                                              Stroke="#64748B" StrokeThickness="2"
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Width="10" Height="14" Stretch="Uniform"
                                              FlowDirection="LeftToRight"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F1F5F9"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <TextBlock VerticalAlignment="Center" FontSize="22">
    <Run Text="طلب" 
         Foreground="#64748B" 
         FontWeight="Medium"/>
    
    <Run Text=" "/> <Run Text="{Binding OrderNumber, StringFormat='#{0}'}" 
         Foreground="#2563EB" 
         FontWeight="Bold" 
         FlowDirection="LeftToRight"/>
                        </TextBlock>
                        <Border x:Name="StatusBadge"
                                Background="#FEF9C3"
                                CornerRadius="20" Padding="12,4"
                                Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="TxtStatus"
                                       Text="قيد الانتظار"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="#CA8A04"/>
                        </Border>
                    </StackPanel>

                    <!-- التاريخ -->
                    <TextBlock x:Name="TxtCreatedDate"
                              Text="{Binding StartDate, StringFormat={}{0:dd/MM/yyyy}}"
                               FontSize="12" Foreground="#64748B"
                               Margin="44,4,0,0"/>
                </StackPanel>

                <Button Grid.Column="2" x:Name="BtnEditOrder"
                        Content="✏️ تعديل الطلب"
                        Click="BtnEditOrder_Click"
                        Padding="16,8"
                        Background="White"
                        Foreground="#1E293B"
                        FontSize="13" FontWeight="SemiBold"
                        BorderBrush="#E2E8F0" BorderThickness="1.5"
                        Cursor="Hand" VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="9" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F8FAFC"/>
                                    <Setter Property="BorderBrush" Value="#2563EB"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                
            </Grid>
        </Border>

        <!-- ===== TABS ===== -->
        <Border Grid.Row="1" Background="White"
                BorderThickness="0,0,0,1" BorderBrush="#F1F5F9"
                Padding="24,0">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="TabOrderInfo" Content="معلومات الطلب"
                        Click="TabOrderInfo_Click"
                        Padding="16,12" Background="Transparent"
                        BorderThickness="0,0,0,3" BorderBrush="#2563EB"
                        Foreground="#2563EB" FontWeight="SemiBold" FontSize="13" Cursor="Hand"/>

                <Button x:Name="TabAppointments" Content="المواعيد"
                        Click="TabAppointments_Click"
                        Padding="16,12" Background="Transparent"
                        BorderThickness="0,0,0,3" BorderBrush="Transparent"
                        Foreground="#64748B" FontSize="13" Cursor="Hand"/>

                <Button x:Name="TabVisits" Content="الزيارات"
                        Click="TabVisits_Click"
                        Padding="16,12" Background="Transparent"
                        BorderThickness="0,0,0,3" BorderBrush="Transparent"
                        Foreground="#64748B" FontSize="13" Cursor="Hand"/>

                <Button x:Name="TabInvoice" Content="الفاتورة"
                        Click="TabInvoice_Click"
                        Padding="16,12" Background="Transparent"
                        BorderThickness="0,0,0,3" BorderBrush="Transparent"
                        Foreground="#64748B" FontSize="13" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <!-- ===== CONTENT ===== -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <Grid Margin="24,20,24,24">

                <!-- TAB: معلومات الطلب -->
                <Grid x:Name="PanelOrderInfo" Visibility="Visible">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- بطاقة بيانات العميل -->
                    <Border Grid.Column="0" Grid.Row="0"
                            Background="White" CornerRadius="14"
                            BorderBrush="#E2E8F0" BorderThickness="1" Padding="20">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" Color="#000" Opacity="0.03" ShadowDepth="1"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="👤 بيانات العميل"
                                       FontSize="15" FontWeight="Bold"
                                       Foreground="#1E293B" Margin="0,0,0,16"/>

                            <StackPanel Margin="0,0,0,14">
                                <TextBlock Text="الاسم" FontSize="11"
                                           Foreground="#94A3B8" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="28" Height="28" Background="#EEF2FF"
                                            CornerRadius="14" Margin="0,0,8,0">
                                        <TextBlock Text="👤" FontSize="13"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock  Text="{Binding CustomerName}"
                                               FontSize="15" FontWeight="SemiBold"
                                               Foreground="#0F172A" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>

                            <Border Height="1" Background="#F1F5F9" Margin="0,0,0,14"/>

                            <TextBlock Text="التواصل" FontSize="11"
                                       Foreground="#94A3B8" Margin="0,0,0,8"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="📞" FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock  Text="{Binding CustomerPhones}"
                                           FontSize="14" Foreground="#374151"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📍" FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock  Text="{Binding Address}"
                                           FontSize="14" Foreground="#374151" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- بطاقة تفاصيل العطل -->
                    <Border Grid.Column="2" Grid.Row="0"
                            Background="White" CornerRadius="14"
                            BorderBrush="#E2E8F0" BorderThickness="1"
                            Padding="20">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" Color="#000" Opacity="0.03" ShadowDepth="1"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="🔧 تفاصيل العطل"
                                       FontSize="15" FontWeight="Bold"
                                       Foreground="#1E293B" Margin="0,0,0,16"/>

                            <!-- الوصف -->
                            <StackPanel Margin="0,0,0,14">
                                <TextBlock Text="وصف العطل"
                                           FontSize="11" Foreground="#94A3B8"
                                           Margin="0,0,0,6"/>
                                <Border Background="#F8FAFC" CornerRadius="8"
                                        BorderBrush="#E2E8F0" BorderThickness="1"
                                        Padding="12">
                                    <TextBlock x:Name="TxtIssueDescription"
                                               Text="{Binding Problem}"
                                               FontSize="14" Foreground="#374151"
                                               TextWrapping="Wrap" LineHeight="22"/>
                                </Border>
                            </StackPanel>

                            <Border Height="1" Background="#F1F5F9" Margin="0,0,0,14"/>

                            <!-- الملاحظات -->
                            <StackPanel>
                                <TextBlock Text="ملاحظات"
                                           FontSize="11" Foreground="#94A3B8"
                                           Margin="0,0,0,6"/>
                                <Border Background="#F8FAFC" CornerRadius="8"
                                        BorderBrush="#E2E8F0" BorderThickness="1"
                                        Padding="12">
                                    <TextBlock x:Name="TxtNotes"
                                               Text="{Binding Notes}"
                                               FontSize="14" Foreground="#374151"
                                               TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <!-- بطاقة بيانات الجهاز -->
                    <Border Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="3"
                            Background="White" CornerRadius="14"
                            BorderBrush="#E2E8F0" BorderThickness="1" Padding="20">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" Color="#000" Opacity="0.03" ShadowDepth="1"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="🧺 بيانات الجهاز"
                                       FontSize="15" FontWeight="Bold"
                                       Foreground="#1E293B" Margin="0,0,0,16"/>
                            <WrapPanel>
                                <Border Background="#F1F5F9" CornerRadius="10" Padding="14,10" Margin="0,0,12,8">
                                    <StackPanel>
                                        <TextBlock Text="نوع الجهاز" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="TxtDeviceType" Text="{Binding CustomerDevice.TypeName}"
                                                   FontSize="14" FontWeight="SemiBold" Foreground="#1E293B"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#F1F5F9" CornerRadius="10" Padding="14,10" Margin="0,0,12,8">
                                    <StackPanel>
                                        <TextBlock Text="الماركة" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="TxtDeviceBrand" Text="{Binding CustomerDevice.BrandName}"
                                                   FontSize="14" FontWeight="SemiBold" Foreground="#1E293B"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#F1F5F9" CornerRadius="10" Padding="14,10" Margin="0,0,12,8">
                                    <StackPanel>
                                        <TextBlock Text="الموصفات" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="TxtDeviceSpec" Text="{Binding CustomerDevice.SpecName}"
                                            FontSize="14" FontWeight="SemiBold" Foreground="#1E293B"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#F1F5F9" CornerRadius="10" Padding="14,10" Margin="0,0,12,8">
                                    <StackPanel>
                                        <TextBlock Text="الموديل" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="TxtDeviceModel" Text="{Binding CustomerDevice.Model}"
                                                   FontSize="14" FontWeight="SemiBold" Foreground="#1E293B"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#F1F5F9" CornerRadius="10" Padding="14,10" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="الرقم التسلسلي" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="TxtSerialNumber" Text="{Binding CustomerDevice.SerialNumber}"
                                                   FontSize="14" FontWeight="SemiBold" Foreground="#1E293B"/>
                                    </StackPanel>
                                </Border>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- TAB: المواعيد -->
                <Border x:Name="PanelAppointments" Visibility="Collapsed"
                        Background="White" CornerRadius="14"
                        BorderBrush="#E2E8F0" BorderThickness="1" Padding="20">
                    <StackPanel>
                        <TextBlock Text="📅 المواعيد" FontSize="15" FontWeight="Bold"
                                   Foreground="#1E293B" Margin="0,0,0,16"/>
                        <TextBlock Text="لا توجد مواعيد مسجلة" Foreground="#94A3B8"
                                   FontSize="13" HorizontalAlignment="Center" Margin="0,40,0,40"/>
                    </StackPanel>
                </Border>

                <!-- TAB: الزيارات -->
                <Border x:Name="PanelVisits" Visibility="Collapsed"
                        Background="White" CornerRadius="14"
                        BorderBrush="#E2E8F0" BorderThickness="1" Padding="20">
                    <StackPanel>
                        <TextBlock Text="🔍 الزيارات" FontSize="15" FontWeight="Bold"
                                   Foreground="#1E293B" Margin="0,0,0,16"/>
                        <TextBlock Text="لا توجد زيارات مسجلة" Foreground="#94A3B8"
                                   FontSize="13" HorizontalAlignment="Center" Margin="0,40,0,40"/>
                    </StackPanel>
                </Border>

                <!-- TAB: الفاتورة -->
                <Border x:Name="PanelInvoice" Visibility="Collapsed"
                        Background="White" CornerRadius="14"
                        BorderBrush="#E2E8F0" BorderThickness="1" Padding="20">
                    <StackPanel>
                        <TextBlock Text="🧾 الفاتورة" FontSize="15" FontWeight="Bold"
                                   Foreground="#1E293B" Margin="0,0,0,16"/>
                        <TextBlock Text="لا توجد فاتورة بعد" Foreground="#94A3B8"
                                   FontSize="13" HorizontalAlignment="Center" Margin="0,40,0,40"/>
                    </StackPanel>
                </Border>

            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>