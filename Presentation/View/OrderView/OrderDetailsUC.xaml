<UserControl x:Class="Presentation.View.OrderView.OrderDetailsUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:gl="clr-namespace:System.Globalization;assembly=mscorlib"
             FlowDirection="RightToLeft"
             Language="ar-EG">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Tabs -->
            <RowDefinition Height="*"/>
            <!-- Content -->
        </Grid.RowDefinitions>

        <!-- ===== HEADER ===== -->
        <Border Grid.Row="0" Background="White"
                BorderThickness="0,0,0,1" BorderBrush="#EDF2F7"
                Padding="24,16">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" Color="#000" Opacity="0.03" ShadowDepth="2"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- رقم الطلب + الحالة + التاريخ -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                        <!-- زر رجوع -->
                        <Button x:Name="BtnBack" Click="BtnBack_Click"
                                Width="32" Height="32"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Margin="0,0,12,0" VerticalAlignment="Center">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                        <Path Data="M8 4L2 10L8 16"
                                              Stroke="#64748B" StrokeThickness="2"
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Width="10" Height="14" Stretch="Uniform"
                                              FlowDirection="LeftToRight"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F1F5F9"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <TextBlock VerticalAlignment="Center" FontSize="22">
    <Run Text="طلب" 
         Foreground="#64748B" 
         FontWeight="Medium"/>
    
    <Run Text=" "/> <Run Text="{Binding OrderNumber, StringFormat='#{0}'}" 
         Foreground="#2563EB" 
         FontWeight="Bold" 
         FlowDirection="LeftToRight"/>
                        </TextBlock>
                        <Border x:Name="StatusBadge"
        Background="{Binding StatusBackground}"
        CornerRadius="20" Padding="12,4"
        Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="TxtStatus"
               Text="{Binding State}"
               FontSize="12" FontWeight="SemiBold"
               Foreground="{Binding StatusForeground}"/>
                        </Border>
                    </StackPanel>

                    <!-- التاريخ -->
                    <TextBlock x:Name="TxtCreatedDate"
                              Text="{Binding StartDate, StringFormat={}{0:dd/MM/yyyy}}"
                               FontSize="12" Foreground="#64748B"
                               Margin="44,4,0,0"/>
                </StackPanel>

                <Button Grid.Column="2" x:Name="BtnEditOrder"
                        Content="✏️ تعديل الطلب"
                        Click="BtnEditOrder_Click"
                        Padding="16,
                        
                        8"
                        Background="White"
                        Foreground="#1E293B"
                        FontSize="13" FontWeight="SemiBold"
                        BorderBrush="#E2E8F0" BorderThickness="1.5"
                        Cursor="Hand" VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="9" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F8FAFC"/>
                                    <Setter Property="BorderBrush" Value="#2563EB"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                
            </Grid>
        </Border>

        <!-- ===== TABS ===== -->
        <Border Grid.Row="1" Background="White"
                BorderThickness="0,0,0,1" BorderBrush="#F1F5F9"
                Padding="24,0">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="TabOrderInfo" Content="معلومات الطلب"
                        Click="TabOrderInfo_Click"
                        Padding="16,12" Background="Transparent"
                        BorderThickness="0,0,0,3" BorderBrush="#2563EB"
                        Foreground="#2563EB" FontWeight="SemiBold" FontSize="13" Cursor="Hand"/>

                <Button x:Name="TabAppointments" Content="المواعيد"
                        Click="TabAppointments_Click"
                        Padding="16,12" Background="Transparent"
                        BorderThickness="0,0,0,3" BorderBrush="Transparent"
                        Foreground="#64748B" FontSize="13" Cursor="Hand"/>

    

                <Button x:Name="TabInvoice" Content="الفاتورة"
                        Click="TabInvoice_Click"
                        Padding="16,12" Background="Transparent"
                        BorderThickness="0,0,0,3" BorderBrush="Transparent"
                        Foreground="#64748B" FontSize="13" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <!-- ===== CONTENT ===== -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <Grid Margin="24,20,24,24">

                <!-- TAB: معلومات الطلب -->
                <ScrollViewer x:Name="ScrollOrderInfo" VerticalScrollBarVisibility="Auto" Visibility="Visible">
                    <Grid x:Name="PanelOrderInfo" Visibility="Visible">
                        <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>


                    <!-- بطاقة بيانات العميل -->
                    <Border Grid.Column="0" Grid.Row="0"
                            Background="White" CornerRadius="14"
                            BorderBrush="#E2E8F0" BorderThickness="1" Padding="20">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" Color="#000" Opacity="0.03" ShadowDepth="1"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="👤 بيانات العميل"
                                       FontSize="15" FontWeight="Bold"
                                       Foreground="#1E293B" Margin="0,0,0,16"/>

                            <StackPanel Margin="0,0,0,14">
                                <TextBlock Text="الاسم" FontSize="11"
                                           Foreground="#94A3B8" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="28" Height="28" Background="#EEF2FF"
                                            CornerRadius="14" Margin="0,0,8,0">
                                        <TextBlock Text="👤" FontSize="13"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock  Text="{Binding CustomerName}"
                                               FontSize="15" FontWeight="SemiBold"
                                               Foreground="#0F172A" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>

                            <Border Height="1" Background="#F1F5F9" Margin="0,0,0,14"/>

                            <TextBlock Text="التواصل" FontSize="11"
                                       Foreground="#94A3B8" Margin="0,0,0,8"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="📞" FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock  Text="{Binding CustomerPhones}"
                                           FontSize="14" Foreground="#374151"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📍" FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock  Text="{Binding Address}"
                                           FontSize="14" Foreground="#374151" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- بطاقة تفاصيل العطل -->
                    <Border Grid.Column="2" Grid.Row="0"
                            Background="White" CornerRadius="14"
                            BorderBrush="#E2E8F0" BorderThickness="1"
                            Padding="20">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" Color="#000" Opacity="0.03" ShadowDepth="1"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="🔧 تفاصيل العطل"
                                       FontSize="15" FontWeight="Bold"
                                       Foreground="#1E293B" Margin="0,0,0,16"/>

                            <!-- الوصف -->
                            <StackPanel Margin="0,0,0,14">
                                <TextBlock Text="وصف العطل"
                                           FontSize="11" Foreground="#94A3B8"
                                           Margin="0,0,0,6"/>
                                <Border Background="#F8FAFC" CornerRadius="8"
                                        BorderBrush="#E2E8F0" BorderThickness="1"
                                        Padding="12">
                                    <TextBlock x:Name="TxtIssueDescription"
                                               Text="{Binding Problem}"
                                               FontSize="14" Foreground="#374151"
                                               TextWrapping="Wrap" LineHeight="22"/>
                                </Border>
                            </StackPanel>

                            <Border Height="1" Background="#F1F5F9" Margin="0,0,0,14"/>

                            <!-- الملاحظات -->
                            <StackPanel>
                                <TextBlock Text="ملاحظات"
                                           FontSize="11" Foreground="#94A3B8"
                                           Margin="0,0,0,6"/>
                                <Border Background="#F8FAFC" CornerRadius="8"
                                        BorderBrush="#E2E8F0" BorderThickness="1"
                                        Padding="12">
                                    <TextBlock x:Name="TxtNotes"
                                               Text="{Binding Notes}"
                                               FontSize="14" Foreground="#374151"
                                               TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <!-- بطاقة بيانات الجهاز -->
                    <Border Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="3"
                            Background="White" CornerRadius="14"
                            BorderBrush="#E2E8F0" BorderThickness="1" Padding="20">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" Color="#000" Opacity="0.03" ShadowDepth="1"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="🧺 بيانات الجهاز"
                                       FontSize="15" FontWeight="Bold"
                                       Foreground="#1E293B" Margin="0,0,0,16"/>
                            <WrapPanel>
                                <Border Background="#F1F5F9" CornerRadius="10" Padding="14,10" Margin="0,0,12,8">
                                    <StackPanel>
                                        <TextBlock Text="نوع الجهاز" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="TxtDeviceType" Text="{Binding CustomerDevice.TypeName}"
                                                   FontSize="14" FontWeight="SemiBold" Foreground="#1E293B"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#F1F5F9" CornerRadius="10" Padding="14,10" Margin="0,0,12,8">
                                    <StackPanel>
                                        <TextBlock Text="الماركة" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="TxtDeviceBrand" Text="{Binding CustomerDevice.BrandName}"
                                                   FontSize="14" FontWeight="SemiBold" Foreground="#1E293B"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#F1F5F9" CornerRadius="10" Padding="14,10" Margin="0,0,12,8">
                                    <StackPanel>
                                        <TextBlock Text="الموصفات" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="TxtDeviceSpec" Text="{Binding CustomerDevice.SpecName}"
                                            FontSize="14" FontWeight="SemiBold" Foreground="#1E293B"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#F1F5F9" CornerRadius="10" Padding="14,10" Margin="0,0,12,8">
                                    <StackPanel>
                                        <TextBlock Text="الموديل" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="TxtDeviceModel" Text="{Binding CustomerDevice.Model}"
                                                   FontSize="14" FontWeight="SemiBold" Foreground="#1E293B"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#F1F5F9" CornerRadius="10" Padding="14,10" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="الرقم التسلسلي" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="TxtSerialNumber" Text="{Binding CustomerDevice.SerialNumber}"
                                                   FontSize="14" FontWeight="SemiBold" Foreground="#1E293B"/>
                                    </StackPanel>
                                </Border>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </Grid>
                </ScrollViewer>


                <!-- TAB: المواعيد -->
                <Border x:Name="PanelAppointments" Visibility="Collapsed" Background="White" CornerRadius="14" BorderBrush="#E2E8F0" BorderThickness="1" Padding="20">
                    <Grid>
                        <!-- الـ Grid الرئيسي للمواعيد والـ Empty State -->
                        <Grid x:Name="GridAppointmentsMain" Visibility="Visible">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Header -->
                            <Grid Grid.Row="0" Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="📅 المواعيد المسجلة" FontSize="15" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" x:Name="BtnAddAppointment" Content="➕ إضافة موعد" Click="BtnAddAppointment_Click" Padding="16,8" Background="#2563EB" Foreground="White" FontSize="13" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#1D4ED8"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>

                            <!-- Cards / Empty State -->
                            <Grid Grid.Row="1">
                                <!-- Empty State -->
                                <Border x:Name="AppointmentsEmptyState" Background="#F8FAFC" CornerRadius="10" BorderBrush="#E2E8F0" BorderThickness="1" Padding="40" Visibility="Collapsed">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="📅" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                        <TextBlock Text="لا توجد مواعيد مسجلة حتى الآن" Foreground="#94A3B8" FontSize="13" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- Cards List -->
                                <ItemsControl x:Name="AppointmentsGrid" Visibility="Collapsed">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1" Padding="20" Margin="0,0,0,12">
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="8" Color="#000" Opacity="0.05" ShadowDepth="1"/>
                                                </Border.Effect>
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <!-- Row 0: التاريخ + الحالة -->
                                                    <Grid Grid.Row="0" Margin="0,0,0,14">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                            <Border Background="#EFF6FF" CornerRadius="8" Padding="8,6" Margin="0,0,10,0">
                                                                <TextBlock Text="📅" FontSize="16"/>
                                                            </Border>
                                                            <StackPanel VerticalAlignment="Center">
                                                                <TextBlock Text="تاريخ الموعد" FontSize="10" Foreground="#94A3B8" Margin="0,0,0,2"/>
                                                                <TextBlock Text="{Binding ScheduledDate, StringFormat={}{0:dd/MM/yyyy}}" FontSize="15" FontWeight="Bold" Foreground="#0F172A"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <Border Grid.Column="1" CornerRadius="20" Padding="14,5" VerticalAlignment="Center">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#F1F5F9"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding AppointmentState}" Value="0">
                                                                            <Setter Property="Background" Value="#FEF9C3"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding AppointmentState}" Value="1">
                                                                            <Setter Property="Background" Value="#FEE2E2"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding AppointmentState}" Value="2">
                                                                            <Setter Property="Background" Value="#DCFCE7"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding AppointmentState}" Value="3">
                                                                            <Setter Property="Background" Value="#F1F5F9"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="{Binding AppointmentStateName}" FontSize="12" FontWeight="SemiBold">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="#64748B"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding AppointmentState}" Value="0">
                                                                                <Setter Property="Foreground" Value="#CA8A04"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding AppointmentState}" Value="1">
                                                                                <Setter Property="Foreground" Value="#DC2626"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding AppointmentState}" Value="2">
                                                                                <Setter Property="Foreground" Value="#16A34A"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding AppointmentState}" Value="3">
                                                                                <Setter Property="Foreground" Value="#64748B"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>
                                                    </Grid>
                                                    <Border Grid.Row="1" Height="1" Background="#F1F5F9" Margin="0,0,0,14"/>

                                                    <!-- Row 2: البيانات الفرعية -->
                                                    <Grid Grid.Row="2" Margin="0,0,0,16">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="1.2*"/>
                                                            <ColumnDefinition Width="1.2*"/>
                                                            <ColumnDefinition Width="1.2*"/>
                                                            <ColumnDefinition Width="1.5*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="نوع الزيارة" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,6"/>
                                                            <Border Background="#F8FAFC" CornerRadius="8" Padding="10,6" HorizontalAlignment="Left">
                                                                <TextBlock Text="{Binding VisitTypeName}" FontSize="13" FontWeight="SemiBold" Foreground="#2563EB"/>
                                                            </Border>
                                                        </StackPanel>

                                                      


                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="الفني" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,6"/>
                                                            <StackPanel Orientation="Horizontal">
                                                                <Border Width="28" Height="28" CornerRadius="14" Background="#EEF2FF" Margin="0,0,8,0">
                                                                    <TextBlock Text="👤" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <TextBlock Text="{Binding TechnicianName}" FontSize="13" FontWeight="SemiBold" Foreground="#1E293B" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="2">
                                                            <TextBlock Text="مساعد الفني" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,6"/>
                                                            <StackPanel Orientation="Horizontal">
                                                                <Border Width="28" Height="28" CornerRadius="14" Background="#F0FDF4" Margin="0,0,8,0">
                                                                    <TextBlock Text="👤" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#1E293B" VerticalAlignment="Center">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Text" Value="{Binding AssistantName}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding AssistantName}" Value="{x:Null}">
                                                                                    <Setter Property="Text" Value="—"/>
                                                                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </StackPanel>
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="3">
                                                            <TextBlock Text="السائق" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,6"/>
                                                            <StackPanel Orientation="Horizontal">
                                                                <Border Width="28" Height="28" CornerRadius="14" Background="#FFF7ED" Margin="0,0,8,0">
                                                                    <TextBlock Text="🚗" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#1E293B" VerticalAlignment="Center">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Text" Value="{Binding DriverName}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding DriverName}" Value="{x:Null}">
                                                                                    <Setter Property="Text" Value="—"/>
                                                                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </StackPanel>
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="4">
                                                            <TextBlock Text="ملاحظات" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,6"/>
                                                            <TextBlock FontSize="13" TextWrapping="Wrap" MaxHeight="44">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Text" Value="{Binding Notes}"/>
                                                                        <Setter Property="Foreground" Value="#1E293B"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Notes}" Value="">
                                                                                <Setter Property="Text" Value="لا توجد ملاحظات"/>
                                                                                <Setter Property="Foreground" Value="#CBD5E1"/>
                                                                                <Setter Property="FontStyle" Value="Italic"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Notes}" Value="{x:Null}">
                                                                                <Setter Property="Text" Value="لا توجد ملاحظات"/>
                                                                                <Setter Property="Foreground" Value="#CBD5E1"/>
                                                                                <Setter Property="FontStyle" Value="Italic"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="5" Margin="20,0,0,0">
                                                            <StackPanel.Style>
                                                                <Style TargetType="StackPanel">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding AppointmentState}" Value="3">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </StackPanel.Style>
                                                            <TextBlock Text="سبب الإلغاء ⚠️" FontSize="11" Foreground="#EF4444" Margin="0,0,0,6"/>
                                                            <TextBlock FontSize="13" TextWrapping="Wrap" MaxHeight="44">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Text" Value="{Binding CancelReason}"/>
                                                                        <Setter Property="Foreground" Value="#B91C1C"/>
                                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding CancelReason}" Value="{x:Null}">
                                                                                <Setter Property="Text" Value="لم يتم تحديد السبب"/>
                                                                                <Setter Property="FontStyle" Value="Italic"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding CancelReason}" Value="">
                                                                                <Setter Property="Text" Value="لم يتم تحديد السبب"/>
                                                                                <Setter Property="FontStyle" Value="Italic"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Grid>

