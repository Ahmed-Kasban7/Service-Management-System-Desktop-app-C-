                                                            <Button.Style>
                                                                <Style TargetType="Button">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding AppointmentState}" Value="2">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding AppointmentState}" Value="3">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                            <TextBlock Text="✏️" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                                            <TextBlock Text="تعديل" Foreground="#2563EB" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>

                                                        <Button Width="110" Height="36" Background="#FEE2E2" BorderBrush="#FCA5A5" BorderThickness="1" Cursor="Hand" Margin="0,0,10,0" Tag="{Binding AppointmentId}" Click="BtnCancelAppointment_Click">
                                                            <Button.Style>
                                                                <Style TargetType="Button">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding AppointmentState}" Value="2">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding AppointmentState}" Value="3">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                            <TextBlock Text="❌" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                                            <TextBlock Text="إلغاء الموعد" Foreground="#DC2626" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>

                                                        <!-- تسجيل تقرير الزيارة -->
                                                        <Button Width="150" Height="36" Background="#DCFCE7" BorderBrush="#BBF7D0" BorderThickness="1" Cursor="Hand" Tag="{Binding AppointmentId}" Click="BtnRecordVisit_Click">
                                                            <Button.Style>
                                                                <Style TargetType="Button">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding AppointmentState}" Value="2">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding AppointmentState}" Value="3">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                            <TextBlock Text="📝" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                                            <TextBlock Text="تسجيل تقرير الزيارة" Foreground="#16A34A" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>

                                                        <!-- زرار عرض تقرير الزيارة المحدث -->
                                                        <Button Width="150" Height="36" Background="#DBEAFE" BorderBrush="#BFDBFE" BorderThickness="1" Cursor="Hand" Tag="{Binding AppointmentId}" Click="BtnViewVisit_Click">
                                                            <Button.Style>
                                                                <Style TargetType="Button">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding AppointmentState}" Value="2">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                            <TextBlock Text="📄" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                                            <TextBlock Text="تقرير الزيارة" Foreground="#2563EB" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Grid>

                        <!-- ================================================================= -->
                        <!-- 🔥 جديد: كارد تفاصيل الزيارة المضمن (In-line Details View) -->
                        <!-- ================================================================= -->
                        <!-- ================================================================= -->
                        <!-- 🔥 تقرير الزيارة (In-line Details View) - نسخة تعمل مباشرة -->
                        <!-- ================================================================= -->
                        <Grid x:Name="PanelVisitDetailsView" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- شريط العودة مع معلومات الموعد -->
                            <!-- شريط العودة + معلومات الفني (دمج في بورد واحد) -->
                            <Border Grid.Row="0" Background="White" CornerRadius="12" 
        BorderBrush="#E2E8F0" BorderThickness="1"
        Padding="16" Margin="0,0,0,16">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="6" Color="#000" Opacity="0.03" ShadowDepth="1"/>
                                </Border.Effect>

                                <StackPanel>
                                    <!-- الصف الأول: زر العودة + عنوان التقرير + الحالة -->
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- زر العودة -->
                                        <Button Grid.Column="0" x:Name="BtnBackToAppointments" 
                    Click="BtnBackToAppointments_Click" 
                    Background="#F1F5F9" BorderThickness="0" 
                    Cursor="Hand" Padding="10,6">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="➜" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="العودة للمواعيد" FontSize="12" FontWeight="SemiBold" 
                                           Foreground="#475569" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#E2E8F0"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>

                                        <!-- عنوان التقرير -->
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                            <TextBlock Text="📄 تقرير الزيارة" 
               FontSize="18" FontWeight="Bold" 
               Foreground="#1E293B" HorizontalAlignment="Center"
               Margin="0,0,0,6"/>
                                            <Border Background="#F1F5F9" CornerRadius="12" 
            Padding="12,4" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding ScheduledDate, StringFormat='📅 {0:dd/MM/yyyy}'}" 
                   FontSize="12" Foreground="#64748B" 
                   FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>

                                        <!-- حالة التقرير -->
                                        <Border Grid.Column="2" CornerRadius="20" Padding="12,5"
                    Background="#DCFCE7" VerticalAlignment="Center">
                                            <TextBlock Text="✓ مكتمل" FontSize="11" FontWeight="SemiBold" 
                           Foreground="#16A34A"/>
                                        </Border>
                                    </Grid>

                                    <!-- خط فاصل -->
                                    <Border Height="1" Background="#F1F5F9" Margin="0,0,0,14"/>

                                    <!-- الصف الثاني: معلومات الفني -->
                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- نوع الزيارة -->
                                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock Text="نوع الزيارة" FontSize="10" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                            <Border Background="#EFF6FF" CornerRadius="8" Padding="12,6" HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding VisitTypeName}" FontSize="13" FontWeight="SemiBold" Foreground="#2563EB"/>
                                            </Border>
                                        </StackPanel>

                                        <!-- الفني المسؤول -->
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,12,0">
                                            <Border Width="34" Height="34" Background="#EEF2FF" CornerRadius="17" Margin="0,0,10,0">
                                                <TextBlock Text="👤" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="الفني" FontSize="10" Foreground="#94A3B8" Margin="0,0,0,2"/>
                                                <TextBlock Text="{Binding TechnicianName, FallbackValue='—'}" 
                       FontSize="13" FontWeight="SemiBold" Foreground="#1E293B"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- مساعد الفني -->
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,12,0">
                                            <Border Width="34" Height="34" Background="#F0FDF4" CornerRadius="17" Margin="0,0,10,0">
                                                <TextBlock Text="👤" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="مساعد الفني" FontSize="10" Foreground="#94A3B8" Margin="0,0,0,2"/>
                                                <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#1E293B">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="{Binding AssistantName, FallbackValue='—'}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding AssistantName}" Value="{x:Null}">
                                                                    <Setter Property="Text" Value="—"/>
                                                                    <Setter Property="Foreground" Value="#CBD5E1"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding AssistantName}" Value="">
                                                                    <Setter Property="Text" Value="—"/>
                                                                    <Setter Property="Foreground" Value="#CBD5E1"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- السائق -->
                                        <StackPanel Grid.Column="3" Orientation="Horizontal">
                                            <Border Width="34" Height="34" Background="#FFF7ED" CornerRadius="17" Margin="0,0,10,0">
                                                <TextBlock Text="🚗" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="السائق" FontSize="10" Foreground="#94A3B8" Margin="0,0,0,2"/>
                                                <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#1E293B">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="{Binding DriverName, FallbackValue='—'}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DriverName}" Value="{x:Null}">
                                                                    <Setter Property="Text" Value="—"/>
                                                                    <Setter Property="Foreground" Value="#CBD5E1"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding DriverName}" Value="">
                                                                    <Setter Property="Text" Value="—"/>
                                                                    <Setter Property="Foreground" Value="#CBD5E1"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                            
                            <!-- محتوى التقرير -->
                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                <StackPanel>

                                    <!-- بطاقة المعلومات الأساسية -->
                                    <Border Background="White" CornerRadius="12" 
        BorderBrush="#E2E8F0" BorderThickness="1"
        Padding="20" Margin="0,0,0,14">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="6" Color="#000" Opacity="0.03" ShadowDepth="1"/>
                                        </Border.Effect>

                                        <StackPanel>

                                            <!-- ===== 1. التشخيص ===== -->
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <Border Background="#EFF6FF" CornerRadius="6" Padding="6,3" Margin="0,0,8,0">
                                                        <TextBlock Text="🔍" FontSize="14"/>
                                                    </Border>
                                                    <TextBlock Text="تشخيص الفني" FontSize="13" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <Border Background="#F8FAFC" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Padding="14,12">
                                                    <TextBlock Text="{Binding Diagnosis}" FontSize="14" Foreground="#374151" TextWrapping="Wrap" LineHeight="26" Padding="4,0"/>
                                                </Border>
                                            </StackPanel>

                                            <!-- ===== 2. الإجراءات (تم إضافة Margin علوي 20) ===== -->
                                            <StackPanel x:Name="PanelActions" Margin="0,20,0,0">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ActionsTaken}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ActionsTaken}" Value="">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ActionsTaken}" Value=" ">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ActionsTaken}" Value="  ">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>

                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <Border Background="#F0FDF4" CornerRadius="6" Padding="6,3" Margin="0,0,8,0">
                                                        <TextBlock Text="🛠️" FontSize="14"/>
                                                    </Border>
                                                    <TextBlock Text="الإجراءات المتخذة" FontSize="13" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <Border Background="#F8FAFC" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Padding="14,12">
                                                    <TextBlock Text="{Binding ActionsTaken, FallbackValue=''}" FontSize="14" Foreground="#374151" TextWrapping="Wrap" LineHeight="26" Padding="4,0"/>
                                                </Border>
                                            </StackPanel>

                                            <!-- ===== 3. الملاحظات (تم إضافة Margin علوي 20) ===== -->
                                            <StackPanel x:Name="PanelNotes" Margin="0,20,0,0">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Notes}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Notes}" Value="">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Notes}" Value=" ">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Notes}" Value="  ">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>

                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <Border Background="#FFF7ED" CornerRadius="6" Padding="6,3" Margin="0,0,8,0">
                                                        <TextBlock Text="📝" FontSize="14"/>
                                                    </Border>
                                                    <TextBlock Text="الملاحظات" FontSize="13" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <Border Background="#F8FAFC" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Padding="14,12">
                                                    <TextBlock Text="{Binding Notes}" FontSize="14" Foreground="#374151" TextWrapping="Wrap" LineHeight="26" Padding="4,0"/>
                                                </Border>
                                            </StackPanel>

                                        </StackPanel>
                                    </Border>

                                    <!-- قطع الغيار المستخدمة -->
                                    <Border x:Name="PanelSpareParts" Background="White" CornerRadius="12" 
        BorderBrush="#E2E8F0" BorderThickness="1"
        Padding="20" Margin="0,0,0,14">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <!-- الوضع الافتراضي: مخفي -->
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <!-- يظهر فقط إذا كانت القائمة موجودة ولها عناصر -->
                                                    <DataTrigger Binding="{Binding SpareParts.Count, TargetNullValue=0}" Value="1">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SpareParts.Count, TargetNullValue=0}" Value="2">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SpareParts.Count, TargetNullValue=0}" Value="3">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SpareParts.Count, TargetNullValue=0}" Value="4">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SpareParts.Count, TargetNullValue=0}" Value="5">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SpareParts.Count, TargetNullValue=0}" Value="6">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SpareParts.Count, TargetNullValue=0}" Value="7">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SpareParts.Count, TargetNullValue=0}" Value="8">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SpareParts.Count, TargetNullValue=0}" Value="9">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SpareParts.Count, TargetNullValue=0}" Value="10">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="6" Color="#000" Opacity="0.03" ShadowDepth="1"/>
                                        </Border.Effect>

                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                                <Border Background="#F0FDF4" CornerRadius="6" Padding="6,3" Margin="0,0,8,0">
                                                    <TextBlock Text="⚙️" FontSize="14"/>
                                                </Border>
                                                <TextBlock Text="قطع الغيار المستخدمة" FontSize="13" FontWeight="Bold" 
                       Foreground="#1E293B" VerticalAlignment="Center"/>
                                            </StackPanel>

                                            <!-- جدول قطع الغيار -->
                                            <ItemsControl ItemsSource="{Binding SpareParts}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="#F8FAFC" CornerRadius="8" 
                            BorderBrush="#E2E8F0" BorderThickness="1"
                            Padding="14" Margin="0,0,0,8">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>

                                                                <TextBlock Grid.Column="0" Text="{Binding PartName}" 
                                       FontSize="13" FontWeight="SemiBold" 
                                       Foreground="#1E293B" VerticalAlignment="Center"/>

                                                                <Border Grid.Column="1" Background="#EFF6FF" CornerRadius="12" 
                                    Padding="8,3" Margin="0,0,10,0">
                                                                    <TextBlock Text="{Binding Quantity}" FontSize="11" 
                                           Foreground="#2563EB" FontWeight="SemiBold"/>
                                                                </Border>

                                                                <TextBlock Grid.Column="2" Text="×" FontSize="13" 
                                       Foreground="#94A3B8" VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>

                                                                <TextBlock Grid.Column="3" Text="{Binding UnitPrice, StringFormat={}{0:F0} ج.م, ConverterCulture=ar-EG}"  
                                       FontSize="13" FontWeight="SemiBold" 
                                       Foreground="#0F172A" VerticalAlignment="Center"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- الإجمالي -->
                                            <Border Background="#EFF6FF" CornerRadius="8" Padding="14,10" Margin="0,8,0,0">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="إجمالي تكلفة القطع" 
                           FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding TotalPartsCost, StringFormat={}{0:F0} ج.م, ConverterCulture=ar-EG}" 
                           FontSize="14" FontWeight="Bold" Foreground="#2563EB"/>
                                                </Grid>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                    
                                    <Border Background="White" CornerRadius="12" 
                    BorderBrush="#E2E8F0" BorderThickness="1"
                    Padding="20" Margin="0,0,0,14">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="6" Color="#000" Opacity="0.03" ShadowDepth="1"/>
                                        </Border.Effect>

                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                                <Border Background="#FEF3C7" CornerRadius="6" Padding="6,3" Margin="0,0,8,0">
                                                    <TextBlock Text="💰" FontSize="14"/>
                                                </Border>
                                                <TextBlock Text="التفاصيل المالية" FontSize="13" FontWeight="Bold" 
                                   Foreground="#1E293B" VerticalAlignment="Center"/>
                                            </StackPanel>

                                           
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- التكلفة على العميل -->
                                                <Border Grid.Column="0" Background="#F1F5F9" CornerRadius="10" Padding="14,12">
                                                    <StackPanel>
                                                        <TextBlock Text="التكلفة على العميل" FontSize="11" Foreground="#64748B" Margin="0,0,0,4"/>
                                                        <TextBlock Text="{Binding TotalCostToCustomer, StringFormat={}{0:F0} ج.م, ConverterCulture=ar-EG}" 
                       FontSize="16" FontWeight="Bold" Foreground="#0F172A"/>
                                                    </StackPanel>
                                                </Border>

                                                <!-- تكلفة الانتقالات -->
                                                <Border Grid.Column="2" Background="#F1F5F9" CornerRadius="10" Padding="14,12">
                                                    <StackPanel>
                                                        <TextBlock Text="تكلفة الانتقالات" FontSize="11" Foreground="#64748B" Margin="0,0,0,4"/>
                                                        <TextBlock Text="{Binding TransportationCost, StringFormat={}{0:F0} ج.م, ConverterCulture=ar-EG}"  
                       FontSize="16" FontWeight="Bold" Foreground="#0F172A"/>
                                                    </StackPanel>
                                                </Border>

                                                <!-- المبلغ المدفوع -->
                                                <Border Grid.Column="4" Background="#DCFCE7" CornerRadius="10" Padding="14,12">
                                                    <StackPanel>
                                                        <TextBlock Text="المبلغ المدفوع" FontSize="11" Foreground="#14532D" Margin="0,0,0,4"/>
                                                        <TextBlock Text="{Binding AmountPaid, StringFormat={}{0:F0} ج.م, ConverterCulture=ar-EG}"  
                       FontSize="16" FontWeight="Bold" Foreground="#16A34A"/>
                                                    </StackPanel>
                                                </Border>

                                                <!-- الباقي -->
                                                <Border Grid.Column="6" Background="#FEF2F2" CornerRadius="10" Padding="14,12">
                                                    <StackPanel>
                                                        <TextBlock Text="المبلغ المتبقي" FontSize="11" Foreground="#991B1B" Margin="0,0,0,4"/>
                                                        <TextBlock Text="{Binding RemainingAmount, StringFormat={}{0:F0} ج.م, ConverterCulture=ar-EG}"  
                       FontSize="16" FontWeight="Bold" Foreground="#DC2626"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>



                                            <Border x:Name="PanelPartsTransport" CornerRadius="10" Padding="14,12"
        Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1"
        Margin="0,12,0,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SpareParts.Count, TargetNullValue=0}" Value="1">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SpareParts.Count, TargetNullValue=0}" Value="2">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SpareParts.Count, TargetNullValue=0}" Value="3">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SpareParts.Count, TargetNullValue=0}" Value="4">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SpareParts.Count, TargetNullValue=0}" Value="5">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SpareParts.Count, TargetNullValue=0}" Value="6">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SpareParts.Count, TargetNullValue=0}" Value="7">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SpareParts.Count, TargetNullValue=0}" Value="8">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SpareParts.Count, TargetNullValue=0}" Value="9">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding SpareParts.Count, TargetNullValue=0}" Value="10">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="تكلفة انتقالات قطع الغيار" FontSize="11" Foreground="#64748B" Margin="0,0,0,4"/>
                                                        <TextBlock Text="{Binding PartsTransportationCost, StringFormat={}{0:F0} ج.م}" 
                       FontSize="14" FontWeight="SemiBold" Foreground="#1E293B"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="متحمل التكلفة" FontSize="11" Foreground="#64748B" Margin="0,0,0,4"/>
                                                        <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="#1E293B">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="الشركة"/>
                                                                    <Setter Property="Foreground" Value="#2563EB"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding TransportationBearer}" Value="1">
                                                                            <Setter Property="Text" Value="{Binding PaidByEmployeeName}"/>
                                                                            <Setter Property="Foreground" Value="#DC2626"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding TransportationBearer}" Value="{x:Null}">
                                                                            <Setter Property="Text" Value="—"/>
                                                                            <Setter Property="Foreground" Value="#94A3B8"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                            
                                        </StackPanel>
                                    </Border>

                              

                            

                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

                    </Grid>
                </Border>

                <Border x:Name="PanelVisits" Visibility="Collapsed"
                        Background="White" CornerRadius="14"
                        BorderBrush="#E2E8F0" BorderThickness="1" Padding="20">
                    <StackPanel>
                        <TextBlock Text="🔍 الزيارات" FontSize="15" FontWeight="Bold"
                                   Foreground="#1E293B" Margin="0,0,0,16"/>
                        <TextBlock Text="لا توجد زيارات مسجلة" Foreground="#94A3B8"
                                   FontSize="13" HorizontalAlignment="Center" Margin="0,40,0,40"/>
                    </StackPanel>
                </Border>

                <!-- TAB: الفاتورة -->
                <!-- TAB: الفاتورة -->
                <Border x:Name="PanelInvoice" Visibility="Collapsed"
        Background="White" CornerRadius="14"
        BorderBrush="#E2E8F0" BorderThickness="1" Padding="20">

                    <StackPanel>
                        <!-- Header -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="🧾" FontSize="20" Margin="0,0,10,0"/>
                                <TextBlock Text="الفاتورة" FontSize="18" FontWeight="Bold" Foreground="#1E293B"/>
                                <Border Background="#EFF6FF" CornerRadius="20" Padding="10,4" Margin="12,0,0,0">
                                    <TextBlock x:Name="TxtInvoiceStatus" Text="غير مدفوعة" 
                               FontSize="11" FontWeight="SemiBold" Foreground="#2563EB"/>
                                </Border>
                            </StackPanel>

                            <Button Grid.Column="1" x:Name="BtnPrintInvoice"
                    Content="🖨️ طباعة الفاتورة"
                    Click="BtnPrintInvoice_Click"
                    Padding="14,8"
                    Background="#2563EB"
                    Foreground="White"
                    FontSize="13" FontWeight="SemiBold"
                    BorderThickness="0"
                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#1D4ED8"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                        <!-- تفاصيل الفاتورة -->
                        <Border Background="#F8FAFC" CornerRadius="12" 
                BorderBrush="#E2E8F0" BorderThickness="1"
                Padding="20">

                            <StackPanel>
                                <!-- معلومات الفاتورة -->
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="رقم الفاتورة" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="TxtInvoiceNumber" Text="INV-2026-001" 
                                   FontSize="16" FontWeight="Bold" Foreground="#1E293B"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="تاريخ الإصدار" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="TxtInvoiceDate" Text="13/06/2026" 
                                   FontSize="16" FontWeight="Bold" Foreground="#1E293B"/>
                                    </StackPanel>
                                </Grid>

                                <Border Height="1" Background="#E2E8F0" Margin="0,0,0,16"/>

                                <!-- جدول الفاتورة -->
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Header -->
                                    <Border Grid.Row="0" Background="#EFF6FF" CornerRadius="8,8,0,0" Padding="12,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="100"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="البيان" FontWeight="Bold" FontSize="12" Foreground="#1E293B"/>
                                            <TextBlock Grid.Column="1" Text="الكمية" FontWeight="Bold" FontSize="12" Foreground="#1E293B" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="السعر" FontWeight="Bold" FontSize="12" Foreground="#1E293B" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="3" Text="الإجمالي" FontWeight="Bold" FontSize="12" Foreground="#1E293B" HorizontalAlignment="Center"/>
                                        </Grid>
                                    </Border>

                                    <!-- Items -->
                                    <ItemsControl Grid.Row="1" x:Name="InvoiceItemsControl" Margin="0,0,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="12,8">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="80"/>
                                                            <ColumnDefinition Width="100"/>
                                                            <ColumnDefinition Width="100"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding Description}" FontSize="13" Foreground="#374151"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Quantity}" FontSize="13" Foreground="#374151" HorizontalAlignment="Center"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding UnitPrice, StringFormat={}{0:N2} ج.م}" FontSize="13" Foreground="#374151" HorizontalAlignment="Center"/>
                                                        <TextBlock Grid.Column="3" Text="{Binding TotalPrice, StringFormat={}{0:N2} ج.م}" FontSize="13" FontWeight="SemiBold" Foreground="#1E293B" HorizontalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>

                                <!-- الإجماليات -->
                                <Border Background="#F8FAFC" CornerRadius="0,0,8,8" 
                        BorderBrush="#E2E8F0" BorderThickness="1,0,1,1"
                        Padding="16,12" Margin="0,0,0,16">

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="1">
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="120"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="المجموع الفرعي" FontSize="12" Foreground="#64748B" HorizontalAlignment="Right"/>
                                                <TextBlock Grid.Column="1" x:Name="TxtSubtotal" Text="0.00 ج.م" FontSize="13" Foreground="#1E293B" HorizontalAlignment="Right"/>
                                            </Grid>

                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="120"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="الخصم" FontSize="12" Foreground="#64748B" HorizontalAlignment="Right"/>
                                                <TextBlock Grid.Column="1" x:Name="TxtDiscount" Text="0.00 ج.م" FontSize="13" Foreground="#1E293B" HorizontalAlignment="Right"/>
                                            </Grid>

                                            <Border Height="1" Background="#E2E8F0" Margin="0,0,0,6"/>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="120"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="الإجمالي" FontSize="14" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Right"/>
                                                <TextBlock Grid.Column="1" x:Name="TxtTotal" Text="0.00 ج.م" FontSize="16" FontWeight="Bold" Foreground="#2563EB" HorizontalAlignment="Right"/>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- حالة الدفع -->
                                <Border CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#FEF2F2"/>
                                            <Setter Property="BorderBrush" Value="#FCA5A5"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPaid}" Value="True">
                                                    <Setter Property="Background" Value="#DCFCE7"/>
                                                    <Setter Property="BorderBrush" Value="#86EFAC"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="⚠️" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" x:Name="TxtPaymentStatus" Text="المبلغ غير مدفوع" FontSize="13" Foreground="#DC2626" VerticalAlignment="Center"/>

                                        <Button Grid.Column="2" x:Name="BtnMarkAsPaid"
                                Content="تحديد كمدفوع"
                                Click="BtnMarkAsPaid_Click"
                                Padding="12,6"
                                Background="#16A34A"
                                Foreground="White"
                                FontSize="12" FontWeight="SemiBold"
                                BorderThickness="0"
                                Cursor="Hand"
                                Visibility="Collapsed">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" 
                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#15803D"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>