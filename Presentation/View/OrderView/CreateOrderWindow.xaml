<Window x:Class="Presentation.View.OrderView.CreateOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="انشاء طلب جديد" Height="458" Width="621"
        FlowDirection="RightToLeft">
    <Window.Resources>
        <Style x:Key="ModernDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F9F9F9"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderGray}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="SelectionMode" Value="Single"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="انشاء طلب جديد"
                   FontSize="18"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Foreground="{StaticResource PrimaryBlue}"
                   Margin="0,0,0,10"/>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="12"
                Padding="15"
                BorderBrush="#E2E8F0"
                BorderThickness="1">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,10">
                    <TextBlock HorizontalAlignment="Left" Margin="0,0,0,2">
                        <Run Text=" *" Foreground="Red"/>
                        <Run Text="العميل"/>
                    </TextBlock>

                    <ComboBox x:Name="customerID"
          Style="{StaticResource ModernComboBox}"
          DisplayMemberPath="Name"
          SelectedValuePath="Id"
          HorizontalAlignment="Stretch"
          IsEditable="True"
          StaysOpenOnEdit="True"
          IsTextSearchEnabled="False"
          SelectionChanged="customerID_SelectionChanged"
          KeyUp="customerID_TextChanged"
          HorizontalContentAlignment="Left"
          FocusVisualStyle="{x:Null}"
          ToolTip="{Binding SelectedItem.Name, RelativeSource={RelativeSource Self}}">
                        <ComboBox.Resources>
                            <Style TargetType="{x:Type TextBox}">
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <Setter Property="AllowDrop" Value="True"/>
                            </Style>
                        </ComboBox.Resources>
                    </ComboBox>
                    <TextBlock x:Name="CustomerError"
                               Foreground="Red"
                               FontSize="11"
                               Text=""
                               HorizontalAlignment="Left"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="10,0,0,10">
                    <TextBlock HorizontalAlignment="Left" Margin="0,0,0,2">
                        <Run Text=" *" Foreground="Red"/>
                        <Run Text="الجهاز"/>
                    </TextBlock>

                    <ComboBox x:Name="DeviceID"
                              SelectedItem="{Binding SelectedDevice}"
                              DisplayMemberPath="DeviceName"
                              SelectedValuePath="DeviceId"
                              Style="{StaticResource ModernComboBox}"
                              HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Left"
                              ToolTip="{Binding SelectedItem.DeviceName, RelativeSource={RelativeSource Self}}"/>
                    <TextBlock x:Name="DeviceError"
                               Foreground="Red"
                               FontSize="11"
                               Text=""
                               HorizontalAlignment="Left"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,0,0,10">
                    <TextBlock HorizontalAlignment="Left">
                        <Run Text=" *" Foreground="Red"/>
                        <Run Text="العطل"/>
                    </TextBlock>

                    <TextBox x:Name="TxtIssue"
                             Style="{StaticResource ModernTextBox}"
                             Height="60"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             TextAlignment="Left"/>

                    <TextBlock x:Name="IssueError"
                               Foreground="Red"
                               FontSize="11"
                               Text=""
                               HorizontalAlignment="Left"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.ColumnSpan="2">
                    <TextBlock Text="الملاحظات"
                               HorizontalAlignment="Left"
                               Margin="0,0,0,2"/>

                    <TextBox x:Name="TxtNotes"
                             Style="{StaticResource ModernTextBox}"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             Height="60"
                             TextAlignment="Left"/>
                </StackPanel>

                <Button Grid.Row="3"
                        Grid.ColumnSpan="2"
                        x:Name="BtnCreateOrder"
                        Content="➕ إنشاء الطلب "
                        Style="{StaticResource ActionButtonStyle}"
                        Height="40"
                        Margin="0,23,0,0" 
                        Background="{StaticResource PrimaryBlue}"
                        Foreground="White"
                        Click="BtnCreateOrder_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>