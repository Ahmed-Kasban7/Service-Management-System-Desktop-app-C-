<Window x:Class="Presentation.View.OrderView.CreateOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📋 إنشاء طلب جديد"
        Height="Auto" 
        Width="620"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Background="#EEF2F7"
        FlowDirection="RightToLeft"
        MinHeight="520"
        MinWidth="500">

    <Window.Resources>
        <!-- الألوان الأساسية -->
        <SolidColorBrush x:Key="PrimaryBlue" Color="#2563EB"/>
        <SolidColorBrush x:Key="PrimaryBlueDark" Color="#1D4ED8"/>
        <SolidColorBrush x:Key="PrimaryBlueLight" Color="#DBEAFE"/>
        <SolidColorBrush x:Key="DangerRed" Color="#DC2626"/>
        <SolidColorBrush x:Key="DangerRedDark" Color="#991B1B"/>
        <SolidColorBrush x:Key="SuccessGreen" Color="#16A34A"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#1E293B"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#64748B"/>
        <SolidColorBrush x:Key="BorderColor" Color="#E2E8F0"/>

        <!-- الأنماط المشتركة -->
        <Style x:Key="FieldHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="ErrorText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource DangerRed}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="Visibility" Value="Collapsed"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>


      

        <!-- زر رئيسي -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Width" Value="130"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryBlueDark}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#94A3B8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- زر إلغاء -->
        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource DangerRed}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource DangerRedDark}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- الهيكل الرئيسي -->
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- العنوان مع أيقونة -->
        <TextBlock Grid.Row="0"
                   Text="📋 إنشاء طلب جديد"
                   FontSize="20" FontWeight="Bold"
                   Foreground="{StaticResource PrimaryBlue}"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,15"/>

        <!-- محتوى النموذج -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      MaxHeight="520">
            <Border Background="White"
                    CornerRadius="12"
                    Padding="20"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1">
                <StackPanel>

                    <!-- العميل -->
                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Style="{StaticResource FieldHeader}">
                            <Run Text="العميل"/>
                            <Run Text="*" Foreground="{StaticResource DangerRed}"/>
                        </TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="customerID"
                                      Grid.Column="0"
                                      Margin="0,0,8,0"
                                      Height="36"
                                      Style="{StaticResource ModernComboBox}"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Id"
                                      IsEditable="True"
                                      StaysOpenOnEdit="True"
                                      IsTextSearchEnabled="False"
                                      SelectionChanged="customerID_SelectionChanged"
                                      KeyUp="customerID_TextChanged"
                                      HorizontalContentAlignment="Left"
                                      FocusVisualStyle="{x:Null}"
                                      ToolTip="{Binding SelectedItem.Name, RelativeSource={RelativeSource Self}}">
                                <ComboBox.Resources>
                                    <Style TargetType="{x:Type TextBox}">
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                        <Setter Property="AllowDrop" Value="True"/>
                                    </Style>
                                </ComboBox.Resources>
                            </ComboBox>
                            <Button Grid.Column="1"
                                    x:Name="BtnAddCustomer"
                                    Content="+"
                                    Width="36" Height="38"
                                    FontSize="18"
                                    FontWeight="Bold"
                                    Background="{StaticResource PrimaryBlue}"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="BtnAddCustomer_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </Grid>
                        <TextBlock x:Name="CustomerError"
                                   Style="{StaticResource ErrorText}"/>
                    </StackPanel>

                    <!-- الجهاز -->
                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Style="{StaticResource FieldHeader}">
                            <Run Text="الجهاز"/>
                            <Run Text="*" Foreground="{StaticResource DangerRed}"/>
                        </TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="DeviceID"
                                      Grid.Column="0"
                                      Margin="0,0,8,0"
                                      Style="{StaticResource ModernComboBox}"
                                      SelectedItem="{Binding SelectedDevice}"
                                      DisplayMemberPath="DeviceName"
                                      SelectedValuePath="DeviceId"
                                      HorizontalContentAlignment="Left"
                                      ToolTip="{Binding SelectedItem.DeviceName, RelativeSource={RelativeSource Self}}"/>
                            <Button Grid.Column="1"
                                    x:Name="BtnAddDevice"
                                    Content="+"
                                    Width="36" Height="38"
                                    FontSize="18"
                                    FontWeight="Bold"
                                    Background="{StaticResource PrimaryBlue}"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    IsEnabled="False"
                                    Click="BtnAddDevice_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </Grid>
                        <TextBlock x:Name="DeviceError"
                                   Style="{StaticResource ErrorText}"/>
                    </StackPanel>

                    <!-- العطل -->
                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Style="{StaticResource FieldHeader}">
                            <Run Text="العطل"/>
                            <Run Text="*" Foreground="{StaticResource DangerRed}"/>
                        </TextBlock>
                        <TextBox x:Name="TxtIssue"
                                 Style="{StaticResource ModernTextBox}"
                                 Height="70"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 TextAlignment="Left"/>
                        <TextBlock x:Name="IssueError"
                                   Style="{StaticResource ErrorText}"/>
                    </StackPanel>

                    <!-- الملاحظات -->
                    <StackPanel>
                        <TextBlock Style="{StaticResource FieldHeader}">
                            <Run Text="ملاحظات"/>
                        </TextBlock>
                        <TextBox x:Name="TxtNotes"
                                 Style="{StaticResource ModernTextBox}"
                                 Height="70"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 TextAlignment="Left"/>
                    </StackPanel>

                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- الأزرار -->
        <Border Grid.Row="2"
                Padding="0,16,0,0"
                BorderThickness="0,1,0,0"
                BorderBrush="{StaticResource BorderColor}">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,4,0,0">
                <Button x:Name="BtnSave"
                        Style="{StaticResource PrimaryButton}"
                        Click="BtnSave_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💾" Margin="0,0,6,0"/>
                        <TextBlock Text="حفظ"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnCancel"
                        Style="{StaticResource DangerButton}"
                        Margin="12,0,0,0"
                        Click="BtnCancel_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✖" Margin="0,0,6,0"/>
                        <TextBlock Text="إلغاء"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>