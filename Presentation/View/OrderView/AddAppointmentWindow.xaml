<Window x:Class="Presentation.View.OrderView.AddAppointmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="إضافة موعد"
        Height="Auto" Width="480"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Background="#EEF2F7"
        FlowDirection="RightToLeft">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBlue" Color="#4169E1"/>
        <SolidColorBrush x:Key="SuccessGreen" Color="#27AE60"/>
        <SolidColorBrush x:Key="DangerRed" Color="#E53935"/>
        <SolidColorBrush x:Key="DangerRedDark" Color="#B71C1C"/>

        <Style x:Key="FieldHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <!-- Style للـ DatePicker -->
        <Style x:Key="ModernDatePicker" TargetType="DatePicker">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <DatePickerTextBox x:Name="PART_TextBox"
                                               Grid.Column="0"
                                               Foreground="{TemplateBinding Foreground}"
                                               Background="Transparent"
                                               BorderThickness="0"
                                               Padding="{TemplateBinding Padding}"
                                               VerticalContentAlignment="Center"/>
                                <Button x:Name="PART_Button"
                                    Grid.Column="1"
                                    Width="32"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand">
                                    <TextBlock Text="📅" FontSize="16"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                </Button>
                                <Popup x:Name="PART_Popup"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#2563EB"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter Property="BorderBrush" Value="#2563EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- العنوان -->
        <TextBlock Grid.Row="0"
                   Text="إضافة موعد جديد"
                   FontSize="20" FontWeight="Bold"
                   Foreground="{StaticResource PrimaryBlue}"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,15"/>

        <!-- المحتوى -->
        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="20"
                BorderBrush="#E2E8F0" BorderThickness="1">
            <StackPanel>

                <!-- الفني + نوع الزيارة -->
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- الفني -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource FieldHeader}">
                            <Run Text="الفني"/>
                            <Run Text=" *" Foreground="{StaticResource DangerRed}"/>
                        </TextBlock>
                        <ComboBox x:Name="CbTechnician"
                                  Style="{StaticResource ModernComboBox}"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Id"/>
                        <TextBlock x:Name="TxtTechnicianError"
                                   Foreground="{StaticResource DangerRed}"
                                   FontSize="12" Margin="0,4,0,0"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed"/>
                    </StackPanel>

                    <!-- نوع الزيارة -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource FieldHeader}">
                            <Run Text="نوع الزيارة"/>
                            <Run Text=" *" Foreground="{StaticResource DangerRed}"/>
                        </TextBlock>
                        <ComboBox x:Name="CbVisitType"
                                  Style="{StaticResource ModernComboBox}">
                            <ComboBoxItem Content="كشف"    Tag="0"/>
                            <ComboBoxItem Content="إصلاح"    Tag="1"/>
                            <ComboBoxItem Content="تركيب قطع غيار" Tag="2"/>
                            <ComboBoxItem Content="سحب"   Tag="3"/>
                            <ComboBoxItem Content="تسليم"    Tag="4"/>
                            <ComboBoxItem Content="متابعة"   Tag="5"/>
                        </ComboBox>
                        <TextBlock x:Name="TxtVisitTypeError"
                                   Foreground="{StaticResource DangerRed}"
                                   FontSize="12" Margin="0,4,0,0"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Grid>

                <!-- المساعد + التاريخ -->
                <!-- المساعد + السائق + التاريخ -->
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="مساعد الفني"
                   Style="{StaticResource FieldHeader}"/>
                        <ComboBox x:Name="CbAssistant"
                  Style="{StaticResource ModernComboBox}"
                  DisplayMemberPath="Name"
                  SelectedValuePath="Id"/>
                    </StackPanel>

                    <!-- السائق -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="السائق"
                   Style="{StaticResource FieldHeader}"/>
                        <ComboBox x:Name="CbDriver"
                  Style="{StaticResource ModernComboBox}"
                  DisplayMemberPath="Name"
                  SelectedValuePath="Id"/>
                    </StackPanel>

                 
                </Grid>
                <!-- التاريخ -->
                <StackPanel Grid.Column="4">
                    <TextBlock Style="{StaticResource FieldHeader}">
<Run Text="تاريخ الموعد"/>
<Run Text=" *" Foreground="{StaticResource DangerRed}"/>
                    </TextBlock>
                    <DatePicker x:Name="DpScheduledDate"
        Style="{StaticResource ModernDatePicker}"
        SelectedDateFormat="Short"/>
                    <TextBlock x:Name="TxtDateError"
       Foreground="{StaticResource DangerRed}"
       FontSize="12" Margin="0,4,0,0"
       TextWrapping="Wrap"
       Visibility="Collapsed"/>
                </StackPanel>
                <!-- الملاحظات -->
                <StackPanel>
                    <TextBlock Text="ملاحظات"
                               Style="{StaticResource FieldHeader}"/>
                    <TextBox x:Name="TxtNotes"
                             Style="{StaticResource ModernTextBox}"
                             Height="80"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             VerticalContentAlignment="Top"/>
                </StackPanel>

            </StackPanel>
        </Border>

        <!-- الأزرار -->
        <Border Grid.Row="2" Padding="0,15,0,0"
                BorderThickness="0,1,0,0" BorderBrush="#CBD5E1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                <Button x:Name="BtnSave"
                        Content="➕ إضافة"
                        Width="130" Height="42"
                        Background="{StaticResource PrimaryBlue}"
                        Foreground="White" FontWeight="Bold" Cursor="Hand"
                        Click="BtnSave_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.9"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="BtnCancel"
                        Content="❌ إلغاء"
                        Margin="15,0,0,0"
                        Width="100" Height="42"
                        Background="{StaticResource DangerRed}"
                        Foreground="White" FontWeight="Bold" Cursor="Hand"
                        Click="BtnCancel_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{StaticResource DangerRedDark}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </StackPanel>
        </Border>
    </Grid>
</Window>