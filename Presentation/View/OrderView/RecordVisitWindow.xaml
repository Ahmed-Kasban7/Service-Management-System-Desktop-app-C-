<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Presentation.View.OrderView.RecordVisitWindow"
        Title="تسجيل تقرير الزيارة"
        Height="750" Width="560"
        WindowStartupLocation="CenterOwner"
        Background="#EEF2F7"
        FlowDirection="RightToLeft">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBlue"     Color="#2563EB"/>
        <SolidColorBrush x:Key="PrimaryDark"     Color="#1D4ED8"/>
        <SolidColorBrush x:Key="DangerRed"       Color="#E53935"/>
        <SolidColorBrush x:Key="DangerRedDark"   Color="#B71C1C"/>
        <SolidColorBrush x:Key="SuccessGreen"    Color="#16A34A"/>
        
        <Style x:Key="FieldHeader" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Margin"     Value="0,0,0,5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="📝 تسجيل تقرير الزيارة الفنية"
                   FontSize="20" FontWeight="Bold"
                   Foreground="{StaticResource PrimaryBlue}"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,16"/>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Border Background="White" CornerRadius="14"
                    BorderBrush="#E2E8F0" BorderThickness="1"
                    Padding="20">
                <StackPanel>

                    <!-- التشخيص -->
                    <StackPanel Margin="0,0,0,14">
                        <TextBlock Style="{StaticResource FieldHeader}">
                            <Run Text="التشخيص"/>
                            <Run Text=" *" Foreground="{StaticResource DangerRed}"/>
                        </TextBlock>
                        <TextBox x:Name="TxtDiagnosis"
                                 Style="{StaticResource ModernTextBox}"
                                 Height="70" AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalContentAlignment="Top"/>
                        <TextBlock x:Name="TxtDiagnosisError"
                                   Foreground="{StaticResource DangerRed}"
                                   FontSize="11" Margin="0,4,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>

                    <!-- ما تم عمله -->
                    <StackPanel Margin="0,0,0,14">
                        <TextBlock Text="ما تم عمله في الجهاز"
                                   Style="{StaticResource FieldHeader}"/>
                        <TextBox x:Name="TxtActionsTaken"
                                 Style="{StaticResource ModernTextBox}"
                                 Height="70" AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalContentAlignment="Top"/>
                    </StackPanel>

                    <!-- ملاحظات -->
                    <StackPanel Margin="0,0,0,14">
                        <TextBlock Text="ملاحظات"
                                   Style="{StaticResource FieldHeader}"/>
                        <TextBox x:Name="TxtNotes"
                                 Style="{StaticResource ModernTextBox}"
                                 Height="55" AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalContentAlignment="Top"/>
                    </StackPanel>

                    <!-- تكاليف الزيارة -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- التكلفة على العميل -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FieldHeader}">
                                <Run Text="التكلفة على العميل (ج.م)"/>
                                <Run Text=" *" Foreground="{StaticResource DangerRed}"/>
                            </TextBlock>
                            <TextBox x:Name="TxtMaintenanceCost"
                                     Style="{StaticResource ModernTextBox}"
                                     Text="0"
                                     FlowDirection="LeftToRight"
                                     HorizontalContentAlignment="Right"/>
                            <TextBlock x:Name="TxtCostError"
                                       Foreground="{StaticResource DangerRed}"
                                       FontSize="11" Margin="0,4,0,0"
                                       Visibility="Collapsed"/>
                        </StackPanel>

                        <!-- تكلفة الانتقالات -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource FieldHeader}">
                                <Run Text="تكلفة الانتقالات (ج.م)"/>
                                <Run Text=" *" Foreground="{StaticResource DangerRed}"/>
                            </TextBlock>
                            <TextBox x:Name="TxtTransportCost"
                                     Style="{StaticResource ModernTextBox}"
                                     Text="0"
                                     FlowDirection="LeftToRight"
                                     HorizontalContentAlignment="Right"/>
                        </StackPanel>

                        <!-- المدفوع -->
                        <StackPanel Grid.Column="4">
                            <TextBlock Style="{StaticResource FieldHeader}">
                                <Run Text="المدفوع (ج.م)"/>
                                <Run Text=" *" Foreground="{StaticResource DangerRed}"/>
                            </TextBlock>
                            <TextBox x:Name="TxtAmountPaid"
                                     Style="{StaticResource ModernTextBox}"
                                     Text="0"
                                     FlowDirection="LeftToRight"
                                     HorizontalContentAlignment="Right"/>
                            <TextBlock x:Name="TxtPaidError"
                                       Foreground="{StaticResource DangerRed}"
                                       FontSize="11" Margin="0,4,0,0"
                                       Visibility="Collapsed"/>
                        </StackPanel>
                    </Grid>

                    <!-- Divider -->
                    <Border Height="1" Background="#F1F5F9" Margin="0,4,0,16"/>

                    <!-- هيدر قطع الغيار -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="⚙️ قطع الغيار المستخدمة"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="#1E293B"
                                   VerticalAlignment="Center"/>

                        <Button Grid.Column="1"
                                Content="➕ إضافة قطعة"
                                Padding="14,7"
                                Background="#EFF6FF"
                                Foreground="{StaticResource PrimaryBlue}"
                                BorderThickness="0"
                                FontSize="12" FontWeight="SemiBold"
                                Cursor="Hand"
                                Click="BtnAddPartRow_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#DBEAFE"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <!-- قائمة القطع الديناميكية -->
                    <ItemsControl x:Name="ContainerSpareParts" Margin="0,0,0,10">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#F8FAFC" CornerRadius="10"
                                        BorderBrush="#E2E8F0" BorderThickness="1"
                                        Padding="14" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- اسم القطعة + حذف -->
                                        <Grid Grid.Row="0" Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="اسم قطعة الغيار"
                                                           Style="{StaticResource FieldHeader}"/>
                                                <TextBox Text="{Binding PartName, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource ModernTextBox}"/>
                                            </StackPanel>

                                            <Button Grid.Column="1"
                                                    Width="36" Height="36"
                                                    VerticalAlignment="Bottom"
                                                    Margin="10,0,0,0"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    ToolTip="حذف القطعة"
                                                    Click="BtnDeletePartRow_Click">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="delBorder"
                                                                Background="Transparent"
                                                                CornerRadius="8">
                                                            <TextBlock Text="🗑️" FontSize="15"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="delBorder"
                                                                        Property="Background"
                                                                        Value="#FEE2E2"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </Grid>

                                        <!-- الكمية + تكلفة الشراء + سعر البيع -->
                                        <Grid Grid.Row="1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="الكمية"
                   Style="{StaticResource FieldHeader}"/>
                                                <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource ModernTextBox}"
                 FlowDirection="LeftToRight"
                 HorizontalContentAlignment="Right"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="تكلفة الشراء (ج.م)"
                   Style="{StaticResource FieldHeader}"/>
                                                <TextBox Text="{Binding OriginalCost, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource ModernTextBox}"
                 FlowDirection="LeftToRight"
                 HorizontalContentAlignment="Right"/>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border x:Name="PanelPaidBy"
        Background="#F8FAFC" CornerRadius="10"
        BorderBrush="#E2E8F0" BorderThickness="1"
        Padding="14" Margin="0,4,0,10">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=ContainerSpareParts, Path=HasItems}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="1.5*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="تكلفة انتقالات القطع (ج.م)" Style="{StaticResource FieldHeader}"/>
                                <TextBox x:Name="TxtPartTransportCost"
                     Style="{StaticResource ModernTextBox}"
                     Text="0"
                     FlowDirection="LeftToRight"
                     HorizontalContentAlignment="Right"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="متحمل تكلفة الانتقالات" Style="{StaticResource FieldHeader}"/>
                                <ComboBox x:Name="CbPaidBy"
                      Style="{StaticResource ModernComboBox}"
                      SelectionChanged="CbPaidBy_SelectionChanged">
                                    <ComboBoxItem Content="الشركة" Tag="Company" IsSelected="True"/>
                                    <ComboBoxItem Content="الموظف" Tag="Employee"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel x:Name="PanelPaidByEmployee"
                    Grid.Column="4"
                    Visibility="Collapsed">
                                <TextBlock Text="اسم الموظف المسئول" Style="{StaticResource FieldHeader}"/>
                                <ComboBox x:Name="CbPaidByEmployee"
                      Style="{StaticResource ModernComboBox}"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Id"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Buttons -->
        <Border Grid.Row="2"
                Padding="0,15,0,0"
                BorderThickness="0,1,0,0"
                BorderBrush="#E2E8F0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                <Button Content="💾 حفظ الزيارة"
                        Width="160" Height="42"
                        Background="{StaticResource SuccessGreen}"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="BtnSaveVisit_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#15803D"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Content="❌ إلغاء"
                        Width="100" Height="42"
                        Margin="12,0,0,0"
                        Background="{StaticResource DangerRed}"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="BtnCancel_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="cancelBorder"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="cancelBorder"
                                            Property="Background"
                                            Value="{StaticResource DangerRedDark}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </StackPanel>
        </Border>

    </Grid>
</Window>