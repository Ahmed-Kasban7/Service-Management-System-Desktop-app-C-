<Window x:Class="Presentation.View.Customer_View.EditCustomerView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تعديل بيانات العميل"
        Height="450"
        Width="420"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <Border Margin="20"
                Background="White"
                CornerRadius="10"
                Padding="20">


            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="15"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Title -->
                <TextBlock Text="تعديل بيانات العميل"
                       FontSize="20"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>

                <!-- Name -->
                <StackPanel Grid.Row="2">
                    <TextBlock Text="الاسم"
                           FontWeight="SemiBold"/>
                    <TextBox x:Name="TxtName"
                         Height="35"
                         Margin="0,5,0,0"
                         Padding="5"/>
                </StackPanel>

                <!-- Age -->
                <StackPanel Grid.Row="3" Margin="0,10,0,0">
                    <TextBlock Text="العمر"
                           FontWeight="SemiBold"/>
                    <TextBox x:Name="TxtAge"
                         Height="35"
                         Margin="0,5,0,0"
                         Padding="5"/>
                </StackPanel>

                <!-- Gender -->
                <StackPanel Grid.Row="4" Margin="0,10,0,0">
                    <TextBlock Text="الجنس"
                           FontWeight="SemiBold"/>
                    <ComboBox x:Name="TxtSex"
                          Height="35"
                          Margin="0,5,0,0">
                        <ComboBoxItem Content="ذكر"/>
                        <ComboBoxItem Content="أنثى"/>
                    </ComboBox>
                </StackPanel>

                <!-- Address -->
                <StackPanel Grid.Row="5" Margin="0,10,0,0">
                    <TextBlock Text="العنوان"
                           FontWeight="SemiBold"/>
                    <TextBox x:Name="TxtAddress"
                         Height="35"
                         Margin="0,5,0,0"
                         Padding="5"/>
                </StackPanel>

                <!-- Discount -->
                <StackPanel Grid.Row="6" Margin="0,10,0,0">
                    <TextBlock Text="نسبة الخصم (%)"
                           FontWeight="SemiBold"/>
                    <TextBox x:Name="TxtDiscount"
                         Height="35"
                         Margin="0,5,0,0"
                         Padding="5"/>
                </StackPanel>

                <StackPanel Grid.Row="8"
            Orientation="Horizontal"
            HorizontalAlignment="Center"
            Margin="0,10,0,0">

                    <!-- Save Button -->
                    <Button Content="حفظ"
            Width="110"
            Height="40"
            Margin="8"
            FontWeight="SemiBold"
            Foreground="White"
            Cursor="Hand"
            Click="BtnSave_Click">

                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
                        Background="#27AE60"
                        CornerRadius="8"
                        Padding="5">
                                    <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                                </Border>

                                <ControlTemplate.Triggers>
                                    <!-- Hover -->
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border"
                                Property="Background"
                                Value="#2ECC71"/>
                                    </Trigger>

                                    <!-- Pressed -->
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border"
                                Property="Background"
                                Value="#1E8449"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Cancel Button -->
                    <Button Content="إلغاء"
            Width="110"
            Height="40"
            Margin="8"
            FontWeight="SemiBold"
            Foreground="White"
            Cursor="Hand"
            Click="BtnCancel_Click">

                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
                        Background="{StaticResource DangerRed}"
                        CornerRadius="8"
                        Padding="5">
                                    <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                                </Border>

                                <ControlTemplate.Triggers>
                                    <!-- Hover -->
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border"
                                Property="Background"
                                Value="#E74C3C"/>
                                    </Trigger>

                                    <!-- Pressed -->
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border"
                                Property="Background"
                                Value="#922B21"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>
            </Grid>

        </Border>

    </ScrollViewer>

</Window>