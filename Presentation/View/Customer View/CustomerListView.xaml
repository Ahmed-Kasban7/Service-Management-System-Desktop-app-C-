<Window x:Class="Presentation.View.Customer_View.CustomerListView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="لوحة التحكم - Admin Console"
        Height="800"
        Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#EEF2F7"
        FlowDirection="RightToLeft">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="43*"/>
            <ColumnDefinition Width="27*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="295*"/>
            <RowDefinition Height="97*"/>
        </Grid.RowDefinitions>

        <!-- الشريط العلوي -->
        <Grid Grid.Row="1" Grid.ColumnSpan="2" Grid.RowSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>


            <Border Grid.Row="0" Background="White" Padding="20,10" BorderThickness="0,0,0,1" BorderBrush="#F0F3F7">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" Color="#000" Opacity="0.02" ShadowDepth="1"/>
                </Border.Effect>

                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Grid x:Name="LogoContainer" Cursor="Hand">
                            <Border Width="68" Height="68" Background="FloralWhite" CornerRadius="14" 
                        BorderBrush="#E2E8F0" BorderThickness="1.2">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" Color="#000" Opacity="0.06" ShadowDepth="1"/>
                                </Border.Effect>

                                <Border CornerRadius="12" ClipToBounds="True" Margin="3">
                                    <Image x:Name="CompanyLogo" Stretch="UniformToFill" 
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Border>

                            <Button x:Name="BtnChangeLogo" Click="BtnChangeLogo_Click"
                        Width="22" Height="22" VerticalAlignment="Bottom" HorizontalAlignment="Right" 
                        Margin="0,0,-4,-4" Background="#3B82F6" Foreground="White" 
                        BorderThickness="1.5" BorderBrush="White">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Grid>
                                            <Ellipse Fill="{TemplateBinding Background}" Stroke="{TemplateBinding BorderBrush}" StrokeThickness="1.5"/>
                                            <TextBlock Text="✎" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,1"/>
                                        </Grid>
                                    </ControlTemplate>
                                </Button.Template>
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMouseOver, ElementName=LogoContainer}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>

                        <TextBlock Text="Pro Fix" FontSize="18" FontWeight="Bold" Foreground="#1E293B" 
                       VerticalAlignment="Center" Margin="15,0,0,0"/>
                    </StackPanel>

                    <Grid Grid.Column="1" Margin="40,0"/>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">

                        <Border Background="#F8FAFC" CornerRadius="10" Padding="12,7" Margin="0,0,12,0" 
                    BorderBrush="#E2E8F0" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📅" Margin="0,0,8,0" VerticalAlignment="Center" FontSize="12" Opacity="0.7"/>
                                <TextBlock x:Name="TxtTodayDate" Text="28 فبراير 2026" Foreground="#64748B" 
                               FontWeight="Medium" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Button Content="⚙️" Style="{StaticResource IconButtonSmallStyle}" FontSize="18" Padding="10,6"/>
                    </StackPanel>
                </Grid>
            </Border>
            <!-- المحتوى الرئيسي -->
            <Grid x:Name="CustomerContentGrid" Grid.Row="1" Margin="30,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition x:Name="ProfileColumn" Width="0"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="1" 
            x:Name="ProfileSection" 
            Visibility="Collapsed" 
            Background="White" 
            CornerRadius="12" 

Margin="10,0,0,20">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Customer Top Header - محسّن -->


                            <!-- SECTION 1: البيانات الأساسية - محسّن -->
                            <Border Background="#4169E1"
        CornerRadius="12,12,0,0"
        Padding="20,15">

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- العنوان -->
                                    <TextBlock Text="📋 البيانات الأساسية"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="White"
                   VerticalAlignment="Center"/>

                                    <!-- أزرار تعديل / حذف -->
                                    <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
                                        <!-- تعديل -->
                                        <Button x:Name="BtnEditCustomer"
                    Content="✏️"
                                                        ToolTip="تعديل البيانات الأساسية للعميل"

                    Width="36"
                    Height="36"
                    Background="White"
                    Foreground="{StaticResource PrimaryBlue}"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="BtnEditCustomer_Click"
                    IsEnabled="False" RenderTransformOrigin="1.333,0.537">
                                            <Button.Template>
                                                <ControlTemplate TargetType="{x:Type Button}">
                                                    <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8">
                                                        <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Opacity" Value="0.9"/>
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter Property="Opacity" Value="0.4"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>


                                    </StackPanel>
                                </Grid>
                            </Border>


                            <Border Padding="25"
        Background="White"
        FlowDirection="RightToLeft">

                                <StackPanel>

                                    <!-- الصف الأول: الاسم + الكود -->
                                    <Grid Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- كود العميل -->
                                        <StackPanel Grid.Column="0"
                        HorizontalAlignment="Left">
                                            <TextBlock Text="كود العميل (ID)"
                           Foreground="{StaticResource GrayText}"
                           FontSize="12"
                           Margin="0,0,0,5"/>

                                            <TextBlock x:Name="TxtProfileID"
                           Text="---"
                           FontWeight="Bold"
                           FontSize="16"
                           Foreground="{StaticResource DarkText}"/>
                                        </StackPanel>
                                        <!-- الاسم الكامل -->
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="الاسم الكامل"
                           Foreground="{StaticResource GrayText}"
                           FontSize="12"
                           Margin="0,0,0,5"/>

                                            <TextBlock x:Name="TxtProfileName"
                           Text="---"
                           FontWeight="Bold"
                           FontSize="16"
                           TextWrapping="Wrap"

                           Foreground="{StaticResource DarkText}"/>
                                        </StackPanel>

                                    </Grid>

                                    <!-- الصف الثاني: الجنس + العمر -->
                                    <Grid Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- الجنس -->
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="الجنس"
                           Foreground="{StaticResource GrayText}"
                           FontSize="12"
                           Margin="0,0,0,5"/>

                                            <TextBlock x:Name="TxtProfileSex"
                           Text="---"
                           FontWeight="Bold"
                           FontSize="16"
                           Foreground="{StaticResource DarkText}"/>
                                        </StackPanel>

                                        <!-- العمر -->
                                        <StackPanel Grid.Column="1"
                        HorizontalAlignment="Left">
                                            <TextBlock Text="العمر"
                           Foreground="{StaticResource GrayText}"
                           FontSize="12"
                           Margin="0,0,0,5"/>

                                            <TextBlock x:Name="TxtProfileAge"
                           Text="---"
                           FontWeight="Bold"
                           FontSize="16"
                           Foreground="{StaticResource DarkText}"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- العنوان -->
                                    <StackPanel Margin="0,0,0,20">
                                        <TextBlock Text="العنوان"
                       Foreground="{StaticResource GrayText}"
                       FontSize="12"
                       Margin="0,0,0,5"/>

                                        <TextBlock x:Name="TxtProfileAddress"
                       Text="---"
                       FontWeight="SemiBold"
                       FontSize="14"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource DarkText}"/>
                                    </StackPanel>

                                    <!-- الخصم -->
                                    <StackPanel>
                                        <TextBlock Text="نسبة الخصم (%)"
                       Foreground="{StaticResource GrayText}"
                       FontSize="12"
                       Margin="0,0,0,5"/>

                                        <TextBlock x:Name="TxtProfileDiscount"
                       Text="---"
                       FontWeight="Bold"
                       FontSize="16"
                       Foreground="{StaticResource SuccessGreen}"/>
                                    </StackPanel>

                                </StackPanel>
                            </Border>


                            <!-- خط فاصل -->
                            <Border Height="8" Background="#F3F4F6"/>

                            <!-- SECTION 2: أرقام الهواتف -->
                            <Border x:Name="PhonesSection" Padding="25,15" Background="White">
                                <StackPanel>

                                    <!-- Header الهواتف -->
                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="📱 الهواتف المسجلة"
                                                   FontSize="16"
                                                   FontWeight="Bold"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource DarkText}"/>

                                        <Button x:Name="btnAddNum" Grid.Column="1"
                                                Content="➕ إضافة رقم"
                                                Background="{StaticResource PrimaryBlue}"
                                                
                                                Foreground="White"
                                                Padding="12,6"
                                                FontSize="13"
                                                FontWeight="SemiBold"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Click="BtnAddPhone_Click"
                                                IsEnabled="False">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>

                                    <ItemsControl x:Name="PhonesList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#F9FAFB" BorderBrush="{StaticResource BorderGray}" BorderThickness="1" CornerRadius="12" Padding="18" Margin="0,0,0,12">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <Border Width="45" Height="45" Background ="{StaticResource SuccessGreen}" CornerRadius="22.5" Margin="0,0,15,0">
                                                            <TextBlock Text="📱" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>

                                                        <TextBlock Grid.Column="1" Text="{Binding}" FontWeight="Bold" FontSize="17" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0" Foreground="{StaticResource DarkText}"/>

                                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                            <Button Content="✏️"        ToolTip="تعديل الهاتف "
 Background="{StaticResource PrimaryBlue}" 
            Style="{StaticResource IconButtonStyle}" 
            Tag="{Binding}" Click="BtnEditPhone_Click" Margin="0,0,5,0"/>
                                                            <Button Content="🗑️"         ToolTip="حذف الهاتف"
Background="{StaticResource DangerRed}" 
            Style="{StaticResource IconButtonStyle}" 
            Tag="{Binding}" Click="BtnDeletePhone_Click"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock x:Name="TxtNoPhonesMessage" Text="❌ لا توجد أرقام هواتف مسجلة" Foreground="{StaticResource GrayText}" FontSize="13" HorizontalAlignment="Center" Margin="0,20,0,0" Visibility="Collapsed"/>
                                </StackPanel>
                            </Border>

                            <!-- خط فاصل -->
                            <Border Height="8" Background="#F3F4F6"/>

                            <!-- SECTION 3: الأجهزة -->
                            <Border Background="White" Padding="20,14">
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="🧺 الأجهزة المسجلة" FontSize="16" FontWeight="Bold" Foreground="#1F2937" VerticalAlignment="Center"/>

                                    <Button x:Name="btnAddDevice" 
                                            Content="➕ إضافة جهاز"
                                            Background="{StaticResource PrimaryBlue}"
                                            Foreground="White"
                                            Padding="12,6"
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Click="BtnAddDevice_Click"
                                            Grid.Column="1"
                                            IsEnabled="False">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                </Grid>
                            </Border>

                            <Border x:Name="DevicesSection" Padding="20" Background="White">
                                <StackPanel>
                                    <ItemsControl x:Name="DevicesList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="16" Padding="18" Margin="0,0,0,16">
                                                    <StackPanel>
                                                        <Grid Margin="0,0,0,10">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <Border Width="48" Height="48" Background="#EEF2FF" CornerRadius="12" Margin="0,0,12,0">
                                                                <TextBlock Text="🧺" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>

                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="{Binding TypeName}" FontSize="16" FontWeight="Bold" Foreground="#111827"/>
                                                                    <TextBlock Text=" - " FontSize="16" FontWeight="Bold" Foreground="#111827"/>
                                                                    <TextBlock Text="{Binding BrandName}" FontSize="16" FontWeight="Bold" Foreground="#111827"/>
                                                                </StackPanel>

                                                                <TextBlock Text="{Binding SpecName}" FontSize="13" Foreground="#4B5563" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                                            </StackPanel>

                                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
                                                                <Button Content="✏️"         ToolTip="تعديل بيانات الجهاز"
 Background="#2563EB" Style="{StaticResource IconButtonStyle}" 
            Click="BtnEditDevice_Click" Tag="{Binding}" Margin="0,0,6,0"/>
                                                                <Button Content="📜"         ToolTip="تاريخ صيانة الجهاز"
Background="#2563EB" Style="{StaticResource IconButtonStyle}" 
            Click="BtnDeviceHistory_Click" Tag="{Binding}" Margin="0,0,6,0"/>
                                                                <Button Content="🗑️"         ToolTip="حذف الجهاز"
 Background="#EF4444" Style="{StaticResource IconButtonStyle}" 
            Click="BtnDeleteDevice_Click" Tag="{Binding}"/>
                                                            </StackPanel>
                                                        </Grid>

                                                        <Border Height="1" Background="#F3F4F6" Margin="60,4,0,8"/>

                                                        <WrapPanel Margin="52,6,0,0">

                                                            <!-- S/N FIRST -->
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                                                                <StackPanel.Style>
                                                                    <Style TargetType="StackPanel">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding SerialNumber}" Value="{x:Null}">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding SerialNumber}" Value="">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </StackPanel.Style>

                                                                <TextBlock Text="S/N: "
                   FontSize="11"
                   Foreground="#9CA3AF"
                   Margin="0,0,4,0"/>

                                                                <TextBlock Text="{Binding SerialNumber}"
                   FontSize="12"
                   FontWeight="SemiBold"
                   Foreground="#374151"/>
                                                            </StackPanel>


                                                            <!-- MODEL SECOND -->
                                                            <StackPanel Orientation="Horizontal">
                                                                <StackPanel.Style>
                                                                    <Style TargetType="StackPanel">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Model}" Value="{x:Null}">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Model}" Value="">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </StackPanel.Style>

                                                                <TextBlock Text="الموديل: "
                   FontSize="11"
                   Foreground="#9CA3AF"
                   Margin="0,0,4,0"/>

                                                                <TextBlock Text="{Binding Model}"
                   FontSize="12"
                   FontWeight="SemiBold"
                   Foreground="#374151"/>
                                                            </StackPanel>

                                                        </WrapPanel>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock x:Name="TxtNoDevicesMessage" Text="❌ لا توجد أجهزة مسجلة" Foreground="#6B7280" FontSize="13" HorizontalAlignment="Center" Margin="0,20,0,0" Visibility="Collapsed"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>

                </Border>

                <!-- ========== قائمة العملاء (يمين) ========== -->
                <Border Grid.Column="0" Background="White" CornerRadius="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Padding="25,15" 
        BorderThickness="0,0,0,1" 
        BorderBrush="{StaticResource LightGray}">

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">

                                <Button Content="📊 لوحة التحكم"
                Padding="15,10"
                Background="Transparent"
                BorderThickness="0"
                Foreground="{StaticResource GrayText}"/>
                                <Button x:Name="BtnCustomersTab"
                Content="👥 إدارة العملاء"
                Padding="15,10"
                Background="Transparent"
                BorderThickness="0,0,0,3"
                BorderBrush="{StaticResource PrimaryBlue}"
                Foreground="{StaticResource PrimaryBlue}"
                FontWeight="SemiBold"
                />

                                <Button Content="🔧 إدارة الفنيين"
                Padding="15,10"
                Background="Transparent"
                BorderThickness="0"
                Foreground="{StaticResource GrayText}"/>

                                <Button Content="📦 إدارة الطلبات"
                Padding="15,10"
                Background="Transparent"
                BorderThickness="0"
                Foreground="{StaticResource GrayText}"/>



                                <Button x:Name="BtnSettingsTab" Content="⚙️ الإعدادات"
                Padding="15,10"
                Background="Transparent"
                BorderThickness="0"
                Foreground="{StaticResource GrayText}"
                ></Button>

                            </StackPanel>
                        </Border>

                        <Grid Grid.Row="1">


                            <Grid x:Name="CustomersContainer" Visibility="Visible">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <!-- customerheader -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- عنوان + عدد العملاء -->
                                    <RowDefinition Height="*"/>
                                    <!-- DataGrid -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- Pagination -->
                                </Grid.RowDefinitions>

                                <!-- Header: زر الإضافة + البحث -->
                                <Border x:Name="customerheader" Grid.Row="0" Padding="25,15">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,20,0">
                                            <TextBlock Text="قائمة العملاء" FontSize="16" FontWeight="Bold" Foreground="#1E293B"/>
                                            <TextBlock FontSize="12" Foreground="#64748B" Margin="0,4,0,0">
                <Run Text="عدد العملاء: "/>
                <Run x:Name="TxtCustomerCountNumber" Text="0" FontWeight="Bold"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <Border Grid.Column="1" Background="White" BorderBrush="{StaticResource BorderGray}"
                BorderThickness="1" CornerRadius="8" Padding="12,8" MaxWidth="400" HorizontalAlignment="Center" Width="350">
                                            <Grid>
                                                <TextBox x:Name="SearchBox" Background="Transparent" BorderThickness="0" FontSize="14"
                         Foreground="Black" VerticalContentAlignment="Center" KeyDown="SearchBox_KeyDown"/>
                                                <TextBlock Text="🔍 بحث بالاسم أو كود العميل" Foreground="{StaticResource GrayText}" 
                           IsHitTestVisible="False" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="{x:Type TextBlock}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </Border>

                                        <Button x:Name="BtnAddCustomer" Grid.Column="2" Content="➕ إنشاء عميل" Height="38"
                Padding="18,8" Background="{StaticResource PrimaryBlue}" Foreground="White"
                BorderThickness="0" Cursor="Hand" FontWeight="SemiBold" FontSize="14"
                Click="BtnCreateCustomer_Click" HorizontalAlignment="Left">
                                            <Button.Template>
                                                <ControlTemplate TargetType="{x:Type Button}">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </Border>

                                <Grid Grid.Row="1">
                                    <DataGrid x:Name="DgCustomers" 
                  AutoGenerateColumns="False" 
                  GridLinesVisibility="None" 
                  Background="Transparent" 
                  BorderThickness="0" 
                  SelectionMode="Single" 
                  CanUserAddRows="False" 
                  IsReadOnly="True" 
                  RowHeaderWidth="0" 
                  SelectionChanged="DgCustomers_SelectionChanged">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="كود العميل" Binding="{Binding ID}" Width="150"/>
                                            <DataGridTextColumn Header="الاسم" Binding="{Binding Name}" Width="1.5*"/>
                                            <DataGridTextColumn Header="الهاتف" Binding="{Binding Phone}" Width="150"/>
                                            <DataGridTextColumn Header="العنوان" Binding="{Binding Address}" Width="*"/>
                                            <DataGridTemplateColumn Width="60">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnDeleteCustomer_Click">
                                                            <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" Fill="#EF4444" Width="16" Height="16" Stretch="Uniform"/>
                                                        </Button>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <Border x:Name="EmptyStateOverlay" 
                Background="#AAFFFFFF" 
                Visibility="Collapsed" 
                CornerRadius="12">
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="👥" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,15" Opacity="0.2"/>
                                            <TextBlock x:Name="TxtEmptyMessage" 
                           Text="لا توجد بيانات لعرضها" 
                           FontSize="15" FontWeight="Bold" Foreground="#475569" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Border Grid.Row="3" Padding="15" Background="White" BorderBrush="#F1F5F9" BorderThickness="0">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                                        <Button x:Name="BtnNextPage" Click="BtnNextPage_Click" Width="42" Height="42" Cursor="Hand">
                                            <Button.Style>
                                                <Style TargetType="{x:Type Button}">
                                                    <Setter Property="Background" Value="White"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="{x:Type Button}">
                                                                <Border x:Name="btnBorder" Background="{TemplateBinding Background}" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1.5">
                                                                    <Path x:Name="arrowPath" Data="M6.5 1L1.5 6L6.5 11" Stroke="#64748B" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="Uniform" Width="10" Height="14"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="btnBorder" Property="Background" Value="#F1F5F9"/>
                                                                        <Setter TargetName="arrowPath" Property="Stroke" Value="#2563EB"/>
                                                                        <Setter TargetName="btnBorder" Property="BorderBrush" Value="#2563EB"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter Property="Opacity" Value="0.2"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <StackPanel VerticalAlignment="Center" Margin="20,0">
                                            <TextBlock x:Name="TxtPageInfo" Text="1" Foreground="#1E293B" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                            <TextBlock Text="الصفحة" Foreground="#94A3B8" FontSize="10" HorizontalAlignment="Center" Margin="0,-2,0,0"/>
                                        </StackPanel>

                                        <Button x:Name="BtnPrevPage" Click="BtnPrevPage_Click" Width="42" Height="42" Cursor="Hand">
                                            <Button.Style>
                                                <Style TargetType="{x:Type Button}">
                                                    <Setter Property="Background" Value="White"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="{x:Type Button}">
                                                                <Border x:Name="btnBorder" Background="{TemplateBinding Background}" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1.5">
                                                                    <Path x:Name="arrowPath" Data="M1.5 1L6.5 6L1.5 11" Stroke="#64748B" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="Uniform" Width="10" Height="14"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="btnBorder" Property="Background" Value="#F1F5F9"/>
                                                                        <Setter TargetName="arrowPath" Property="Stroke" Value="#2563EB"/>
                                                                        <Setter TargetName="btnBorder" Property="BorderBrush" Value="#2563EB"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter Property="Opacity" Value="0.2"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                    </StackPanel>
                                </Border>
   
                            </Grid>



                        </Grid>
                    </Grid>

                </Border>

            </Grid>
        </Grid>

    </Grid>
</Window>