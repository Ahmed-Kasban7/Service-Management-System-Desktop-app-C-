<Window x:Class="Presentation.View.Customer_View.CustomerListView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="لوحة التحكم - Admin Console"
        Height="800"
        Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#EEF2F7"
        FlowDirection="RightToLeft">

    <Window.Resources>

        <!-- الألوان -->
        <SolidColorBrush x:Key="PrimaryBlue" Color="#4169E1"/>
        <SolidColorBrush x:Key="SuccessGreen" Color="#10B981"/>
        <SolidColorBrush x:Key="DangerRed" Color="#EF4444"/>
        <SolidColorBrush x:Key="WarningOrange" Color="#F59E0B"/>
        <SolidColorBrush x:Key="LightBlue" Color="#E8F0FE"/>
        <SolidColorBrush x:Key="DarkText" Color="#1A1A1A"/>
        <SolidColorBrush x:Key="GrayText" Color="#6B7280"/>
        <SolidColorBrush x:Key="LightGray" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="BorderGray" Color="#D1D5DB"/>
        <SolidColorBrush x:Key="RedButton" Color="#EF4444"/>

        <!-- الخطوط -->
        <Style TargetType="Control">
            <Setter Property="FontFamily" Value="Cairo, Segoe UI, Tahoma"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- TextBox Style -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderGray}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource DarkText}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBlue}"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox Style -->
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderGray}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource DarkText}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <Grid>
                                <ToggleButton Name="ToggleButton"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              Focusable="False"
                                              IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                              ClickMode="Press"/>
                                <ContentPresenter Name="ContentSite"
                                                  IsHitTestVisible="False"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  Margin="12,10"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Right"/>
                                <Popup Name="Popup"
                                       Placement="Bottom"
                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       PopupAnimation="Slide">
                                    <Border Background="White"
                                            BorderBrush="{StaticResource BorderGray}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Margin="0,5,0,0">
                                        <ScrollViewer>
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Button Style -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="25,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Icon Button Style -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid Column Header Style -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource GrayText}"/>
            <Setter Property="Padding" Value="20,15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{StaticResource LightGray}"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
        </Style>

        <!-- DataGrid Row Style -->
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{StaticResource LightGray}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F9FAFB"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource LightBlue}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataGrid Cell Style -->
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource DarkText}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="43*"/>
            <ColumnDefinition Width="27*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- الشريط العلوي -->
        <Grid Grid.Row="1" Grid.ColumnSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" Padding="30,20" 
                    BorderThickness="0,0,0,1" BorderBrush="{StaticResource LightGray}">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="+ إنشاء طلب"
                                Style="{StaticResource PrimaryButton}"
                                Margin="0,0,15,0"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" FlowDirection="LeftToRight">
                        <Border Background="White"
                                BorderBrush="{StaticResource BorderGray}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12,8"
                                Margin="0,0,10,0">
                            <TextBlock Text="📅 29 يناير 2026" Foreground="{StaticResource GrayText}"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- المحتوى الرئيسي -->
            <Grid Grid.Row="1" Margin="30,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="450"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>


                <!-- ========== البروفايل الكامل (يسار) ========== -->
                <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="0" Margin="0,0,20,0"
                        x:Name="ProfileSection" Opacity="0.3">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Customer Top Header - محسّن -->
                            <Border Padding="20" 
        Background="White" 
        BorderThickness="0,0,0,1" 
        BorderBrush="{StaticResource LightGray}" 
        CornerRadius="12,12,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="19*"/>
                                        <ColumnDefinition Width="20*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- العنوان -->
                                    <TextBlock Text="👤 بيانات العميل"
                   FontWeight="Bold"
                   FontSize="16"
                   VerticalAlignment="Center"
                   Foreground="{StaticResource PrimaryBlue}" Margin="-10,0,10,0" Grid.ColumnSpan="2"/>

                                    <!-- زر الحذف -->
                                    <Button x:Name="BtnDeleteCustomer"
                Content="🗑️ حذف العميل"
                Padding="12,6"
                Background="{StaticResource DangerRed}"
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand"
                Click="BtnDeleteCustomer_Click"
                IsEnabled="False"
                FontWeight="SemiBold" Margin="90,-12,-10,-12" Grid.Column="1" Grid.ColumnSpan="2">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Opacity" Value="0.9"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter Property="Opacity" Value="0.5"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Border>


                            <!-- SECTION 1: البيانات الأساسية - محسّن -->
                            <Border Background="#4169E1"
        CornerRadius="12,12,0,0"
        Padding="20,15">

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- العنوان -->
                                    <TextBlock Text="📋 البيانات الأساسية"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="White"
                   VerticalAlignment="Center"/>

                                    <!-- أزرار تعديل / حذف -->
                                    <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
                                        <!-- تعديل -->
                                        <Button x:Name="BtnEditCustomer"
                    Content="✏️"
                    Width="36"
                    Height="36"
                    Background="White"
                    Foreground="{StaticResource PrimaryBlue}"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="BtnEditCustomer_Click"
                    IsEnabled="False" RenderTransformOrigin="1.333,0.537">
                                            <Button.Template>
                                                <ControlTemplate TargetType="{x:Type Button}">
                                                    <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8">
                                                        <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Opacity" Value="0.9"/>
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter Property="Opacity" Value="0.4"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <!-- تعديل -->
                                        <!-- تعديل -->

                                        <!-- تعديل -->

                                        <!-- حذف -->

                                    </StackPanel>
                                </Grid>
                            </Border>


                            <Border Padding="25"
        Background="White"
        FlowDirection="RightToLeft">

                                <StackPanel>

                                    <!-- الصف الأول: الاسم + الكود -->
                                    <Grid Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- الاسم الكامل -->
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="الاسم الكامل"
                           Foreground="{StaticResource GrayText}"
                           FontSize="12"
                           Margin="0,0,0,5"/>

                                            <TextBlock x:Name="TxtProfileName"
                           Text="---"
                           FontWeight="Bold"
                           FontSize="16"
                           TextWrapping="Wrap"

                           Foreground="{StaticResource DarkText}"/>
                                        </StackPanel>

                                        <!-- كود العميل -->
                                        <StackPanel Grid.Column="1"
                        HorizontalAlignment="Left">
                                            <TextBlock Text="كود العميل (ID)"
                           Foreground="{StaticResource GrayText}"
                           FontSize="12"
                           Margin="0,0,0,5"/>

                                            <TextBlock x:Name="TxtProfileID"
                           Text="---"
                           FontWeight="Bold"
                           FontSize="16"
                           Foreground="{StaticResource DarkText}"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- الصف الثاني: الجنس + العمر -->
                                    <Grid Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- الجنس -->
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="الجنس"
                           Foreground="{StaticResource GrayText}"
                           FontSize="12"
                           Margin="0,0,0,5"/>

                                            <TextBlock x:Name="TxtProfileSex"
                           Text="---"
                           FontWeight="Bold"
                           FontSize="16"
                           Foreground="{StaticResource DarkText}"/>
                                        </StackPanel>

                                        <!-- العمر -->
                                        <StackPanel Grid.Column="1"
                        HorizontalAlignment="Left">
                                            <TextBlock Text="العمر"
                           Foreground="{StaticResource GrayText}"
                           FontSize="12"
                           Margin="0,0,0,5"/>

                                            <TextBlock x:Name="TxtProfileAge"
                           Text="---"
                           FontWeight="Bold"
                           FontSize="16"
                           Foreground="{StaticResource DarkText}"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- العنوان -->
                                    <StackPanel Margin="0,0,0,20">
                                        <TextBlock Text="العنوان"
                       Foreground="{StaticResource GrayText}"
                       FontSize="12"
                       Margin="0,0,0,5"/>

                                        <TextBlock x:Name="TxtProfileAddress"
                       Text="---"
                       FontWeight="SemiBold"
                       FontSize="14"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource DarkText}"/>
                                    </StackPanel>

                                    <!-- الخصم -->
                                    <StackPanel>
                                        <TextBlock Text="نسبة الخصم (%)"
                       Foreground="{StaticResource GrayText}"
                       FontSize="12"
                       Margin="0,0,0,5"/>

                                        <TextBlock x:Name="TxtProfileDiscount"
                       Text="---"
                       FontWeight="Bold"
                       FontSize="16"
                       Foreground="{StaticResource SuccessGreen}"/>
                                    </StackPanel>

                                </StackPanel>
                            </Border>


                            <!-- خط فاصل -->
                            <Border Height="8" Background="#F3F4F6"/>

                            <!-- SECTION 2: أرقام الهواتف -->
                            <Border x:Name="PhonesSection" Padding="25,15" Background="White">
                                <StackPanel>

                                    <!-- Header الهواتف -->
                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="📱 الهواتف المسجلة"
                                                   FontSize="16"
                                                   FontWeight="Bold"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource DarkText}"/>

                                        <Button x:Name="btnAddNum" Grid.Column="1"
                                                Content="➕ إضافة رقم"
                                                Background="{StaticResource PrimaryBlue}"
                                                Foreground="White"
                                                Padding="12,6"
                                                FontSize="13"
                                                FontWeight="SemiBold"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Click="BtnAddPhone_Click"
                                                IsEnabled="False">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>

                                    <ItemsControl x:Name="PhonesList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#F9FAFB" BorderBrush="{StaticResource BorderGray}" BorderThickness="1" CornerRadius="12" Padding="18" Margin="0,0,0,12">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <Border Width="45" Height="45" Background ="{StaticResource SuccessGreen}" CornerRadius="22.5" Margin="0,0,15,0">
                                                            <TextBlock Text="📱" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>

                                                        <TextBlock Grid.Column="1" Text="{Binding}" FontWeight="Bold" FontSize="17" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0" Foreground="{StaticResource DarkText}"/>

                                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                            <Button Content="✏️" Width="38" Height="38" Background="{StaticResource PrimaryBlue}" Foreground="White" Tag="{Binding}" Click="BtnEditPhone_Click" Margin="0,0,8,0">
                                                                <Button.Template>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </Button.Template>
                                                            </Button>
                                                            <Button Content="🗑️" Width="38" Height="38" Background="{StaticResource DangerRed}" Foreground="White" Tag="{Binding}" Click="BtnDeletePhone_Click">
                                                                <Button.Template>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </Button.Template>
                                                            </Button>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock x:Name="TxtNoPhonesMessage" Text="❌ لا توجد أرقام هواتف مسجلة" Foreground="{StaticResource GrayText}" FontSize="13" HorizontalAlignment="Center" Margin="0,20,0,0" Visibility="Collapsed"/>
                                </StackPanel>
                            </Border>

                            <!-- خط فاصل -->
                            <Border Height="8" Background="#F3F4F6"/>

                            <!-- SECTION 3: الأجهزة -->
                            <Border Background="White" Padding="20,14">
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="🧺 الأجهزة المسجلة" FontSize="16" FontWeight="Bold" Foreground="#1F2937" VerticalAlignment="Center"/>

                                    <Button x:Name="btnAddDevice" 
                                            Content="➕ إضافة جهاز"
                                            Background="{StaticResource PrimaryBlue}"
                                            Foreground="White"
                                            Padding="12,6"
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Click="BtnAddDevice_Click"
                                            Grid.Column="1"
                                            IsEnabled="False">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                </Grid>
                            </Border>

                            <Border x:Name="DevicesSection" Padding="20" Background="White">
                                <StackPanel>
                                    <ItemsControl x:Name="DevicesList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="16" Padding="18" Margin="0,0,0,16">
                                                    <StackPanel>
                                                        <Grid Margin="0,0,0,14">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <Border Width="44" Height="44" Background="#EEF2FF" CornerRadius="12" Margin="0,0,12,0">
                                                                <TextBlock Text="🧺" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>

                                                            <!-- Device Info -->
                                                            <StackPanel Grid.Column="1">
                                                                <TextBlock Text="{Binding Model}" FontSize="15" FontWeight="Bold" Foreground="#111827"/>
                                                                <TextBlock FontSize="12" Foreground="#6B7280">
                                                                    <Run Text="{Binding Brand}"/>
                                                                    <Run Text=" • "/>
                                                                    <Run Text="{Binding Type}"/>
                                                                </TextBlock>
                                                            </StackPanel>

                                                            <!-- Device Actions -->
                                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
                                                                <Button Content="✏️"
                                                                        Width="34"
                                                                        Height="34"
                                                                        Background="#2563EB"
                                                                        Foreground="White"
                                                                        Margin="0,0,6,0"
                                                                        BorderThickness="0"
                                                                        Tag="{Binding}"
                                                                        Click="BtnEditDevice_Click">
                                                                    <Button.Template>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                            </Border>
                                                                        </ControlTemplate>
                                                                    </Button.Template>
                                                                </Button>

                                                                <Button Content="📜"
                                                                        Width="34"
                                                                        Height="34"
                                                                        Background="#2563EB"
                                                                        Foreground="White"
                                                                        Margin="0,0,6,0"
                                                                        BorderThickness="0"
                                                                        Tag="{Binding}"
                                                                        Click="BtnDeviceHistory_Click">
                                                                    <Button.Template>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                            </Border>
                                                                        </ControlTemplate>
                                                                    </Button.Template>
                                                                </Button>

                                                                <Button Content="🗑️"
                                                                        Width="34"
                                                                        Height="34"
                                                                        Background="#EF4444"
                                                                        Foreground="White"
                                                                        BorderThickness="0"
                                                                        Tag="{Binding}"
                                                                        Click="BtnDeleteDevice_Click">
                                                                    <Button.Template>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                            </Border>
                                                                        </ControlTemplate>
                                                                    </Button.Template>
                                                                </Button>
                                                            </StackPanel>
                                                        </Grid>

                                                        <!-- Divider -->
                                                        <Border Height="1" Background="#E5E7EB" Margin="0,0,0,12"/>

                                                        <!-- Device Details -->
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition/>
                                                                <ColumnDefinition/>
                                                            </Grid.ColumnDefinitions>

                                                            <StackPanel>
                                                                <TextBlock Text="الرقم التسلسلي" FontSize="10" Foreground="#9CA3AF"/>
                                                                <TextBlock Text="{Binding SerialNumber}" FontSize="13" FontWeight="SemiBold" Foreground="#111827"/>
                                                            </StackPanel>

                                                            <StackPanel Grid.Column="1">
                                                                <TextBlock Text="المواصفات" FontSize="10" Foreground="#9CA3AF"/>
                                                                <TextBlock Text="{Binding Spec}" FontSize="13" FontWeight="SemiBold" Foreground="#111827"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock x:Name="TxtNoDevicesMessage" Text="❌ لا توجد أجهزة مسجلة" Foreground="#6B7280" FontSize="13" HorizontalAlignment="Center" Margin="0,20,0,0" Visibility="Collapsed"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- ========== قائمة العملاء (يمين) ========== -->
                <Border Grid.Column="1" Background="White" CornerRadius="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- التبويبات -->
                        <Border Grid.Row="0" Padding="25,15" 
                                BorderThickness="0,0,0,1" BorderBrush="{StaticResource LightGray}">
                            <Grid>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="🔧 Technicians" 
                                            Padding="15,10" Background="Transparent"
                                            BorderThickness="0" Foreground="{StaticResource GrayText}"/>
                                    <Button Content="📦 Orders" 
                                            Padding="15,10" Background="Transparent"
                                            BorderThickness="0" Foreground="{StaticResource GrayText}"/>
                                    <Button Content="👥 Customers" 
                                            Padding="15,10" Background="Transparent"
                                            BorderThickness="0,0,0,3" BorderBrush="{StaticResource PrimaryBlue}"
                                            Foreground="{StaticResource PrimaryBlue}" FontWeight="SemiBold"/>
                                    <Button Content="📊 Dashboard" 
                                            Padding="15,10" Background="Transparent"
                                            BorderThickness="0" Foreground="{StaticResource GrayText}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- شريط البحث والعنوان والزرار - محسّن -->
                        <Border Grid.Row="1" Padding="25,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- شريط البحث في اليمين -->
                                <Border Grid.Column="0"
                Background="White"
                BorderBrush="{StaticResource BorderGray}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12,8"
                MaxWidth="450"
                HorizontalAlignment="Left" Width="303">
                                    <Grid Width="420">
                                        <TextBox x:Name="SearchBox"
         Background="Transparent"
         BorderThickness="0"
         FontSize="14"
         Foreground="Black"
         VerticalContentAlignment="Center"
         KeyDown="SearchBox_KeyDown"/>


                                        <TextBlock Text="🔍 بحث بالاسم أو الهاتف أو كود العميل"
                           Foreground="{StaticResource GrayText}"
                           IsHitTestVisible="False"
                           VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Border>

                                <!-- عدد العملاء في الوسط -->
                                <StackPanel Grid.Column="1" 
                    Orientation="Horizontal" 
                    VerticalAlignment="Center"
                    Margin="20,0"/>

                                <!-- زرار الإنشاء في اليسار -->
                                <Button
    x:Name="BtnAddCustomer"
    Content="➕ إنشاء عميل"
    Height="38"
    Padding="18,8"
    Background="{StaticResource PrimaryBlue}"
    Foreground="White"
    BorderThickness="0"
    Cursor="Hand"
    FontWeight="SemiBold"
    FontSize="13"
    Click="BtnCreateCustomer_Click"
    Grid.Column="2"
    HorizontalAlignment="Left">

                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="0.9"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>
                        <!-- الجدول -->
                        <DataGrid Grid.Row="2" x:Name="DgCustomers"
                                  AutoGenerateColumns="False"
                                  GridLinesVisibility="None"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  SelectionMode="Single"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserResizeRows="False"
                                  CanUserReorderColumns="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  SelectionChanged="DgCustomers_SelectionChanged">

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="العنوان" Binding="{Binding Address}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextAlignment" Value="Left"/>
                                            <Setter Property="FlowDirection" Value="LeftToRight"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="الهاتف" Binding="{Binding Phone}" Width="170">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextAlignment" Value="Left"/>
                                            <Setter Property="FlowDirection" Value="LeftToRight"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="الاسم" Binding="{Binding Name}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextAlignment" Value="Left"/>
                                            <Setter Property="FlowDirection" Value="LeftToRight"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="كود العميل" Binding="{Binding ID}" Width="170">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextAlignment" Value="Left"/>
                                            <Setter Property="FlowDirection" Value="LeftToRight"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>

                        </DataGrid>
                    </Grid>
                </Border>

            </Grid>
        </Grid>
    </Grid>
</Window>