<UserControl x:Class="Presentation.View.Settings_View.SettingsUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             Background="#EEF2F7"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             SnapsToDevicePixels="True">

    <UserControl.Resources>
        <!-- الألوان - نفس الموجودة -->
        <SolidColorBrush x:Key="PrimaryBlue" Color="#4169E1"/>
        <SolidColorBrush x:Key="SuccessGreen" Color="#10B981"/>
        <SolidColorBrush x:Key="LightBlue" Color="#E8F0FE"/>
        <SolidColorBrush x:Key="DarkText" Color="#1A1A1A"/>
        <SolidColorBrush x:Key="GrayText" Color="#6B7280"/>
        <SolidColorBrush x:Key="LightGray" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="BorderGray" Color="#D1D5DB"/>
        <SolidColorBrush x:Key="DangerRed" Color="#EF4444"/>
        

        <!-- TextBox Style - محسّن -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource DarkText}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderGray}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                          VerticalAlignment="Center" 
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryBlue}"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar Button - محسّن -->
        <Style x:Key="SidebarButton" TargetType="RadioButton">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource GrayText}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="btnBorder" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="10" 
                                Margin="5,2">
                            <ContentPresenter HorizontalAlignment="Left" 
                                              VerticalAlignment="Center" 
                                              Margin="15,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="{StaticResource LightBlue}"/>
                                <Setter TargetName="btnBorder" Property="BorderBrush" Value="{StaticResource PrimaryBlue}"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBlue}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="#F8FAFC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Success Button Style - جديد -->
        <Style x:Key="SuccessButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataTemplate - محسّن شوية -->
        <DataTemplate x:Key="SettingListItemTemplate">
            <Border Background="White"
            BorderBrush="{StaticResource LightGray}"
            BorderThickness="0,0,0,1"
            Padding="10,8"
            HorizontalAlignment="Stretch">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <!-- الاسم -->
                        <ColumnDefinition Width="40"/>
                        <!-- زر الحذف -->
                    </Grid.ColumnDefinitions>

                    <!-- الاسم -->
                    <TextBlock Grid.Column="0"
                       Text="{Binding}" 
                       VerticalAlignment="Center"
                       Foreground="{StaticResource DarkText}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       TextWrapping="NoWrap"/>

            <!-- زر الحذف -->
            <Button Grid.Column="1"
                    Content="🗑️"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="{StaticResource DangerRed}"
                    Cursor="Hand"
                    Tag="{Binding}"
                    Click="BtnDeleteListItem_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="deleteBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="deleteBorder" Property="Background" Value="#FEE2E2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
            </Border>
        </DataTemplate>

    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="15"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar - محسّن بإضافة Shadow -->
        <Border Grid.Column="0" 
                Background="White" 
CornerRadius="0,0,12,12"
                Margin="0,0,5,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" Color="#000" Opacity="0.04" ShadowDepth="1"/>
            </Border.Effect>

            <StackPanel Margin="0,20">
                <!-- Header - محسّن -->
                <StackPanel Margin="20,0,0,25">
                    <TextBlock Text="الإعدادات ⚙️" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource DarkText}"/>
                    <TextBlock Text="إدارة إعدادات النظام" 
                               FontSize="11" 
                               Foreground="{StaticResource GrayText}"
                               Margin="0,3,0,0"/>
                </StackPanel>

                <!-- Menu Items - نفس الموجود -->
                <RadioButton x:Name="BtnGeneralSettings" 
                             Style="{StaticResource SidebarButton}" 
                             IsChecked="True" 
                             Checked="BtnGeneralSettings_Checked">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🏢" Margin="0,0,10,0" FontSize="15"/>
                        <TextBlock><Run Text="بيانات ا"/><Run FlowDirection="RightToLeft" Language="ar-eg" Text="لمركز"/></TextBlock>
                    </StackPanel>
                </RadioButton>

                <RadioButton x:Name="BtnHardwareSettings" 
                             Style="{StaticResource SidebarButton}" 
                             Checked="BtnHardwareSettings_Checked">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🧺" Margin="0,0,10,0" FontSize="15"/>
                        <TextBlock Text="إدارة الاجهزة"/>
                    </StackPanel>
                </RadioButton>

                <Separator Margin="15,10" Background="{StaticResource LightGray}"/>

                <RadioButton x:Name="BtnBackupSettings" 
                             Style="{StaticResource SidebarButton}" 
                             Checked="BtnBackupSettings_Checked">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💾" Margin="0,0,10,0" FontSize="15"/>
                        <TextBlock Text="النسخ الاحتياطي"/>
                    </StackPanel>
                </RadioButton>
            </StackPanel>
        </Border>

        <!-- Content Area - محسّن -->
        <Border Grid.Column="2" 
                Background="White" 
                CornerRadius="0,0,12,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" Color="#000" Opacity="0.04" ShadowDepth="1"/>
            </Border.Effect>

            <Grid Margin="30">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <!-- بيانات المركز - نفس الموجود مع تحسينات -->
                        <Border x:Name="GeneralSettingsPanel" Visibility="Visible">
                            <StackPanel>
                                <!-- Header - محسّن -->
                                <StackPanel Margin="0,0,0,25">
                                    <TextBlock Text="🏢 بيانات المركز الأساسية" 
                                               FontSize="22" 
                                               FontWeight="Bold" 
                                               Foreground="{StaticResource DarkText}"/>
                                    <TextBlock Text="إدارة المعلومات الأساسية للمركز" 
                                               FontSize="13" 
                                               Foreground="{StaticResource GrayText}"
                                               Margin="0,5,0,0"/>
                                </StackPanel>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="220"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Left Column - Form -->
                                    <StackPanel Grid.Column="0">
                                        <!-- اسم المركز -->
                                        <StackPanel Margin="0,0,0,18">
                                            <TextBlock Text="اسم المركز  *" 
                                                       Margin="0,0,0,6" 
                                                       Foreground="{StaticResource GrayText}" 
                                                       FontSize="13"/>
                                            <TextBox x:Name="TxtCenterName"
                                                     Style="{StaticResource ModernTextBox}"/>
                                        </StackPanel>

                                        <!-- الهاتف والبريد -->
                                        <Grid Margin="0,0,0,18">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="15"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="رقم الهاتف *" 
                                                           Margin="0,0,0,6" 
                                                           Foreground="{StaticResource GrayText}" 
                                                           FontSize="13"/>
                                                <TextBox x:Name="TxtPhone"
                                                         Style="{StaticResource ModernTextBox}"
                                                         MaxLength="11"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2"/>
                                        </Grid>

                                        <!-- العنوان -->
                                        <StackPanel Margin="0,0,0,18">
                                            <TextBlock Text="العنوان" 
                                                       Margin="0,0,0,6" 
                                                       Foreground="{StaticResource GrayText}" 
                                                       FontSize="13"/>
                                            <TextBox x:Name="TxtAddress"
                                                     Style="{StaticResource ModernTextBox}"/>
                                        </StackPanel>

                                        <!-- ملاحظات إضافية -->
                                        <StackPanel>
                                            <TextBlock Text="ملاحظات إضافية" 
                                                       Margin="0,0,0,6" 
                                                       Foreground="{StaticResource GrayText}" 
                                                       FontSize="13"/>
                                            <TextBox x:Name="TxtNotes"
                                                     Height="90" 
                                                     TextWrapping="Wrap" 
                                                     AcceptsReturn="True" 
                                                     VerticalContentAlignment="Top" 
                                                     Padding="12,10"
                                                     Background="White"
                                                     Foreground="{StaticResource DarkText}"
                                                     BorderBrush="{StaticResource BorderGray}"
                                                     BorderThickness="1">
                                                <TextBox.Template>
                                                    <ControlTemplate TargetType="TextBox">
                                                        <Border x:Name="border"
                                                                Background="{TemplateBinding Background}" 
                                                                BorderBrush="{TemplateBinding BorderBrush}" 
                                                                BorderThickness="{TemplateBinding BorderThickness}" 
                                                                CornerRadius="8">
                                                            <ScrollViewer x:Name="PART_ContentHost" 
                                                                          Margin="{TemplateBinding Padding}"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsFocused" Value="True">
                                                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryBlue}"/>
                                                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </TextBox.Template>
                                            </TextBox>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Right Column - Logo -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Top">
                                        <TextBlock Text="شعار المركز (Logo)" 
                                                   HorizontalAlignment="Center" 
                                                   Margin="0,0,0,10" 
                                                   Foreground="{StaticResource GrayText}" 
                                                   FontSize="13"/>

                                        <!-- Logo Container -->
                                        <Border x:Name="LogoContainer"
                                                Width="200" 
                                                Height="200" 
                                                Background="#F8FAFC" 
                                                CornerRadius="12" 
                                                BorderBrush="{StaticResource LightGray}" 
                                                BorderThickness="2"
                                                Cursor="Hand">
                                            <Grid>
                                                <!-- Default State -->
                                                <StackPanel x:Name="DefaultLogoState"
                                                            VerticalAlignment="Center" 
                                                            HorizontalAlignment="Center">
                                                    <TextBlock Text="📸" 
                                                               FontSize="48" 
                                                               HorizontalAlignment="Center" 
                                                               Margin="0,0,0,10"/>
                                                    <TextBlock Text="إضافة شعار" 
                                                               Foreground="{StaticResource PrimaryBlue}" 
                                                               FontSize="14"
                                                               FontWeight="Medium"
                                                               HorizontalAlignment="Center"/>
                                                    <TextBlock Text="(اضغط للاختيار)" 
                                                               Foreground="{StaticResource GrayText}" 
                                                               FontSize="11"
                                                               HorizontalAlignment="Center"
                                                               Margin="0,3,0,0"/>
                                                </StackPanel>

                                                <!-- Logo Image -->
                                                <Image x:Name="LogoImage"
                                                       Stretch="UniformToFill"
                                                       Visibility="Collapsed"/>

                                                <!-- Click Handler -->
                                                <Button Background="Transparent" 
                                                        BorderThickness="0" 
                                                        Cursor="Hand"
                                                        Click="BtnUploadLogo_Click"/>
                                            </Grid>
                                        </Border>

                                        <!-- Delete Logo -->
                                        <Button x:Name="BtnRemoveLogo"
                                                Content="🗑️ حذف الشعار" 
                                                Background="Transparent" 
                                                Foreground="{StaticResource DangerRed}" 
                                                BorderThickness="0" 
                                                Margin="0,12,0,0" 
                                                FontSize="12" 
                                                Cursor="Hand"
                                                HorizontalAlignment="Center"
                                                Visibility="Collapsed"
                                                Click="BtnRemoveLogo_Click">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="deleteBorder"
                                                            Background="Transparent"
                                                            CornerRadius="6"
                                                            Padding="8,4">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="deleteBorder" Property="Background" Value="#FEE2E2"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Grid>

                                <!-- Save & Reset Buttons -->
                                <Separator Margin="0,30" Background="{StaticResource LightGray}"/>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                    <Button Content="💾 حفظ التغييرات" 
                                            Style="{StaticResource SuccessButton}" 
                                            Width="160"
                                            Click="BtnSaveSettings_Click"/>

                                    <Button Content="↺ إعادة تعيين" 
                                            Width="140"
                                            Height="42"
                                            Margin="10,0,0,0"
                                            Background="White"
                                            Foreground="{StaticResource GrayText}"
                                            BorderBrush="{StaticResource BorderGray}"
                                            BorderThickness="1"
                                            FontWeight="SemiBold"
                                            FontSize="14"
                                            Cursor="Hand"
                                            Click="BtnResetSettings_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" 
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="8" 
                                                        Padding="15,0">
                                                    <ContentPresenter HorizontalAlignment="Center" 
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#F9FAFB"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Hardware Settings Panel -->

                        <Border x:Name="HardwareSettingsPanel" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="🧺 إدارة تعريفات الأجهزة" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" Foreground="{StaticResource DarkText}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="15"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="15"/>
                                        <ColumnDefinition Width="1.2*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Background="#F8FAFC" CornerRadius="12" BorderBrush="{StaticResource LightGray}" BorderThickness="1" Padding="15">
                                        <StackPanel>
                                            <TextBlock Text="أنواع الأجهزة" FontWeight="Bold" Margin="0,0,0,10" Foreground="{StaticResource PrimaryBlue}"/>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="TxtNewType" Style="{StaticResource ModernTextBox}" Height="35"/>
                                                <Button Grid.Column="1" Content="+" Width="35" Margin="5,0,0,0" Background="{StaticResource PrimaryBlue}" Foreground="White" BorderThickness="0" Click="BtnAddType_Click">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </Grid>
                                            <Border Background="White" CornerRadius="8" Height="350" BorderBrush="{StaticResource LightGray}" BorderThickness="1">
                                                <ItemsControl x:Name="TypesList" ItemsSource="{Binding Types}" ItemTemplate="{StaticResource SettingListItemTemplate}"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2" Background="#F8FAFC" CornerRadius="12" BorderBrush="{StaticResource LightGray}" BorderThickness="1" Padding="15">
                                        <StackPanel>
                                            <TextBlock Text="ماركات الأجهزة" FontWeight="Bold" Margin="0,0,0,10" Foreground="{StaticResource PrimaryBlue}"/>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="TxtNewBrand" Style="{StaticResource ModernTextBox}" Height="35"/>
                                                <Button Grid.Column="1" Content="+" Width="35" Margin="5,0,0,0" Background="{StaticResource PrimaryBlue}" Foreground="White" BorderThickness="0" Click="BtnAddBrand_Click">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </Grid>
                                            <Border Background="White" CornerRadius="8" Height="350" BorderBrush="{StaticResource LightGray}" BorderThickness="1">
                                                <ItemsControl x:Name="BrandsList" ItemsSource="{Binding Brands}" ItemTemplate="{StaticResource SettingListItemTemplate}"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="4" Background="#F8FAFC" CornerRadius="12" BorderBrush="{StaticResource LightGray}" BorderThickness="1" Padding="15">
                                        <StackPanel>
                                            <TextBlock Text= "المواصفات" FontWeight="Bold" Margin="0,0,0,10" Foreground="{StaticResource PrimaryBlue}"/>

                                            <Grid Margin="0,0,0,15">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="150"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <ComboBox x:Name="ComboDeviceType" Grid.Column="0" Height="40" 
                      FontSize="14" VerticalContentAlignment="Center"
                      ItemsSource="{Binding Types}"
                      DisplayMemberPath="TypeName" 
                      SelectedValuePath="TypeID"
                      Style="{StaticResource ModernComboBox}"
                      Tag="اختر النوع"/>

                                                <TextBox x:Name="TxtNewSpec" Grid.Column="1" Margin="8,0" Style="{StaticResource ModernTextBox}" 
                     Height="40" FontSize="14" Tag="اسم المواصفة..."/>

                                                <Button Grid.Column="2" Content="+" Width="40" Height="40" 
                    Background="{StaticResource PrimaryBlue}" Foreground="White" 
                    BorderThickness="0" Click="BtnAddSpec_Click">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </Grid>

                                            <Border Background="{StaticResource LightGray}" Padding="10,5" CornerRadius="8,8,0,0">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="2*"/>
                                                        <ColumnDefinition Width="1*"/>
                                                        <ColumnDefinition Width="40"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="1" Text="المواصفة" FontSize="11" FontWeight="Bold" Foreground="{StaticResource GrayText}"/>
                                                    <TextBlock Grid.Column="0" Text="النوع" FontSize="11" FontWeight="Bold" Foreground="{StaticResource GrayText}"/>
                                                </Grid>
                                            </Border>

                                            <Border Background="White" CornerRadius="0,0,8,8" Height="340" BorderBrush="{StaticResource LightGray}" BorderThickness="1,0,1,1">
                                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                    <ItemsControl x:Name="SpecsList" ItemsSource="{Binding Specs}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Padding="10,8">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="2*"/>
                                                                            <ColumnDefinition Width="1*"/>
                                                                            <ColumnDefinition Width="40"/>
                                                                        </Grid.ColumnDefinitions>

                                                                        <TextBlock Grid.Column="1" Text="{Binding SpecName}" VerticalAlignment="Center" 
                                               Foreground="{StaticResource DarkText}" FontSize="13" TextWrapping="NoWrap"/>

                                                                        <TextBlock Grid.Column="0" Text="{Binding TypeName}" VerticalAlignment="Center" 
                                               Foreground="{StaticResource PrimaryBlue}" FontSize="13" FontWeight="SemiBold"/>

                                                                        <Button Grid.Column="2" Content="🗑️" Background="Transparent" BorderThickness="0" 
                                            Foreground="{StaticResource DangerRed}" Cursor="Hand" 
                                            Tag="{Binding}" Click="BtnDeleteListItem_Click"/>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </ScrollViewer>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Backup Settings Panel -->
                        <Border x:Name="BackupSettingsPanel" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="💾 النسخ الاحتياطي" 
                                           FontSize="22" 
                                           FontWeight="Bold" 
                                           Foreground="{StaticResource DarkText}"
                                           Margin="0,0,0,10"/>
                                <TextBlock Text="قسم النسخ الاحتياطي للبيانات قريباً..." 
                                           FontSize="16" 
                                           Foreground="{StaticResource GrayText}"
                                           HorizontalAlignment="Center"
                                           Margin="0,50"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>