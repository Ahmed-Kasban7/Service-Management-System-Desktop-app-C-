<Window x:Class="Presentation.View.CampaignView.CreateCampaignWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="إضافة حملة جديدة"
        Height="Auto" 
        Width="520"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Background="#EEF2F7"
        FlowDirection="RightToLeft"
        MinHeight="520"
        MinWidth="400">

    <Window.Resources>
        <!-- الألوان الأساسية -->
        <SolidColorBrush x:Key="PrimaryBlue" Color="#2563EB"/>
        <SolidColorBrush x:Key="PrimaryBlueDark" Color="#1D4ED8"/>
        <SolidColorBrush x:Key="PrimaryBlueLight" Color="#DBEAFE"/>
        <SolidColorBrush x:Key="DangerRed" Color="#DC2626"/>
        <SolidColorBrush x:Key="DangerRedDark" Color="#991B1B"/>
        <SolidColorBrush x:Key="SuccessGreen" Color="#16A34A"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#1E293B"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#64748B"/>
        <SolidColorBrush x:Key="BorderColor" Color="#E2E8F0"/>

        <!-- الأنماط المشتركة -->
        <Style x:Key="FieldHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="ErrorText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource DangerRed}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="Visibility" Value="Collapsed"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>




        <Style x:Key="ModernDatePicker" TargetType="DatePicker">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Border Background="{TemplateBinding Background}"
                     BorderBrush="{TemplateBinding BorderBrush}"
                     BorderThickness="{TemplateBinding BorderThickness}"
                     CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <DatePickerTextBox x:Name="PART_TextBox"
                                        Grid.Column="0"
                                        Foreground="{TemplateBinding Foreground}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="{TemplateBinding Padding}"
                                        VerticalContentAlignment="Center"/>
                                <Button x:Name="PART_Button"
                             Grid.Column="1"
                             Width="32"
                             Background="Transparent"
                             BorderThickness="0"
                             Cursor="Hand">
                                    <TextBlock Text="📅" FontSize="16"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                                </Button>
                                <Popup x:Name="PART_Popup"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#2563EB"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter Property="BorderBrush" Value="#2563EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <!-- زر رئيسي -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Width" Value="130"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryBlueDark}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#94A3B8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- زر إلغاء -->
        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource DangerRed}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource DangerRedDark}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- الهيكل الرئيسي -->
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- العنوان مع أيقونة -->
        <TextBlock Grid.Row="0"
                   Text="📢 إضافة حملة جديدة"
                   FontSize="20" FontWeight="Bold"
                   Foreground="{StaticResource PrimaryBlue}"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,15"/>

        <!-- محتوى النموذج -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      MaxHeight="520">
            <Border Background="White"
                    CornerRadius="12"
                    Padding="20"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1">
                <StackPanel>

                    <!-- اسم الحملة -->
                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Style="{StaticResource FieldHeader}">
                            <Run Text="اسم الحملة"/>
                            <Run Text="*" Foreground="{StaticResource DangerRed}"/>
                        </TextBlock>
                        <TextBox x:Name="TxtCampaignName"
                                 Style="{StaticResource ModernTextBox}"/>
                        <TextBlock x:Name="TxtNameError"
                                   Style="{StaticResource ErrorText}"/>
                    </StackPanel>

                    <!-- المصدر -->
                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Style="{StaticResource FieldHeader}">
                            <Run Text="منصة الإعلان"/>
                            <Run Text="*" Foreground="{StaticResource DangerRed}"/>
                        </TextBlock>
                        <ComboBox x:Name="CbSources"
                                  Style="{StaticResource ModernComboBox}"
                                  DisplayMemberPath="SourceName"
                                  SelectedValuePath="Id"/>
                        <TextBlock x:Name="TxtSourcesError"
                                   Style="{StaticResource ErrorText}"/>
                    </StackPanel>

                    <!-- تكلفة الحملة -->
                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Style="{StaticResource FieldHeader}">
                            <Run Text="تكلفة الحملة"/>
                            <Run Text="*" Foreground="{StaticResource DangerRed}"/>
                        </TextBlock>
                        <TextBox x:Name="TxtCost"
                                 Style="{StaticResource ModernTextBox}"
                                 Text="0"
                                 Height="38"/>
                        <TextBlock x:Name="TxtCostError"
                                   Style="{StaticResource ErrorText}"/>
                    </StackPanel>

                    <!-- التواريخ -->
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- تاريخ البداية -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FieldHeader}">
                                <Run Text="تاريخ البداية"/>
                                <Run Text="*" Foreground="{StaticResource DangerRed}"/>
                            </TextBlock>
                            <DatePicker x:Name="DpStartDate"
                                        Style="{StaticResource ModernDatePicker}"
                                        SelectedDateFormat="Short"/>
                            <TextBlock x:Name="TxtStartDateError"
                                       Style="{StaticResource ErrorText}"/>
                        </StackPanel>

                        <!-- تاريخ النهاية -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource FieldHeader}">
                                <Run Text="تاريخ النهاية"/>
                                <Run Text="*" Foreground="{StaticResource DangerRed}"/>
                            </TextBlock>
                            <DatePicker x:Name="DpEndDate"
                                        Style="{StaticResource ModernDatePicker}"
                                        SelectedDateFormat="Short"/>
                            <TextBlock x:Name="TxtEndDateError"
                                       Style="{StaticResource ErrorText}"/>
                        </StackPanel>
                    </Grid>

                    <!-- الخصم -->
                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Style="{StaticResource FieldHeader}">
                            <Run Text="نسبة الخصم"/>
                            <Run Text="%" Foreground="{StaticResource TextSecondary}"/>
                        </TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtDiscount"
                                     Grid.Column="0"
                                     Style="{StaticResource ModernTextBox}"
                                     Text="0"
                                     Height="38"/>
                        </Grid>
                        <TextBlock x:Name="TxtDiscountError"
                                   Style="{StaticResource ErrorText}"/>
                    </StackPanel>

                    <!-- ملاحظات -->
                    <StackPanel>
                        <TextBlock Style="{StaticResource FieldHeader}">
                            <Run Text="ملاحظات"/>
                        </TextBlock>
                        <TextBox x:Name="TxtNotes"
                                 Style="{StaticResource ModernTextBox}"
                                 Height="80"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 VerticalContentAlignment="Top"/>
                    </StackPanel>

                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- الأزرار -->
        <Border Grid.Row="2"
                Padding="0,16,0,0"
                BorderThickness="0,1,0,0"
                BorderBrush="{StaticResource BorderColor}">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,4,0,0">
                <Button x:Name="BtnSave"
                        Style="{StaticResource PrimaryButton}"
                        Click="BtnSave_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="➕" Margin="0,0,6,0"/>
                        <TextBlock Text="إضافة"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnCancel"
                        Style="{StaticResource DangerButton}"
                        Margin="12,0,0,0"
                        Click="BtnCancel_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✖" Margin="0,0,6,0"/>
                        <TextBlock Text="إلغاء"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
