<UserControl x:Class="Presentation.View.CustomerView.CustomerProfileUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             Background="#EEF2F7"
             FlowDirection="RightToLeft">
    
    <UserControl.Resources>
        <!-- ... موارد أخرى ... -->

        <!-- =====  قالب زر الإجراءات الموحد  ===== -->
        <ControlTemplate x:Key="ActionButtonTemplate" TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="9" 
                Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" 
                              VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Tag}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </UserControl.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White"
                BorderThickness="0,0,0,1" BorderBrush="#EDF2F7"
                Padding="24,16">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" Color="#000" Opacity="0.03" ShadowDepth="2"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                        <Button x:Name="BtnBack" Click="BtnBack_Click"
                                Width="32" Height="32"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Margin="0,0,12,0" VerticalAlignment="Center">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                        <Path Data="M8 4L2 10L8 16"
                                              Stroke="#64748B" StrokeThickness="2"
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Width="10" Height="14" Stretch="Uniform"
                                              FlowDirection="LeftToRight"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F1F5F9"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <TextBlock VerticalAlignment="Center" FontSize="22">
                            <Run Text="عميل" Foreground="#64748B" FontWeight="Medium"/>
                            <Run Text=" "/>
                            <Run x:Name="RunCustomerCode" Text="#---"
                                 Foreground="#2563EB" FontWeight="Bold"
                                 FlowDirection="LeftToRight"/>
                        </TextBlock>
                    </StackPanel>

                    <TextBlock x:Name="TxtCreatedDate"
                               Text="تاريخ التسجيل: ---"
                               FontSize="12" Foreground="#64748B"
                               Margin="44,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- زر حذف العميل -->
                  
                    <!-- زر تعديل البيانات -->
                    <StackPanel Grid.Column="2" 
              Orientation="Horizontal" 
              VerticalAlignment="Center">

                        <!-- زر التعديل -->
                        <Button x:Name="BtnEdit"
              Click="BtnEditCustomer_Click"
              Content="✏️ تعديل البيانات"
              Padding="16,8"
              Margin="0,0,8,0"
              Background="White"
              Foreground="#1E293B"
              FontSize="13" 
              FontWeight="SemiBold"
              BorderBrush="#E2E8F0" 
              BorderThickness="1.5"
              Cursor="Hand" 
              VerticalAlignment="Center"
              Tag="#F8FAFC"
              Template="{StaticResource ActionButtonTemplate}" />

                        <!-- زر الحذف -->
                        <Button x:Name="BtnDelete"
              Click="BtnDeleteCustomer_Click"
              Content="🗑️ حذف العميل"
              Padding="16,8"
              Background="White" 
              Foreground="#EF4444"
              FontSize="13" 
              FontWeight="SemiBold"
              BorderBrush="#FCA5A5" 
              BorderThickness="1.5"
              Cursor="Hand" 
              VerticalAlignment="Center"
              Tag="#FEF2F2"
              Template="{StaticResource ActionButtonTemplate}" />
                    </StackPanel>


                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="White"
                BorderThickness="0,0,0,1" BorderBrush="#F1F5F9"
                Padding="24,0">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="TabBasicInfo" Content="البيانات الأساسية"
                        Click="TabBasicInfo_Click"
                        Padding="16,12" Background="Transparent"
                        BorderThickness="0,0,0,3" BorderBrush="#2563EB"
                        Foreground="#2563EB" FontWeight="SemiBold" FontSize="13" Cursor="Hand"/>

                <Button x:Name="TabPhones" Content="الهواتف"
                        Click="TabPhones_Click"
                        Padding="16,12" Background="Transparent"
                        BorderThickness="0,0,0,3" BorderBrush="Transparent"
                        Foreground="#64748B" FontSize="13" Cursor="Hand"/>

                <Button x:Name="TabDevices" Content="الأجهزة"
                        Click="TabDevices_Click"
                        Padding="16,12" Background="Transparent"
                        BorderThickness="0,0,0,3" BorderBrush="Transparent"
                        Foreground="#64748B" FontSize="13" Cursor="Hand"/>

                <Button x:Name="TabOrders" Content="الطلبات"
                        Click="TabOrders_Click"
                        Padding="16,12" Background="Transparent"
                        BorderThickness="0,0,0,3" BorderBrush="Transparent"
                        Foreground="#64748B" FontSize="13" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <Grid Margin="24,20,24,24">

                <!-- ============================================ -->
                <!--   بطاقة البيانات الأساسية (عرض)              -->
                <!-- ============================================ -->
                <Border x:Name="PanelBasicInfo" 
        Visibility="Visible"
        Background="White" 
        CornerRadius="14"
        BorderBrush="#E2E8F0" 
        BorderThickness="1" 
        Padding="22,20">

                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" 
                          Color="#000" 
                          Opacity="0.04" 
                          ShadowDepth="1" />
                    </Border.Effect>

                    <StackPanel FlowDirection="RightToLeft">

                        <!-- =====  العنوان  ===== -->
                        <TextBlock Text="📋 البيانات الأساسية"
                   FontSize="16" 
                   FontWeight="Bold"
                   Foreground="#0F172A" 
                   Margin="0,0,0,18" />

                        <!-- =====  الصف الأول: كود العميل + الاسم  ===== -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="كود العميل" 
                           FontSize="11" 
                           Foreground="#94A3B8" 
                           Margin="0,0,0,4" />
                                <TextBlock x:Name="TxtProfileID" 
                           Text="---" 
                           FontSize="15" 
                           FontWeight="SemiBold" 
                           Foreground="#0F172A" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="الاسم الكامل" 
                           FontSize="11" 
                           Foreground="#94A3B8" 
                           Margin="0,0,0,4" />
                                <TextBlock x:Name="TxtProfileName" 
                           Text="---" 
                           FontSize="15" 
                           FontWeight="SemiBold" 
                           Foreground="#0F172A" 
                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>

                        <Rectangle Height="1" 
                   Fill="#F1F5F9" 
                   Margin="0,0,0,16" />

                        <!-- =====  الصف الثاني: الجنس + العمر  ===== -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="الجنس" 
                           FontSize="11" 
                           Foreground="#94A3B8" 
                           Margin="0,0,0,4" />
                                <TextBlock x:Name="TxtProfileSex" 
                           Text="---" 
                           FontSize="15" 
                           FontWeight="SemiBold" 
                           Foreground="#0F172A" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="العمر" 
                           FontSize="11" 
                           Foreground="#94A3B8" 
                           Margin="0,0,0,4" />
                                <TextBlock x:Name="TxtProfileAge" 
                           Text="---" 
                           FontSize="15" 
                           FontWeight="SemiBold" 
                           Foreground="#0F172A" />
                            </StackPanel>
                        </Grid>

                        <Rectangle Height="1" 
                   Fill="#F1F5F9" 
                   Margin="0,0,0,16" />

                        <!-- =====  الصف الثالث: مصدر العميل + الحملة  ===== -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="مصدر العميل" 
                           FontSize="11" 
                           Foreground="#94A3B8" 
                           Margin="0,0,0,4" />
                                <TextBlock x:Name="TxtProfileSource" 
                           Text="---" 
                           FontSize="15" 
                           FontWeight="SemiBold" 
                           Foreground="#0F172A" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="الحملة" 
                           FontSize="11" 
                           Foreground="#94A3B8" 
                           Margin="0,0,0,4" />
                                <TextBlock x:Name="TxtProfileCampaign" 
                           Text="---" 
                           FontSize="15" 
                           FontWeight="SemiBold" 
                           Foreground="#374151" 
                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>

                        <Rectangle Height="1" 
                   Fill="#F1F5F9" 
                   Margin="0,0,0,16" />

                        <!-- =====  الصف الرابع: العنوان (صف كامل)  ===== -->
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="العنوان" 
                       FontSize="11" 
                       Foreground="#94A3B8" 
                       Margin="0,0,0,4" />
                            <TextBlock x:Name="TxtProfileAddress" 
                       Text="---" 
                       FontSize="14" 
                       FontWeight="SemiBold" 
                       Foreground="#374151" 
                       TextWrapping="Wrap" />
                        </StackPanel>

                        <Rectangle Height="1" 
                   Fill="#F1F5F9" 
                   Margin="0,0,0,16" />

                        <!-- =====  الصف الخامس: نسبة الخصم  ===== -->
                        <StackPanel>
                            <TextBlock Text="نسبة الخصم (%)" 
                       FontSize="11" 
                       Foreground="#94A3B8" 
                       Margin="0,0,0,4" />
                            <TextBlock x:Name="TxtProfileDiscount" 
                       Text="---" 
                       FontSize="15" 
                       FontWeight="SemiBold" 
                       Foreground="#059669" />
                        </StackPanel>

                    </StackPanel>
                </Border>

                <Border x:Name="PanelPhones" Visibility="Collapsed"
                        Background="White" CornerRadius="14"
                        BorderBrush="#E2E8F0" BorderThickness="1" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" Color="#000" Opacity="0.03" ShadowDepth="1"/>
                    </Border.Effect>
                    <StackPanel FlowDirection="RightToLeft">
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="📱 الهواتف المسجلة"
                                       FontSize="15" FontWeight="Bold"
                                       Foreground="#1E293B" VerticalAlignment="Center"/>
                            <Button x:Name="BtnAddPhone" Grid.Column="1"
                                    Content="➕ إضافة رقم"
                                    Click="BtnAddPhone_Click" IsEnabled="False"
                                    Background="#2563EB" Foreground="White"
                                    Padding="12,7" FontSize="13" FontWeight="SemiBold"
                                    BorderThickness="0" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.5"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                        <ItemsControl x:Name="PhonesList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F9FAFB" BorderBrush="#E5E7EB"
                                            BorderThickness="1" CornerRadius="12"
                                            Padding="14,12" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="40" Height="40" Background="#D1FAE5"
                                                    CornerRadius="20" Margin="0,0,12,0">
                                                <TextBlock Text="📱" FontSize="18"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="{Binding}"
                                                       FontWeight="SemiBold" FontSize="15"
                                                       VerticalAlignment="Center"
                                                       Foreground="#0F172A"/>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <Button Content="✏️" ToolTip="تعديل الهاتف"
                                                        Background="#2563EB"
                                                        Style="{StaticResource IconButtonStyle}"
                                                        Tag="{Binding}" Click="BtnEditPhone_Click"
                                                        Margin="0,0,6,0"/>
                                                <Button Content="🗑️" ToolTip="حذف الهاتف"
                                                        Background="#EF4444"
                                                        Style="{StaticResource IconButtonStyle}"
                                                        Tag="{Binding}" Click="BtnDeletePhone_Click"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock x:Name="TxtNoPhonesMessage"
                                   Text="لا توجد أرقام هواتف مسجلة"
                                   Foreground="#94A3B8" FontSize="13"
                                   HorizontalAlignment="Center"
                                   Margin="0,40,0,40" Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <Border x:Name="PanelDevices" Visibility="Collapsed"
                        Background="White" CornerRadius="14"
                        BorderBrush="#E2E8F0" BorderThickness="1" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" Color="#000" Opacity="0.03" ShadowDepth="1"/>
                    </Border.Effect>

                    <Grid>
                        <StackPanel x:Name="SubPanelDevicesList" Visibility="Visible" FlowDirection="RightToLeft">
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="🧺 الأجهزة المسجلة"
                                           FontSize="15" FontWeight="Bold"
                                           Foreground="#1E293B" VerticalAlignment="Center"/>
                                <Button x:Name="BtnAddDevice" Grid.Column="1"
                                        Content="➕ إضافة جهاز"
                                        Click="BtnAddDevice_Click" IsEnabled="False"
                                        Background="#2563EB" Foreground="White"
                                        Padding="12,7" FontSize="13" FontWeight="SemiBold"
                                        BorderThickness="0" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.5"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>

                            <ItemsControl x:Name="DevicesList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="White" BorderBrush="#E5E7EB"
                                                BorderThickness="1" CornerRadius="14"
                                                Padding="18" Margin="0,0,0,14">
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="48" Height="48" Background="#EEF2FF"
                                                            CornerRadius="12" Margin="0,0,12,0">
                                                        <TextBlock Text="🧺" FontSize="24"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding TypeName}" FontSize="15" FontWeight="SemiBold" Foreground="#111827"/>
                                                            <TextBlock Text=" - " FontSize="15" FontWeight="SemiBold" Foreground="#111827"/>
                                                            <TextBlock Text="{Binding BrandName}" FontSize="15" FontWeight="SemiBold" Foreground="#111827"/>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding SpecName}" FontSize="13" Foreground="#4B5563" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
                                                        <Button Content="✏️" ToolTip="تعديل بيانات الجهاز"
                                                                Background="#2563EB"
                                                                Style="{StaticResource IconButtonStyle}"
                                                                Click="BtnEditDevice_Click"
                                                                Tag="{Binding}" Margin="0,0,6,0"/>
                                                        <Button Content="📜" ToolTip="تاريخ صيانة الجهاز"
                                                                Background="#2563EB"
                                                                Style="{StaticResource IconButtonStyle}"
                                                                Click="BtnDeviceHistory_Click"
                                                                Tag="{Binding}" Margin="0,0,6,0"/>
                                                        <Button Content="🗑️" ToolTip="حذف الجهاز"
                                                                Background="#EF4444"
                                                                Style="{StaticResource IconButtonStyle}"
                                                                Click="BtnDeleteDevice_Click"
                                                                Tag="{Binding}"/>
                                                    </StackPanel>
                                                </Grid>
                                                <Border Height="1" Background="#F3F4F6" Margin="60,8,0,8"/>
                                                <WrapPanel Margin="60,0,0,0">
                                                    
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                                                        <StackPanel.Style>
                                                            <Style TargetType="StackPanel">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding SerialNumber}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding SerialNumber}" Value="">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </StackPanel.Style>
                                                        <StackPanel x:Name="HistorySerialPanel" Orientation="Horizontal" Margin="0,0,20,0" FlowDirection="LeftToRight">
                                                            <TextBlock Text="S/N: " FontSize="11" Foreground="#9CA3AF" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding SerialNumber}" FontSize="12" FontWeight="SemiBold" Foreground="#374151" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <StackPanel.Style>
                                                            <Style TargetType="StackPanel">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Model}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Model}" Value="">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </StackPanel.Style>
                                                        <TextBlock Text="الموديل: " FontSize="11" Foreground="#9CA3AF" Margin="0,0,4,0"/>
                                                        <TextBlock Text="{Binding Model}" FontSize="12" FontWeight="SemiBold" Foreground="#374151"/>
                                                    </StackPanel>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock x:Name="TxtNoDevicesMessage"
                                       Text="لا توجد أجهزة مسجلة"
                                       Foreground="#94A3B8" FontSize="13"
                                       HorizontalAlignment="Center"
                                       Margin="0,40,0,40" Visibility="Collapsed"/>
                        </StackPanel>

                        <StackPanel x:Name="PanelDeviceHistory" Visibility="Collapsed" FlowDirection="RightToLeft">
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="BtnBackToDevices" Click="BtnBackToDevices_Click"
                                        Width="32" Height="32" Background="Transparent" BorderThickness="0"
                                        Cursor="Hand" Margin="0,0,12,0" VerticalAlignment="Center">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                <Path Data="M8 4L2 10L8 16"
                                                      Stroke="#64748B" StrokeThickness="2"
                                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      Width="10" Height="14" Stretch="Uniform"
                                                      FlowDirection="LeftToRight"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#F1F5F9"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <TextBlock Grid.Column="1" Text="📜 تاريخ صيانة الجهاز"
                                           FontSize="15" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                            </Grid>

                            <Border Background="#F8FAFC" CornerRadius="10" BorderBrush="#E2E8F0" BorderThickness="1" Padding="16,12" Margin="0,0,0,16">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Width="48" Height="48" Background="#EEF2FF" CornerRadius="12" Margin="0,0,12,0">
                                            <TextBlock Text="🧺" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock x:Name="TxtHistoryDeviceName" FontSize="15" FontWeight="SemiBold" Foreground="#111827"/>
                                            <TextBlock x:Name="TxtHistoryDeviceDetails" FontSize="13" Foreground="#4B5563" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>
                                    <Border Height="1" Background="#F3F4F6" Margin="52,8,0,8"/>

                                    <WrapPanel Margin="52,0,0,0" x:Name="HistoryDeviceSpecsPanel" FlowDirection="RightToLeft">
                            

                                        <StackPanel x:Name="HistorySerialPanel" Orientation="Horizontal" Margin="0,0,20,0" FlowDirection="LeftToRight">
                                            <TextBlock Text="S/N: " FontSize="11" Foreground="#9CA3AF" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="TxtHistorySerial" FontSize="12" FontWeight="SemiBold" Foreground="#374151" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                        </StackPanel>

                                        <StackPanel x:Name="HistoryModelPanel" Orientation="Horizontal" FlowDirection="RightToLeft">
                                            <TextBlock Text="الموديل: " FontSize="11" Foreground="#9CA3AF" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="TxtHistoryModel" FontSize="12" FontWeight="SemiBold" Foreground="#374151" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        </StackPanel>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <Border Height="1" Background="#F1F5F9" Margin="0,0,0,14"/>

                            <DataGrid x:Name="DeviceOrdersList"
          AutoGenerateColumns="False"
          GridLinesVisibility="Horizontal"
          HorizontalGridLinesBrush="#F1F5F9"
          HeadersVisibility="Column"
          Background="Transparent"
          BorderThickness="0"
          RowHeaderWidth="0"
          IsReadOnly="True"
          CanUserAddRows="False"
          SelectionMode="Single"
          ColumnWidth="*"
          MouseDoubleClick="DeviceOrdersList_MouseDoubleClick">

                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="كود الطلب"
                        Binding="{Binding OrderNumber, StringFormat='#{0}'}"
                        Width="*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FlowDirection" Value="LeftToRight"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="المشكلة"
                        Binding="{Binding Problem}"
                        Width="1.5*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextWrapping" Value="NoWrap"/>
                                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="تاريخ بدء الصيانة"
                        Binding="{Binding Date, StringFormat={}{0:yyyy/MM/dd}}"
                        Width="*"/>
                                    <DataGridTemplateColumn Header="الحالة" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="10" Padding="8,2"
                        Background="{Binding StatusBackground}"
                        HorizontalAlignment="Center">
                                                    <TextBlock Text="{Binding State}"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{Binding StatusForeground}"/>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock x:Name="TxtNoDeviceOrdersMessage"
           Text="لا توجد طلبات صيانة لهذا الجهاز"
           Foreground="#94A3B8" FontSize="13"
           HorizontalAlignment="Center"
           Margin="0,40,0,40" Visibility="Collapsed"/>

                        </StackPanel>
                    </Grid>
                </Border>

                <Border x:Name="PanelOrders" Visibility="Collapsed"
        Background="White" CornerRadius="14"
        BorderBrush="#E2E8F0" BorderThickness="1" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" Color="#000" Opacity="0.03" ShadowDepth="1"/>
                    </Border.Effect>
                    <StackPanel FlowDirection="RightToLeft">
                        <TextBlock Text="📋 طلبات العميل" FontSize="15" FontWeight="Bold" 
                   Foreground="#1E293B" Margin="0,0,0,16"/>

                        <!-- Stats -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#F8FAFC" CornerRadius="10" Padding="12">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock x:Name="TxtTotalOrders" Text="٠" FontSize="22" FontWeight="Bold" Foreground="#0F172A" HorizontalAlignment="Center"/>
                                    <TextBlock Text="إجمالي الطلبات" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Background="#F8FAFC" CornerRadius="10" Padding="12">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock x:Name="TxtDoneOrders" Text="٠" FontSize="22" FontWeight="Bold" Foreground="#059669" HorizontalAlignment="Center"/>
                                    <TextBlock Text="مكتملة" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="4" Background="#F8FAFC" CornerRadius="10" Padding="12">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock x:Name="TxtActiveOrders" Text="٠" FontSize="22" FontWeight="Bold" Foreground="#D97706" HorizontalAlignment="Center"/>
                                    <TextBlock Text="جارى التنفيذ" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Height="1" Background="#F1F5F9" Margin="0,0,0,14"/>

                        <!-- DataGrid مباشرة هنا بدل ItemsControl -->
                        <DataGrid x:Name="OrdersList"
                  AutoGenerateColumns="False"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  Background="Transparent"
                  BorderThickness="0"
                  RowHeaderWidth="0"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  SelectionMode="Single"
                                            HorizontalGridLinesBrush="#F1F5F9"

                  MouseDoubleClick="OrdersList_MouseDoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="كود الطلب"
                                    Binding="{Binding OrderNumber}"
                                    Width="*" />
                                <DataGridTextColumn Header="الجهاز"
                                    Binding="{Binding DeviceSummary}"
                                    Width="*"/>
                                <DataGridTextColumn Header="تاريخ بدء الصيانة"
                                    Binding="{Binding StartDate, StringFormat={}{0:yyyy/MM/dd}}"
                                    Width="*"/>
                                
                                <DataGridTemplateColumn Header="الحالة" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="10" Padding="8,2"
                                    Background="{Binding StatusBackground}"
                                    HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding StatusText}"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{Binding StatusForeground}"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock x:Name="TxtNoOrdersMessage" 
                   Text="لا توجد طلبات مسجلة لهذا العميل" 
                   Foreground="#94A3B8" FontSize="13"
                   HorizontalAlignment="Center"
                   Margin="0,40,0,40" Visibility="Collapsed"/>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>