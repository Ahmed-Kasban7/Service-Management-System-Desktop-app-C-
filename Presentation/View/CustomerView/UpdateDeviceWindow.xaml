<Window x:Class="Presentation.View.Customer_View.UpdateDeviceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تعديل بيانات الجهاز" 
        Height="Auto" Width="480" 
        SizeToContent="Height" 
        WindowStartupLocation="CenterOwner" 
        Background="#F8FAFC" 
        FlowDirection="RightToLeft">
    
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBlue" Color="#4169E1"/>
        <SolidColorBrush x:Key="SuccessGreen" Color="#27AE60"/>
        <SolidColorBrush x:Key="DangerRed" Color="#E53935"/>
        <SolidColorBrush x:Key="DangerRedDark" Color="#B71C1C"/>

        <Style x:Key="FieldHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="🧺 تعديل بيانات الجهاز" 
                   FontSize="18" FontWeight="Bold" 
                   Foreground="{StaticResource PrimaryBlue}" 
                   HorizontalAlignment="Center" 
                   Margin="0,0,0,15"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="500">
            <Border Background="White" CornerRadius="12" Padding="15"
                    BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,5">
                <StackPanel>
                    <TextBlock Text="📝 بيانات الجهاز" FontWeight="Bold" FontSize="14"
                               Foreground="{StaticResource PrimaryBlue}" Margin="0,0,0,12"/>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- نوع الجهاز -->
                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,10">
                            <TextBlock Margin="0,0,0,5" FontSize="11" FontWeight="SemiBold" Foreground="#475569">
                                <Run Text="نوع الجهاز"/>
                                <Run Text="*" Foreground="Red"/>
                            </TextBlock>
                            <ComboBox x:Name="CbType"
                                      Style="{StaticResource ModernComboBox}"
                                      Height="32"
                                      DisplayMemberPath="TypeName"
                                      SelectedValuePath="TypeID"
                                      SelectionChanged="CbType_SelectionChanged"/>
                            <TextBlock x:Name="TxtTypeError"
                                       Text="برجاء اختيار نوع الجهاز"
                                       Foreground="Red" FontSize="11"
                                       Margin="0,4,0,0" TextWrapping="Wrap"
                                       Visibility="Collapsed"/>
                        </StackPanel>

                        <!-- الماركة -->
                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,10">
                            <TextBlock Margin="0,0,0,5" FontSize="11" FontWeight="SemiBold" Foreground="#475569">
                                <Run Text="الماركة"/>
                                <Run Text="*" Foreground="Red"/>
                            </TextBlock>
                            <ComboBox x:Name="CbBrand"
                                      Style="{StaticResource ModernComboBox}"
                                      Height="32"
                                      DisplayMemberPath="BrandName"
                                      SelectedValuePath="BrandID"/>
                            <TextBlock x:Name="TxtBrandError"
                                       Text="برجاء اختيار الماركة"
                                       Foreground="Red" FontSize="11"
                                       Margin="0,4,0,0" TextWrapping="Wrap"
                                       Visibility="Collapsed"/>
                        </StackPanel>

                        <!-- المواصفات -->
                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,10">
                            <TextBlock Margin="0,0,0,5" FontSize="11" FontWeight="SemiBold" Foreground="#475569">
                                <Run Text="المواصفات"/>
                                <Run Text="*" Foreground="Red"/>
                            </TextBlock>
                            <ComboBox x:Name="CbSpec"
                                      Style="{StaticResource ModernComboBox}"
                                      Height="32"
                                      DisplayMemberPath="SpecName"
                                      SelectedValuePath="SpecID"/>
                            <TextBlock x:Name="TxtSpecError"
                                       Text="برجاء اختيار المواصفات"
                                       Foreground="Red" FontSize="11"
                                       Margin="0,4,0,0" TextWrapping="Wrap"
                                       Visibility="Collapsed"/>
                        </StackPanel>

                        <!-- الموديل -->
                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,10">
                            <TextBlock Text="الموديل" Margin="0,0,0,5"
                                       FontSize="11" FontWeight="SemiBold" Foreground="#475569"/>
                            <TextBox x:Name="TxtDeviceModel"
                                     Style="{StaticResource ModernTextBox}"
                                     Height="32"/>
                        </StackPanel>

                        <!-- الرقم التسلسلي -->
                        <StackPanel Grid.Row="2" Grid.ColumnSpan="3">
                            <TextBlock Text="الرقم التسلسلي" Margin="0,0,0,5"
                                       FontSize="11" FontWeight="SemiBold" Foreground="#475569"/>
                            <TextBox x:Name="TxtSerial"
                                     Style="{StaticResource ModernTextBox}"
                                     Height="32"/>
                        </StackPanel>

                    </Grid>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <Border Grid.Row="2" Padding="0,15,0,0"
    BorderThickness="0,1,0,0" BorderBrush="#CBD5E1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                <Button x:Name="BtnSave"
            Content="💾 تعديل"
            Width="130" Height="42"
            Background="{StaticResource SuccessGreen}"
            Foreground="White" FontWeight="Bold" Cursor="Hand"
            Click="BtnUpdate_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.9"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="BtnCancel"
            Content="❌ إلغاء"
            Margin="15,0,0,0"
            Width="100" Height="42"
            Background="{StaticResource DangerRed}"
            Foreground="White" FontWeight="Bold" Cursor="Hand"
            Click="BtnCancel_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{StaticResource DangerRedDark}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </StackPanel>
        </Border>
    </Grid>
</Window>