<Window x:Class="Presentation.View.Customer_View.CreateCustomerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" 
        Title="تسجيل عميل جديد" 
        Height="720" Width="520" 
        WindowStartupLocation="CenterScreen"
        Background="#EEF2F7"
        FlowDirection="RightToLeft">

    <Window.Resources>
        <Style x:Key="ModernDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F9F9F9"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderGray}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F0F2F5"/>
                        <Setter Property="Foreground" Value="{StaticResource DarkText}"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="{StaticResource BorderGray}"/>
                        <Setter Property="HorizontalContentAlignment" Value="Right"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="10"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#E3F2FD"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBlue}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text=" تسجيل عميل جديد" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryBlue}" Margin="0,0,0,10" TextAlignment="Center"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,5,0">
            <StackPanel>
                <Border Background="White" CornerRadius="12" Padding="15" Margin="0,0,0,12"
        BorderBrush="#E2E8F0" BorderThickness="1">

                    <StackPanel>

                        <TextBlock Text="👤 البيانات الأساسية"
                   FontWeight="Bold"
                   FontSize="14"
                   Foreground="{StaticResource PrimaryBlue}"
                   Margin="0,0,0,10"/>

                        <!-- الاسم -->
                        <TextBlock Style="{StaticResource FieldHeader}">
            <Run Text="الاسم الكامل"/> <Run Text="*" Foreground="Red"/>
                        </TextBlock>

                        <TextBox x:Name="TxtName"
                 Style="{StaticResource ModernTextBox}"
                 Margin="0,0,0,5"
                 Height="32"/>

                        <TextBlock x:Name="TxtNameError"
                   Text=""
                   Foreground="Red"
                   FontSize="11"
                   Visibility="Visible"
                   Margin="0,0,0,10"/>

                        <!-- Grid -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- العمر -->
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">

                                <TextBlock Text="العمر" Style="{StaticResource FieldHeader}"/>

                                <TextBox x:Name="TxtAge"
                         Style="{StaticResource ModernTextBox}"
                         Height="32"/>

                                <TextBlock x:Name="TxtAgeError"
                           Text=""
                           Foreground="Red"
                           FontSize="11"
                           Visibility="Visible"/>
                            </StackPanel>

                            <!-- الجنس -->
                            <StackPanel Grid.Column="1" Margin="0,0,8,0">

                                <TextBlock Style="{StaticResource FieldHeader}">
                    <Run Text="الجنس"/> <Run Text="*" Foreground="Red"/>
                                </TextBlock>

                                <ComboBox x:Name="CbSex"
                          Style="{StaticResource ModernComboBox}"
                          Height="32">
                                    <ComboBoxItem Content="ذكر" IsSelected="True"/>
                                    <ComboBoxItem Content="أنثى"/>
                                </ComboBox>

                                
                            </StackPanel>

                            <!-- الخصم -->
                            <StackPanel Grid.Column="2">

                                <TextBlock Text="الخصم %" Style="{StaticResource FieldHeader}"/>

                                <TextBox x:Name="TxtDiscount"
                         Text="0"
                         Style="{StaticResource ModernTextBox}"
                         Height="32"/>

                                <TextBlock x:Name="TxtDiscountError"
                           Text=""
                           Foreground="Red"
                           FontSize="11"
                           Visibility="Visible"/>
                            </StackPanel>
                        </Grid>

                        <!-- العنوان -->
                        <TextBlock Style="{StaticResource FieldHeader}" Margin="0,10,0,3">
            <Run Text="العنوان"/> <Run Text="*" Foreground="Red"/>
                        </TextBlock>

                        <TextBox x:Name="TxtAddress"
                 Style="{StaticResource ModernTextBox}"
                 Height="32"/>

                        <TextBlock x:Name="TxtAddressError"
                   Text=""
                   Foreground="Red"
                   FontSize="11"
                   Visibility="Visible"/>

                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="12" Padding="15" Margin="0,0,0,12" BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="📞 أرقام الهاتف" FontWeight="Bold" FontSize="14" Foreground="{StaticResource PrimaryBlue}" Margin="0,0,0,10"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBox x:Name="TxtNewPhone"
             Style="{StaticResource ModernTextBox}"
             Margin="0,0,8,0"
             Height="32"
             Grid.Row="0"
             Grid.Column="0"/>

                            <Button Grid.Row="0"
            Grid.Column="1"
            Content="إضافة"
            Background="{StaticResource PrimaryBlue}"
            Style="{StaticResource ActionButtonStyle}"
            Height="32"
            FontSize="12"
            Click="BtnAddPhoneToList_Click"/>

                            <TextBlock x:Name="txtPhoneError"
               Grid.Row="1"
               Grid.Column="0"
               Text=""
               Foreground="Red"
               FontSize="11"
               Visibility="Visible"
               Margin="2,2,0,0"/>
                        </Grid>

                        <ListBox x:Name="LstPhones" Height="70" Background="#F8FAFC" BorderBrush="#E2E8F0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Width="400">
                                        <TextBlock Text="{Binding}" VerticalAlignment="Center" FontSize="13"/>
                                        <Button Content="🗑️" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" 
                                                Foreground="{StaticResource DangerRed}" Click="BtnRemovePhone_Click" Cursor="Hand"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="12" Padding="15" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="🧺 بيانات الأجهزة" FontWeight="Bold" FontSize="14" Foreground="{StaticResource PrimaryBlue}" Margin="0,0,0,10"/>

                        <Border Background="#F9FAFB" CornerRadius="8" Padding="10" Margin="0,0,0,10" BorderBrush="#CBD5E1" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <!-- ERROR ROW -->
                                </Grid.RowDefinitions>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Type -->
                                <StackPanel Grid.Column="0" Margin="0,0,8,8">
                                    <TextBlock Style="{StaticResource FieldHeader}">
                <Run Text="نوع الجهاز"/> <Run Text="*" Foreground="Red"/>
                                    </TextBlock>
                                    <ComboBox x:Name="CbType" Style="{StaticResource ModernComboBox}" Height="32"
                      DisplayMemberPath="TypeName"
                      SelectedValuePath="TypeID"
                      SelectionChanged="CbType_SelectionChanged"/>
                                </StackPanel>

                                <!-- Brand -->
                                <StackPanel Grid.Column="1" Margin="0,0,0,8">
                                    <TextBlock Style="{StaticResource FieldHeader}">
                <Run Text="الماركة"/> <Run Text="*" Foreground="Red"/>
                                    </TextBlock>
                                    <ComboBox x:Name="CbBrand" Style="{StaticResource ModernComboBox}" Height="32"
                      DisplayMemberPath="BrandName"
                      SelectedValuePath="BrandID"/>
                                </StackPanel>

                                <!-- Spec -->
                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,8">
                                    <TextBlock Style="{StaticResource FieldHeader}">
                <Run Text="المواصفات"/> <Run Text="*" Foreground="Red"/>
                                    </TextBlock>
                                    <ComboBox x:Name="CbSpec" Style="{StaticResource ModernComboBox}" Height="32"
                      DisplayMemberPath="SpecName"
                      SelectedValuePath="SpecID"/>
                                </StackPanel>

                                <!-- Model -->
                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,8">
                                    <TextBlock Text="الموديل" Style="{StaticResource FieldHeader}"/>
                                    <TextBox x:Name="TxtDeviceModel" Style="{StaticResource ModernTextBox}" Height="32"/>
                                </StackPanel>

                                <!-- Serial -->
                                <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,0,0,10">
                                    <TextBlock Text="الرقم التسلسلي" Style="{StaticResource FieldHeader}"/>
                                    <TextBox x:Name="TxtSerial" Style="{StaticResource ModernTextBox}" Height="32"/>
                                </StackPanel>

                                <!-- ERROR TEXT -->
                                <TextBlock Grid.Row="3"
                   Grid.ColumnSpan="2"
                   x:Name="txtDeviceError"
                   Text=""
                   Foreground="Red"
                   FontSize="12"
                   Visibility="Visible"
                   Margin="2,0,0,6"/>
                                <!-- BUTTON -->
                                <Button Grid.Row="4" Grid.ColumnSpan="2"
                Content="➕ إضافة الجهاز للقائمة"
                Background="{StaticResource PrimaryBlue}"
                Style="{StaticResource ActionButtonStyle}"
                Height="35"
                Click="BtnAddDeviceToList_Click"
                FontSize="12"/>

                            </Grid>
                        </Border>
                        <DataGrid x:Name="DgTempDevices" 
          Style="{StaticResource ModernDataGrid}"
          Height="150" 
          AutoGenerateColumns="False" 
          CanUserAddRows="False" 
          IsReadOnly="True" 
          FontSize="12"
          ColumnWidth="*" 
          HorizontalScrollBarVisibility="Disabled"
          FlowDirection="RightToLeft">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="نوع الجهاز" Binding="{Binding TypeName}" Width="1.5*"/>
                                <DataGridTextColumn Header="الماركة" Binding="{Binding BrandName}" Width="*"/>
                                <DataGridTextColumn Header="المواصفات" Binding="{Binding SpecName}" Width="2*"/>

                                <DataGridTemplateColumn Width="50" CanUserResize="False">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Background="Transparent" 
        BorderThickness="0" 
        Cursor="Hand"
        Click="BtnDeleteDevice_Click"
        Tag="{Binding}">
                                                <Path Data="M 2,2 L 10,10 M 2,10 L 10,2" 
          Stroke="#FF5252" 
          StrokeThickness="2" 
          Width="12" Height="12" 
          Stretch="Uniform" 
          HorizontalAlignment="Center"/>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Padding="0,15,0,0" BorderThickness="0,1,0,0" BorderBrush="#CBD5E1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="BtnSaveAll" Content="💾 حفظ" Style="{StaticResource ActionButtonStyle}" Width="150" Height="38" Background="{StaticResource PrimaryBlue}" Click="BtnSaveAll_Click"/>
                <Button x:Name="BtnCancel" Content="❌ إلغاء" Style="{StaticResource ActionButtonStyle}" Margin="15,0,0,0" Width="100" Height="38" Background="#F1F5F9" Foreground="#64748B" BorderBrush="#CBD5E1" BorderThickness="1" Click="BtnCancel_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>