<UserControl x:Class="Presentation.View.DashboardView.DashboardUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Presentation.View.DashboardView"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             mc:Ignorable="d" 
             FlowDirection="RightToLeft"
             Background="#F4F7FC"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True"
             d:DesignHeight="950" d:DesignWidth="1200">

    <UserControl.Resources>
        <!-- ===== لوحة ألوان احترافية مشبعة ===== -->
        <SolidColorBrush x:Key="PrimaryBlue" Color="#4F46E5"/>
        <SolidColorBrush x:Key="PrimaryBlueTint" Color="#EEF2FF"/>
        <SolidColorBrush x:Key="LightBlue" Color="#E0E7FF"/>

        <!-- المكونات النصية المحايدة -->
        <SolidColorBrush x:Key="DarkText" Color="#0F172A"/>
        <SolidColorBrush x:Key="GrayText" Color="#475569"/>
        <SolidColorBrush x:Key="LightGray" Color="#F1F5F9"/>
        <SolidColorBrush x:Key="BorderGray" Color="#E2E8F0"/>

        <!-- ===== تدرجات كروت المقاييس العلوية ===== -->
        <!-- Customers -->
        <LinearGradientBrush x:Key="CustomersGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFF" Offset="0"/>
            <GradientStop Color="#F0F6FF" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="CustomersAccent" Color="#2563EB"/>
        <SolidColorBrush x:Key="CustomersAccentTint" Color="#EFF6FF"/>

        <!-- Employees -->
        <LinearGradientBrush x:Key="EmployeesGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFF" Offset="0"/>
            <GradientStop Color="#FAF5FF" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="EmployeesAccent" Color="#7C3AED"/>
        <SolidColorBrush x:Key="EmployeesAccentTint" Color="#F5F3FF"/>

        <!-- Orders -->
        <LinearGradientBrush x:Key="OrdersGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFF" Offset="0"/>
            <GradientStop Color="#FFF7ED" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="OrdersAccent" Color="#EA580C"/>
        <SolidColorBrush x:Key="OrdersAccentTint" Color="#FFF7ED"/>

        <!-- Appointments -->
        <LinearGradientBrush x:Key="AppointmentsGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFF" Offset="0"/>
            <GradientStop Color="#F0FDFA" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="AppointmentsAccent" Color="#0D9488"/>
        <SolidColorBrush x:Key="AppointmentsAccentTint" Color="#F0FDFA"/>

        <!-- ===== الألوان المالية الكلاسيكية ===== -->
        <LinearGradientBrush x:Key="IncomeGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFF" Offset="0"/>
            <GradientStop Color="#F0FDF4" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="IncomeGreen" Color="#16A34A"/>

        <LinearGradientBrush x:Key="ExpenseGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFF" Offset="0"/>
            <GradientStop Color="#FEF2F2" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="ExpenseRed" Color="#DC2626"/>

        <!-- كارت المحفظة الرئيسي الجذاب -->
        <LinearGradientBrush x:Key="PrimaryGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#4F46E5" Offset="0"/>
            <GradientStop Color="#6366F1" Offset="0.5"/>
            <GradientStop Color="#4338CA" Offset="1"/>
        </LinearGradientBrush>

        <!-- ===== الـ Styles المحسنة وتأثيرات الانيميشن والتفاعل ===== -->

        <Style x:Key="IconChip" TargetType="Border">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <!-- كارت الرسم البياني ومجموعة العناصر -->
        <Style x:Key="DashboardCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" Color="#0F172A" Opacity="0.03" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- استايل موحد وتفاعلي لكروت المقاييس العلوية (ترتفع عند التحويم) -->
        <Style x:Key="TopMetricCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderGray}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="0"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="16" Color="#0F172A" Opacity="0.04" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="-4" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="0" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBlue}"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="24" Color="#4F46E5" Opacity="0.08" ShadowDepth="4"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- استايل أزرار الفلترة الزمنية التفاعلية -->
        <Style x:Key="PeriodButton" TargetType="RadioButton">
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Foreground" Value="{StaticResource GrayText}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="Transparent" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryBlue}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryBlueTint}"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- قالب عرض الأسطر داخل جدول آخر الحركات المالي -->
        <DataTemplate x:Key="TransactionRowTemplate">
            <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Padding="4,12" Background="Transparent">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="10" Background="{Binding IconBackground}" Margin="0,0,14,0">
                        <TextBlock Text="{Binding IconGlyph}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{Binding IconForeground}"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Description}" FontSize="13.5" FontWeight="SemiBold" Foreground="{StaticResource DarkText}"/>
                        <TextBlock Text="{Binding ReferenceDisplayName}" FontSize="12" Foreground="{StaticResource GrayText}" Margin="0,3,0,0" Cursor="Hand" TextDecorations="Underline" MouseLeftButtonUp="ReferenceLink_Click" Tag="{Binding}"/>
                    </StackPanel>

                    <TextBlock Grid.Column="2" Text="{Binding FormattedAmount}" FontSize="15" FontWeight="Bold" VerticalAlignment="Center" Foreground="{Binding AmountColor}"/>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <!-- الحاوية الرئيسية الداعمة للتمرير بذكاء للمحتوى الداخلي دون الهيدر -->
    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===================== Header (ثابت ولا يختفي عند التمرير) ===================== -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Border Style="{StaticResource IconChip}" Background="{StaticResource PrimaryBlueTint}" VerticalAlignment="Center" Margin="0,0,16,0">
                    <Viewbox Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Canvas Width="24" Height="24">
                            <Rectangle Canvas.Left="3" Canvas.Top="3" Width="7" Height="7" RadiusX="2" RadiusY="2" Fill="{StaticResource PrimaryBlue}"/>
                            <Rectangle Canvas.Left="14" Canvas.Top="3" Width="7" Height="7" RadiusX="2" RadiusY="2" Fill="{StaticResource PrimaryBlue}"/>
                            <Rectangle Canvas.Left="3" Canvas.Top="14" Width="7" Height="7" RadiusX="2" RadiusY="2" Fill="{StaticResource PrimaryBlue}"/>
                            <Rectangle Canvas.Left="14" Canvas.Top="14" Width="7" Height="7" RadiusX="2" RadiusY="2" Fill="{StaticResource PrimaryBlue}"/>
                        </Canvas>
                    </Viewbox>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="لوحة التحكم" FontSize="26" FontWeight="Bold" Foreground="{StaticResource DarkText}"/>
                    <TextBlock Text="نظرة عامة على أداء ومؤشرات المركز الحالية" FontSize="14" Foreground="{StaticResource GrayText}" Margin="0,4,0,0"/>
                </StackPanel>
            </StackPanel>

            <Button Grid.Column="1" Content="↺ تحديث البيانات" Width="130" Height="40" Background="White" Foreground="{StaticResource PrimaryBlue}" BorderBrush="{StaticResource BorderGray}" BorderThickness="1" FontWeight="SemiBold" FontSize="13.5" Cursor="Hand" Click="BtnRefresh_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource PrimaryBlueTint}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- ===================== محتويات لوحة التحكم القابلة للتمرير ===================== -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,8,0">
            <StackPanel>

                <!-- 1️⃣ صف بطاقات المقاييس العلوية الأربعة -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- كارت العملاء -->
                    <Border Grid.Column="0" Style="{StaticResource TopMetricCard}" Background="{StaticResource CustomersGradient}" BorderBrush="#DBEAFE">
                        <StackPanel>
                            <Border Style="{StaticResource IconChip}" Background="White">
                                <Viewbox Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Ellipse Canvas.Left="8" Canvas.Top="3" Width="8" Height="8" Stroke="{StaticResource CustomersAccent}" StrokeThickness="2.5"/>
                                        <Path Data="M4,21 C4,16 8,14 12,14 C16,14 20,16 20,21" Stroke="{StaticResource CustomersAccent}" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    </Canvas>
                                </Viewbox>
                            </Border>
                            <TextBlock Text="إجمالي العملاء" FontSize="13" Foreground="{StaticResource CustomersAccent}" Margin="0,14,0,0" FontWeight="SemiBold"/>
                            <TextBlock Text="0" FontSize="32" FontWeight="Bold" Foreground="{StaticResource DarkText}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- كارت الموظفين -->
                    <Border Grid.Column="2" Style="{StaticResource TopMetricCard}" Background="{StaticResource EmployeesGradient}" BorderBrush="#EDE9FE">
                        <StackPanel>
                            <Border Style="{StaticResource IconChip}" Background="White">
                                <Viewbox Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Rectangle Canvas.Left="5" Canvas.Top="3" Width="14" Height="18" RadiusX="3.5" RadiusY="3.5" Stroke="{StaticResource EmployeesAccent}" StrokeThickness="2.5"/>
                                        <Rectangle Canvas.Left="9" Canvas.Top="1" Width="6" Height="3" RadiusX="1.5" RadiusY="1.5" Fill="{StaticResource EmployeesAccent}"/>
                                        <Ellipse Canvas.Left="9" Canvas.Top="7.5" Width="6" Height="6" Stroke="{StaticResource EmployeesAccent}" StrokeThickness="2"/>
                                        <Line X1="8" Y1="17" X2="16" Y2="17" Stroke="{StaticResource EmployeesAccent}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    </Canvas>
                                </Viewbox>
                            </Border>
                            <TextBlock Text="عدد الموظفين" FontSize="13" Foreground="{StaticResource EmployeesAccent}" Margin="0,14,0,0" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding TotalEmployees}" FontSize="32" FontWeight="Bold" Foreground="{StaticResource DarkText}" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding EmployeesBreakdownText}" FontSize="12" Foreground="{StaticResource EmployeesAccent}" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- كارت الأوردرات المفتوحة -->
                    <Border Grid.Column="4" Style="{StaticResource TopMetricCard}" Background="{StaticResource OrdersGradient}" BorderBrush="#FFEDD5" MouseLeftButtonUp="OrdersCard_Click">
                        <StackPanel>
                            <Border Style="{StaticResource IconChip}" Background="White">
                                <Viewbox Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Rectangle Canvas.Left="5" Canvas.Top="4" Width="14" Height="17" RadiusX="2.5" RadiusY="2.5" Stroke="{StaticResource OrdersAccent}" StrokeThickness="2.5"/>
                                        <Rectangle Canvas.Left="9" Canvas.Top="2" Width="6" Height="3" RadiusX="1.2" RadiusY="1.2" Fill="{StaticResource OrdersAccent}"/>
                                        <Line X1="8" Y1="10" X2="16" Y2="10" Stroke="{StaticResource OrdersAccent}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        <Line X1="8" Y1="14" X2="16" Y2="14" Stroke="{StaticResource OrdersAccent}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    </Canvas>
                                </Viewbox>
                            </Border>
                            <TextBlock Text="الأوردرات المفتوحة" FontSize="13" Foreground="{StaticResource OrdersAccent}" Margin="0,14,0,0" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding OpenOrdersCount}" FontSize="32" FontWeight="Bold" Foreground="{StaticResource DarkText}" Margin="0,4,0,0"/>
                            <Border Background="#FFEDD5" CornerRadius="6" Padding="6,2" HorizontalAlignment="Left" Margin="0,8,0,0">
                                <TextBlock Text="{Binding NewOrdersTodayText}" FontSize="11" FontWeight="Bold" Foreground="{StaticResource OrdersAccent}"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- كارت مواعيد اليوم -->
                    <Border Grid.Column="6" Style="{StaticResource TopMetricCard}" Background="{StaticResource AppointmentsGradient}" BorderBrush="#CCFBF1" MouseLeftButtonUp="AppointmentsCard_Click">
                        <StackPanel>
                            <Border Style="{StaticResource IconChip}" Background="White">
                                <Viewbox Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Rectangle Canvas.Left="4" Canvas.Top="5" Width="16" Height="15" RadiusX="2.5" RadiusY="2.5" Stroke="{StaticResource AppointmentsAccent}" StrokeThickness="2.5"/>
                                        <Line X1="4" Y1="9" X2="20" Y2="9" Stroke="{StaticResource AppointmentsAccent}" StrokeThickness="2.5"/>
                                        <Line X1="8" Y1="3" X2="8" Y2="6.5" Stroke="{StaticResource AppointmentsAccent}" StrokeThickness="2.5" StrokeStartLineCap="Round"/>
                                        <Ellipse Canvas.Left="10.5" Canvas.Top="12.5" Width="3.5" Height="3.5" Fill="{StaticResource AppointmentsAccent}"/>
                                    </Canvas>
                                </Viewbox>
                            </Border>
                            <TextBlock Text="مواعيد اليوم" FontSize="13" Foreground="{StaticResource AppointmentsAccent}" Margin="0,14,0,0" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding TodayAppointmentsCount}" FontSize="32" FontWeight="Bold" Foreground="{StaticResource DarkText}" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding AppointmentsBreakdownText}" FontSize="12" Foreground="{StaticResource AppointmentsAccent}" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- عنوان إدارة الخزنة -->
                <Border BorderBrush="{StaticResource BorderGray}" BorderThickness="0,0,0,1" Padding="0,24,0,12" Margin="0,12,0,16">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💰" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="إدارة المالية والخزنة" FontSize="18" FontWeight="Bold" Foreground="{StaticResource DarkText}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- 2️⃣ صف كروت الخزنة والتدفقات المالية الثلاثية -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.4*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <!-- الرصيد الإجمالي الحالي للمركز -->
                    <Border Grid.Column="0" CornerRadius="16" Padding="28" Background="{StaticResource PrimaryGradient}" ClipToBounds="True">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="28" Color="#4F46E5" Opacity="0.25" ShadowDepth="4"/>
                        </Border.Effect>
                        <Grid>
                            <Ellipse Width="180" Height="180" Fill="White" Opacity="0.06" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-70,-60,0"/>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="40" Height="40" CornerRadius="10" Background="#20FFFFFF" Margin="0,0,12,0">
                                        <Viewbox Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Canvas Width="24" Height="24">
                                                <Rectangle Canvas.Left="3" Canvas.Top="6" Width="18" Height="13" RadiusX="3.5" RadiusY="3.5" Stroke="White" StrokeThickness="2.5"/>
                                                <Ellipse Canvas.Left="14" Canvas.Top="11" Width="4" Height="4" Fill="White"/>
                                            </Canvas>
                                        </Viewbox>
                                    </Border>
                                    <TextBlock Text="الرصيد الإجمالي الحالي" FontSize="14" Foreground="#EEF2FF" VerticalAlignment="Center" FontWeight="Medium"/>
                                </StackPanel>
                                <TextBlock x:Name="txtcurrentbalance" Text="{Binding CurrentBalanceFormatted}" FontSize="38" FontWeight="Bold" Foreground="White" Margin="0,18,0,0"/>
                                <TextBlock x:Name="txtlastupdated" Text="{Binding LastUpdatedText}" FontSize="12" Foreground="#C7D2FE" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- الداخل اليومي -->
                    <Border Grid.Column="2" Style="{StaticResource DashboardCard}" Background="{StaticResource IncomeGradient}" BorderBrush="#BBF7D0">
                        <StackPanel VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="40" Height="40" CornerRadius="10" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,12,0">
                                    <Viewbox Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Canvas Width="24" Height="24">
                                            <Line X1="12" Y1="4" X2="12" Y2="17" Stroke="{StaticResource IncomeGreen}" StrokeThickness="2.5" StrokeStartLineCap="Round"/>
                                            <Path Data="M6,12 L12,18 L18,12" Stroke="{StaticResource IncomeGreen}" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeLineJoin="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                </Border>
                                <TextBlock Text="الداخل اليوم" FontSize="14" Foreground="{StaticResource IncomeGreen}" VerticalAlignment="Center" FontWeight="Bold"/>
                            </StackPanel>
                            <TextBlock Text="{Binding TodayInFormatted}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource IncomeGreen}" Margin="0,16,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- الخارج اليومي -->
                    <Border Grid.Column="4" Style="{StaticResource DashboardCard}" Background="{StaticResource ExpenseGradient}" BorderBrush="#FECACA">
                        <StackPanel VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="40" Height="40" CornerRadius="10" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,12,0">
                                    <Viewbox Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Canvas Width="24" Height="24">
                                            <Line X1="12" Y1="20" X2="12" Y2="7" Stroke="{StaticResource ExpenseRed}" StrokeThickness="2.5" StrokeStartLineCap="Round"/>
                                            <Path Data="M6,12 L12,6 L18,12" Stroke="{StaticResource ExpenseRed}" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeLineJoin="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                </Border>
                                <TextBlock Text="الخارج اليوم" FontSize="14" Foreground="{StaticResource ExpenseRed}" VerticalAlignment="Center" FontWeight="Bold"/>
                            </StackPanel>
                            <TextBlock Text="{Binding TodayOutFormatted}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource ExpenseRed}" Margin="0,16,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Rectangle Height="24" Fill="Transparent"/>

                <!-- 3️⃣ الصف السفلي: الرسوم البيانية وجدول آخر المعاملات -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <!-- كارت رسم بياني خطي لحركة الخزنة -->
                    <Border Grid.Column="0" Style="{StaticResource DashboardCard}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="14"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="مخطط حركة الخزنة" FontSize="16" FontWeight="Bold" Foreground="{StaticResource DarkText}" VerticalAlignment="Center"/>

                                <Border Grid.Column="1" Background="#F8FAFC" CornerRadius="10" Padding="2" BorderBrush="{StaticResource BorderGray}" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton x:Name="Btn7Days" Content="٧ أيام" GroupName="Period" IsChecked="True" Style="{StaticResource PeriodButton}" Checked="PeriodToggle_Checked"/>
                                        <RadioButton x:Name="Btn30Days" Content="٣٠ يوم" GroupName="Period" Style="{StaticResource PeriodButton}" Checked="PeriodToggle_Checked"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- خطوط الدليل وتفسير الألوان (Legend) -->
                            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                    <Border Width="10" Height="10" CornerRadius="2.5" Background="{StaticResource IncomeGreen}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="الإيرادات" FontSize="12" Foreground="{StaticResource GrayText}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                    <Border Width="10" Height="10" CornerRadius="2.5" Background="{StaticResource ExpenseRed}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="المصروفات" FontSize="12" Foreground="{StaticResource GrayText}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="14" Height="2" Background="{StaticResource PrimaryBlue}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="الرصيد التراكمي" FontSize="12" Foreground="{StaticResource GrayText}"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- الرسم البياني الأساسي لـ LiveCharts -->
                            <lvc:CartesianChart Grid.Row="2" Series="{Binding TrendSeries}" XAxes="{Binding TrendXAxes}" YAxes="{Binding TrendYAxes}" Margin="0,12,0,0" MinHeight="300"/>
                        </Grid>
                    </Border>

                    <!-- الجزء الأيمن (توزيع الفئات + كشف آخر الحركات) -->
                    <StackPanel Grid.Column="2">

                        <!-- توزيع المصروفات دائرياً -->
                        <Border Style="{StaticResource DashboardCard}" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="المصروفات حسب الفئة" FontSize="16" FontWeight="Bold" Foreground="{StaticResource DarkText}" Margin="0,0,0,16"/>
                                <lvc:PieChart Series="{Binding CategorySeries}" MinHeight="160" LegendPosition="Hidden"/>
                                <ItemsControl ItemsSource="{Binding CategoryLegend}" Margin="0,12,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Width="8" Height="8" CornerRadius="2" Background="{Binding ColorBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding CategoryName}" FontSize="12.5" Foreground="{StaticResource DarkText}"/>
                                                <TextBlock Grid.Column="2" Text="{Binding TotalFormatted}" FontSize="12.5" FontWeight="SemiBold" Foreground="{StaticResource DarkText}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- قائمة آخر العمليات النقدية المباشرة -->
                        <Border Style="{StaticResource DashboardCard}">
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="آخر الحركات المالية" FontSize="16" FontWeight="Bold" Foreground="{StaticResource DarkText}"/>
                                    <TextBlock Grid.Column="1" Text="عرض الكل ←" FontSize="13" Foreground="{StaticResource PrimaryBlue}" Cursor="Hand" FontWeight="Bold" MouseLeftButtonUp="ViewAll_Click"/>
                                </Grid>

                                <ItemsControl x:Name="RecentTransactionsList" ItemsSource="{Binding RecentTransactions}" ItemTemplate="{StaticResource TransactionRowTemplate}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <Rectangle Height="16" Fill="Transparent"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>